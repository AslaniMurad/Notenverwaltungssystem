<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Klasse erstellen</title>
  <link rel="stylesheet" href="/css/teacher-pages.css">
</head>
<body>
  <div class="container narrow">
    <div class="brand">
      <div class="logo-dot"></div>
      <div class="brand-title">Lehrer Panel</div>
    </div>
    <h1>Neue Klasse erstellen</h1>
    <div class="user-info">
      Eingeloggt als: <%= email %>
    </div>

    <form method="POST" action="/teacher/create-class">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-group">
        <label for="name">Klassenname:</label>
        <input type="text" id="name" name="name" required placeholder="z.B. 3AHIF">
      </div>

      <div class="form-group">
        <label for="subject">Fach:</label>
        <input type="text" id="subject" name="subject" required placeholder="z.B. Mathematik">
      </div>

      <button type="submit" class="btn">Klasse erstellen</button>
      <a class="btn btn-secondary" href="/teacher/classes">Abbrechen</a>
    </form>
  </div>
</body>
</html>