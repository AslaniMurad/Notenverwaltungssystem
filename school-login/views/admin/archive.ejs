<%
  const numberFormatter = new Intl.NumberFormat('de-AT');
  const shortDateFormatter = new Intl.DateTimeFormat('de-DE', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric'
  });
  const dateTimeFormatter = new Intl.DateTimeFormat('de-DE', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
  const formatNumber = (value) => numberFormatter.format(Number(value || 0));
  const formatDate = (value) => {
    if (!value) return '-';
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? String(value) : shortDateFormatter.format(parsed);
  };
  const formatDateTime = (value) => {
    if (!value) return '-';
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? String(value) : dateTimeFormatter.format(parsed);
  };
  const formatDateRange = (start, end) => `${formatDate(start)} bis ${formatDate(end)}`;
  const formatAverageGrade = (value) => {
    if (value == null) return '-';
    return Number(value).toFixed(2).replace('.', ',');
  };
  const buildSearchText = (...values) => values
    .filter((value) => value != null && String(value).trim() !== '')
    .join(' ')
    .toLowerCase();
  const buildExportUrl = (dataset) => selectedSchoolYear
    ? `/archive/export/${dataset}?school_year_id=${encodeURIComponent(selectedSchoolYear.id)}`
    : null;
  const selectedYearLabel = selectedSchoolYear
    ? formatDateRange(selectedSchoolYear.start_date, selectedSchoolYear.end_date)
    : 'Kein Schuljahr ausgewaehlt';
  const jumpLinks = [
    { href: '#archive-overview', label: 'Uebersicht', count: archiveStats?.totalRecords || 0 },
    { href: '#archive-log', label: 'Archivstatus', count: archiveEntries.length },
    { href: '#archive-classes', label: 'Klassen', count: classes.length },
    { href: '#archive-assignments', label: 'Zuordnungen', count: assignments.length },
    { href: '#archive-grades', label: 'Noten', count: grades.length }
  ];
  const getGradeTone = (value) => {
    const numeric = Number(value);
    if (numeric === 1) return 'grade-1';
    if (numeric === 2) return 'grade-2';
    if (numeric === 3) return 'grade-3';
    if (numeric === 4) return 'grade-4';
    if (numeric === 5) return 'grade-5';
    return 'grade-default';
  };
  const totalGrades = grades.length;
  const totalRecords = archiveStats?.totalRecords || 0;
  const page = {
    title: 'Admin - Archiv',
    headerTitle: 'Adminbereich',
    styles: ['/css/admin.css', '/css/admin-archive.css'],
    scripts: ['/js/app.js', '/js/archive.js'],
    bodyClass: 'page-admin',
    hideHeader: true,
    hideFooter: true,
    content: function () { %>
    <div class="app-shell">
      <%- include('./nav-school-year', { csrfToken, currentUser, activePath, activeSchoolYear }) %>

      <section class="app-main archive-page">
        <section class="admin-card archive-hero" id="archive-overview">
          <div class="archive-hero-head">
            <div>
              <p class="app-main-subtitle">Archiv</p>
              <h1>Archivdaten</h1>
            </div>
            <div class="archive-toolbar-actions">
              <a class="btn btn-secondary" href="/admin/rollover">Schuljahreswechsel</a>
              <a class="btn btn-secondary" href="/admin">Admin</a>
            </div>
          </div>

          <dl class="archive-meta-grid">
            <div class="archive-meta-item">
              <dt>Schuljahr</dt>
              <dd><%= selectedSchoolYear?.name || 'Kein Schuljahr' %></dd>
            </div>
            <div class="archive-meta-item">
              <dt>Zeitraum</dt>
              <dd><%= selectedYearLabel %></dd>
            </div>
            <div class="archive-meta-item">
              <dt>Datensaetze</dt>
              <dd><%= formatNumber(totalRecords) %></dd>
            </div>
            <div class="archive-meta-item">
              <dt>Durchschnitt</dt>
              <dd><%= formatAverageGrade(archiveStats?.averageGrade) %></dd>
            </div>
            <div class="archive-meta-item">
              <dt>Schueler</dt>
              <dd><%= formatNumber(archiveStats?.uniqueStudents || 0) %></dd>
            </div>
            <div class="archive-meta-item">
              <dt>Lehrkraefte</dt>
              <dd><%= formatNumber(archiveStats?.uniqueTeachers || 0) %></dd>
            </div>
            <div class="archive-meta-item">
              <dt>Archivtypen</dt>
              <dd><%= formatNumber(archiveStats?.archiveTypes || 0) %></dd>
            </div>
            <div class="archive-meta-item">
              <dt>Letzte Aktivitaet</dt>
              <dd><%= formatDateTime(archiveStats?.latestActivityAt) %></dd>
            </div>
          </dl>

          <% if (activeSchoolYear) { %>
            <div class="archive-context-note">
              Aktiv: <strong><%= activeSchoolYear.name %></strong>
              <% if (selectedSchoolYear && Number(activeSchoolYear.id) !== Number(selectedSchoolYear.id)) { %>
                <span> | Ansicht: <%= selectedSchoolYear.name %></span>
              <% } %>
            </div>
          <% } %>
        </section>

        <section class="admin-card archive-toolbar">
          <div class="archive-toolbar-head">
            <div>
              <p class="admin-eyebrow">Ansicht</p>
              <h2>Schuljahr / Export</h2>
            </div>
          </div>

          <% if (!schoolYears.length) { %>
            <div class="admin-empty">Es sind noch keine Schuljahre hinterlegt.</div>
          <% } else { %>
            <div class="archive-toolbar-grid">
              <form class="admin-form archive-filter-form" method="GET" action="/archive">
                <label class="archive-search-field archive-select-field">
                  <span>Schuljahr</span>
                  <select name="school_year_id" required>
                    <% schoolYears.forEach((schoolYear) => { %>
                      <option value="<%= schoolYear.id %>" <%= Number(selectedSchoolYear?.id) === Number(schoolYear.id) ? 'selected' : '' %>>
                        <%= schoolYear.name %><%= schoolYear.is_active ? ' (aktiv)' : '' %>
                      </option>
                    <% }) %>
                  </select>
                </label>
                <button class="btn btn-primary" type="submit">Ansicht laden</button>
              </form>

              <div class="archive-export-strip">
                <% if (buildExportUrl('grades')) { %>
                  <a class="archive-export-link" href="<%= buildExportUrl('grades') %>">
                    <strong>CSV Noten</strong>
                    <span><%= formatNumber(grades.length) %> Zeilen</span>
                  </a>
                  <a class="archive-export-link" href="<%= buildExportUrl('classes') %>">
                    <strong>CSV Klassen</strong>
                    <span><%= formatNumber(classes.length) %> Zeilen</span>
                  </a>
                  <a class="archive-export-link" href="<%= buildExportUrl('assignments') %>">
                    <strong>CSV Zuordnungen</strong>
                    <span><%= formatNumber(assignments.length) %> Zeilen</span>
                  </a>
                  <a class="archive-export-link" href="<%= buildExportUrl('archives') %>">
                    <strong>CSV Archivstatus</strong>
                    <span><%= formatNumber(archiveEntries.length) %> Zeilen</span>
                  </a>
                <% } %>
              </div>
            </div>
          <% } %>

          <noscript>
            <div class="archive-context-note">
              Ohne JavaScript sind nur Grundansicht und CSV-Export aktiv.
            </div>
          </noscript>
        </section>

        <nav class="archive-jumpbar" aria-label="Archivbereiche">
          <% jumpLinks.forEach((link) => { %>
            <a class="archive-jump-link" href="<%= link.href %>">
              <span><%= link.label %></span>
              <strong><%= formatNumber(link.count) %></strong>
            </a>
          <% }) %>
        </nav>

        <section class="admin-card archive-section" id="archive-log" data-archive-section data-archive-page-size="20">
          <div class="archive-section-head">
            <div>
              <p class="admin-eyebrow">Status</p>
              <h2>Archivstatus</h2>
            </div>
            <div class="archive-section-actions">
              <span class="admin-badge"><%= formatNumber(archiveEntries.length) %> Eintraege</span>
              <% if (buildExportUrl('archives')) { %>
                <a class="btn btn-secondary" href="<%= buildExportUrl('archives') %>">CSV herunterladen</a>
              <% } %>
            </div>
          </div>

          <% if (!archiveEntries.length) { %>
            <div class="admin-empty">Fuer dieses Schuljahr wurden noch keine Archiv-Eintraege protokolliert.</div>
          <% } else { %>
            <div class="archive-section-tools">
              <label class="archive-search-field">
                <span>Archivstatus durchsuchen</span>
                <input type="search" placeholder="Nach Typ, Anzahl oder Datum filtern" data-archive-search>
              </label>
              <div class="archive-inline-stats">
                <span class="archive-inline-stat">CSV: <%= formatNumber(archiveEntries.length) %> Zeilen</span>
              </div>
            </div>

            <div class="archive-table-shell">
              <div class="archive-table-scroller">
                <table class="archive-data-table archive-data-table-compact">
                  <thead>
                    <tr>
                      <th>Archivtyp</th>
                      <th>Anzahl</th>
                      <th>Erstellt</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% archiveEntries.forEach((entry) => { %>
                      <tr data-archive-row data-search-text="<%= buildSearchText(entry.archive_type, entry.entity_count, entry.created_at) %>">
                        <td>
                          <span class="archive-table-title"><%= entry.archive_type %></span>
                        </td>
                        <td class="archive-cell-number"><%= formatNumber(entry.entity_count) %></td>
                        <td class="archive-nowrap"><%= formatDateTime(entry.created_at) %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <div class="archive-filter-empty" data-archive-filter-empty hidden>Keine Eintraege fuer den aktuellen Filter gefunden.</div>
              <div class="archive-table-footer">
                <span class="archive-table-summary" data-archive-summary>Alle <%= formatNumber(archiveEntries.length) %> Zeilen geladen.</span>
                <div class="archive-table-actions" data-archive-actions hidden>
                  <button class="btn btn-secondary" type="button" data-archive-more hidden>Mehr laden</button>
                  <button class="btn btn-secondary" type="button" data-archive-all hidden>Alle zeigen</button>
                  <button class="btn btn-secondary" type="button" data-archive-reset hidden>Zuruecksetzen</button>
                </div>
              </div>
            </div>
          <% } %>
        </section>

        <section class="admin-card archive-section" id="archive-classes" data-archive-section data-archive-page-size="24">
          <div class="archive-section-head">
            <div>
              <p class="admin-eyebrow">Tabelle</p>
              <h2>Klassen</h2>
            </div>
            <div class="archive-section-actions">
              <span class="admin-badge"><%= formatNumber(classes.length) %> Klassen</span>
              <% if (buildExportUrl('classes')) { %>
                <a class="btn btn-secondary" href="<%= buildExportUrl('classes') %>">CSV herunterladen</a>
              <% } %>
            </div>
          </div>

          <% if (!classes.length) { %>
            <div class="admin-empty">Keine Klassen fuer dieses Schuljahr gefunden.</div>
          <% } else { %>
            <div class="archive-section-tools">
              <label class="archive-search-field">
                <span>Klassen durchsuchen</span>
                <input type="search" placeholder="Nach Klasse, Fach oder Datum filtern" data-archive-search>
              </label>
              <div class="archive-inline-stats">
                <span class="archive-inline-stat"><%= formatNumber(classes.length) %> Datensaetze</span>
                <span class="archive-inline-stat">CSV komplett</span>
              </div>
            </div>

            <div class="archive-table-shell">
              <div class="archive-table-scroller">
                <table class="archive-data-table">
                  <thead>
                    <tr>
                      <th>Klasse</th>
                      <th>Fach</th>
                      <th>Fach-ID</th>
                      <th>Erstellt</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% classes.forEach((row) => { %>
                      <tr data-archive-row data-search-text="<%= buildSearchText(row.name, row.subject, row.subject_id, row.created_at) %>">
                        <td>
                          <span class="archive-table-title"><%= row.name %></span>
                        </td>
                        <td><%= row.subject %></td>
                        <td class="archive-cell-number"><%= row.subject_id ?? '-' %></td>
                        <td class="archive-nowrap"><%= formatDateTime(row.created_at) %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <div class="archive-filter-empty" data-archive-filter-empty hidden>Keine Klassen fuer den aktuellen Filter gefunden.</div>
              <div class="archive-table-footer">
                <span class="archive-table-summary" data-archive-summary>Alle <%= formatNumber(classes.length) %> Zeilen geladen.</span>
                <div class="archive-table-actions" data-archive-actions hidden>
                  <button class="btn btn-secondary" type="button" data-archive-more hidden>Mehr laden</button>
                  <button class="btn btn-secondary" type="button" data-archive-all hidden>Alle zeigen</button>
                  <button class="btn btn-secondary" type="button" data-archive-reset hidden>Zuruecksetzen</button>
                </div>
              </div>
            </div>
          <% } %>
        </section>

        <section class="admin-card archive-section" id="archive-assignments" data-archive-section data-archive-page-size="24">
          <div class="archive-section-head">
            <div>
              <p class="admin-eyebrow">Tabelle</p>
              <h2>Zuordnungen</h2>
            </div>
            <div class="archive-section-actions">
              <span class="admin-badge"><%= formatNumber(assignments.length) %> Zuordnungen</span>
              <% if (buildExportUrl('assignments')) { %>
                <a class="btn btn-secondary" href="<%= buildExportUrl('assignments') %>">CSV herunterladen</a>
              <% } %>
            </div>
          </div>

          <% if (!assignments.length) { %>
            <div class="admin-empty">Keine Zuordnungen fuer dieses Schuljahr gefunden.</div>
          <% } else { %>
            <div class="archive-section-tools">
              <label class="archive-search-field">
                <span>Zuordnungen durchsuchen</span>
                <input type="search" placeholder="Nach Klasse, Fach oder Lehrkraft filtern" data-archive-search>
              </label>
              <div class="archive-inline-stats">
                <span class="archive-inline-stat"><%= formatNumber(archiveStats?.uniqueTeachers || 0) %> Lehrkraefte beteiligt</span>
                <span class="archive-inline-stat">CSV komplett</span>
              </div>
            </div>

            <div class="archive-table-shell">
              <div class="archive-table-scroller">
                <table class="archive-data-table">
                  <thead>
                    <tr>
                      <th>Klasse</th>
                      <th>Fach</th>
                      <th>Lehrkraefte</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% assignments.forEach((row) => { %>
                      <tr data-archive-row data-search-text="<%= buildSearchText(row.class_name, row.subject_name, row.teacher_names) %>">
                        <td><span class="archive-table-title"><%= row.class_name %></span></td>
                        <td><%= row.subject_name %></td>
                        <td><span class="archive-note" title="<%= row.teacher_names %>"><%= row.teacher_names %></span></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <div class="archive-filter-empty" data-archive-filter-empty hidden>Keine Zuordnungen fuer den aktuellen Filter gefunden.</div>
              <div class="archive-table-footer">
                <span class="archive-table-summary" data-archive-summary>Alle <%= formatNumber(assignments.length) %> Zeilen geladen.</span>
                <div class="archive-table-actions" data-archive-actions hidden>
                  <button class="btn btn-secondary" type="button" data-archive-more hidden>Mehr laden</button>
                  <button class="btn btn-secondary" type="button" data-archive-all hidden>Alle zeigen</button>
                  <button class="btn btn-secondary" type="button" data-archive-reset hidden>Zuruecksetzen</button>
                </div>
              </div>
            </div>
          <% } %>
        </section>

        <section class="admin-card archive-section archive-section-wide" id="archive-grades" data-archive-section data-archive-page-size="40">
          <div class="archive-section-head">
            <div>
              <p class="admin-eyebrow">Tabelle</p>
              <h2>Noten</h2>
            </div>
            <div class="archive-section-actions">
              <span class="admin-badge"><%= formatNumber(totalGrades) %> Noten</span>
              <% if (buildExportUrl('grades')) { %>
                <a class="btn btn-primary" href="<%= buildExportUrl('grades') %>">CSV herunterladen</a>
              <% } %>
            </div>
          </div>

          <% if (!grades.length) { %>
            <div class="admin-empty">Keine Noten fuer dieses Schuljahr gefunden.</div>
          <% } else { %>
            <div class="archive-section-tools archive-section-tools-wide">
              <label class="archive-search-field">
                <span>Noten durchsuchen</span>
                <input type="search" placeholder="Nach Klasse, Schueler, Fach, Note oder Kommentar filtern" data-archive-search>
              </label>
              <div class="archive-inline-stats">
                <span class="archive-inline-stat"><%= formatNumber(archiveStats?.uniqueStudents || 0) %> Schueler</span>
                <span class="archive-inline-stat">Durchschnitt: <%= formatAverageGrade(archiveStats?.averageGrade) %></span>
                <span class="archive-inline-stat">CSV: <%= formatNumber(totalGrades) %> Noten</span>
              </div>
            </div>

            <div class="archive-table-shell archive-table-shell-tall">
              <div class="archive-table-scroller">
                <table class="archive-data-table archive-data-table-grades">
                  <thead>
                    <tr>
                      <th>Klasse</th>
                      <th>Schueler</th>
                      <th>Fach</th>
                      <th>Note</th>
                      <th>Kommentar</th>
                      <th>Zeitpunkt</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% grades.forEach((row) => { %>
                      <tr data-archive-row data-search-text="<%= buildSearchText(row.class_name, row.student_name, row.subject, row.grade, row.note, row.created_at) %>">
                        <td><span class="archive-table-title"><%= row.class_name %></span></td>
                        <td><%= row.student_name %></td>
                        <td><%= row.subject %></td>
                        <td>
                          <span class="archive-grade-badge <%= getGradeTone(row.grade) %>"><%= row.grade %></span>
                        </td>
                        <td>
                          <span class="archive-note" title="<%= row.note || '-' %>"><%= row.note || '-' %></span>
                        </td>
                        <td class="archive-nowrap"><%= formatDateTime(row.created_at) %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <div class="archive-filter-empty" data-archive-filter-empty hidden>Keine Noten fuer den aktuellen Filter gefunden.</div>
              <div class="archive-table-footer">
                <span class="archive-table-summary" data-archive-summary>Alle <%= formatNumber(totalGrades) %> Zeilen geladen.</span>
                <div class="archive-table-actions" data-archive-actions hidden>
                  <button class="btn btn-secondary" type="button" data-archive-more hidden>Mehr laden</button>
                  <button class="btn btn-secondary" type="button" data-archive-all hidden>Alle zeigen</button>
                  <button class="btn btn-secondary" type="button" data-archive-reset hidden>Zuruecksetzen</button>
                </div>
              </div>
            </div>
          <% } %>
        </section>
      </section>
    </div>
<% } }; %>
<%- include('../layout', page) %>
