<%
  const preview = rolloverPreview || null;
  const hasWizard = Boolean(wizardView && wizardView.draft);
  const draft = wizardView?.draft || wizardDraft || null;
  const baseClassPlans = wizardView?.baseClassPlans || [];
  const extraClassPlans = wizardView?.extraClassPlans || [];
  const sourceClassGroups = wizardView?.sourceClassGroups || [];
  const intakeTargets = wizardView?.intakeTargets || [];
  const reviewClassRows = wizardView?.reviewClassRows || [];
  const validation = wizardView?.validation || { valid: false, errors: [], reviewStats: {} };
  const targetOptions = wizardView?.targetOptions || [];
  const sourceClasses = draft?.sourceClasses || [];
  const sourceClassMap = new Map(sourceClasses.map((classRow) => [Number(classRow.id), classRow]));
  const startValues = startForm || {};
  const routeActiveName = draft?.activeSchoolYear?.name || preview?.activeSchoolYear?.name || activeSchoolYear?.name || 'Nicht gesetzt';
  const routeNextName = draft?.nextSchoolYear?.name || preview?.nextSchoolYear?.name || startValues.schoolYearName || 'Nicht verfügbar';
  const routeActiveStart = draft?.activeSchoolYear?.start_date || preview?.activeSchoolYear?.start_date || activeSchoolYear?.start_date;
  const routeActiveEnd = draft?.activeSchoolYear?.end_date || preview?.activeSchoolYear?.end_date || activeSchoolYear?.end_date;
  const routeNextStart = draft?.nextSchoolYear?.startDate || preview?.nextSchoolYear?.startDate || startValues.startDate;
  const routeNextEnd = draft?.nextSchoolYear?.endDate || preview?.nextSchoolYear?.endDate || startValues.endDate;
  const currentStepIndex = wizardSteps.findIndex((step) => step.key === wizardStep);
  const visibleExtraRows = extraClassPlans.length ? extraClassPlans : [null];
  const shortDateFormatter = new Intl.DateTimeFormat('de-DE', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric'
  });
  const dateTimeFormatter = new Intl.DateTimeFormat('de-DE', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
  const formatDate = (value) => {
    if (!value) return '-';
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? String(value) : shortDateFormatter.format(parsed);
  };
  const formatDateTime = (value) => {
    if (!value) return '-';
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? String(value) : dateTimeFormatter.format(parsed);
  };
  const formatDateRange = (start, end) => `${formatDate(start)} bis ${formatDate(end)}`;
  const getPlanKindBadge = (kind) => {
    if (kind === 'promote') return 'Hochstufung';
    if (kind === 'intake') return 'Neueinstieg';
    if (kind === 'extra') return 'Zusatz';
    return 'Ziel';
  };
  const page = {
    title: 'Admin - Schuljahreswechsel',
    headerTitle: 'Adminbereich',
    styles: ['/css/admin.css', '/css/admin-rollover.css'],
    scripts: ['/js/app.js', '/js/rollover-wizard.js'],
    bodyClass: 'page-admin',
    hideHeader: true,
    hideFooter: true,
    content: function () { %>
    <div class="app-shell">
      <%- include('./nav-school-year', { csrfToken, currentUser, activePath, activeSchoolYear }) %>

      <section class="app-main school-year-rollover">
        <div class="app-main-header school-year-header">
          <div>
            <p class="app-main-subtitle">Schuljahresverwaltung</p>
            <h1>Schuljahreswechsel-Assistent</h1>
            <p class="admin-muted school-year-header-copy">
              Mehrstufiger Wizard für Klassen, Lehrerzuordnungen und Schülerübernahme.
            </p>
          </div>
          <div class="admin-actions-row school-year-header-actions">
            <% if (hasWizard) { %>
              <a class="btn btn-primary" href="/admin/rollover?step=<%= wizardStep === 'start' ? 'classes' : wizardStep %>">Assistent öffnen</a>
            <% } %>
            <a class="btn btn-secondary" href="/archive">Archiv</a>
          </div>
        </div>

        <% if (message || error || intakeParseErrors.length) { %>
          <div class="school-year-alert-stack">
            <% if (message) { %>
              <div class="school-year-alert school-year-alert-info"><%= message %></div>
            <% } %>
            <% if (error) { %>
              <div class="school-year-alert school-year-alert-error"><%= error %></div>
            <% } %>
            <% if (intakeParseErrors.length) { %>
              <div class="school-year-alert school-year-alert-error">
                <strong>Import prüfen:</strong>
                <ul class="school-year-inline-list">
                  <% intakeParseErrors.forEach((entry) => { %>
                    <li><%= entry %></li>
                  <% }) %>
                </ul>
              </div>
            <% } %>
          </div>
        <% } %>

        <nav class="school-year-stepper" aria-label="Wizard Schritte">
          <% wizardSteps.forEach((step, index) => { %>
            <a
              class="school-year-step <%= index === currentStepIndex ? 'is-current' : '' %> <%= index < currentStepIndex ? 'is-done' : '' %> <%= !hasWizard && step.key !== 'start' ? 'is-disabled' : '' %>"
              href="/admin/rollover?step=<%= hasWizard || step.key === 'start' ? step.key : 'start' %>"
            >
              <span class="school-year-step-index"><%= index + 1 %></span>
              <span class="school-year-step-label"><%= step.label %></span>
            </a>
          <% }) %>
        </nav>

        <% if (wizardStep === 'start') { %>
          <section class="school-year-panel school-year-panel-start">
            <div class="school-year-panel-head">
              <div>
                <p class="admin-eyebrow">Start</p>
                <h2>Assistent vorbereiten</h2>
              </div>
              <% if (hasWizard) { %>
                <form method="POST" action="/admin/rollover/reset">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn btn-secondary" type="submit">Assistent zurücksetzen</button>
                </form>
              <% } %>
            </div>

            <% if (preview || hasWizard) { %>
              <div class="school-year-hero-grid">
                <div class="school-year-route-card">
                  <span class="school-year-route-label">Route</span>
                  <div class="school-year-route">
                    <strong><%= routeActiveName %></strong>
                    <span>&rarr;</span>
                    <strong><%= routeNextName %></strong>
                  </div>
                  <small>
                    <%= formatDateRange(routeActiveStart, routeActiveEnd) %>
                    |
                    <%= formatDateRange(routeNextStart, routeNextEnd) %>
                  </small>
                </div>

                <div class="school-year-metric-grid">
                  <div class="school-year-metric"><span>Klassen</span><strong><%= draft?.sourceSummary?.classCount || preview?.classCount || 0 %></strong></div>
                  <div class="school-year-metric"><span>Schüler</span><strong><%= draft?.sourceSummary?.studentCount || preview?.studentCount || 0 %></strong></div>
                  <div class="school-year-metric"><span>Zuordnungen</span><strong><%= draft?.sourceSummary?.assignmentCount || preview?.assignmentsCopied || 0 %></strong></div>
                  <div class="school-year-metric"><span>Archivierte Noten</span><strong><%= draft?.sourceSummary?.gradeCount || preview?.gradeCount || 0 %></strong></div>
                </div>
              </div>

              <% if (hasWizard) { %>
                <section class="school-year-subpanel school-year-start-config">
                  <div class="school-year-subpanel-head">
                    <div>
                      <p class="admin-eyebrow">Zielschuljahr</p>
                      <h3>Aktueller Wizard</h3>
                    </div>
                    <small>Zum Ändern Assistent zuerst zurücksetzen.</small>
                  </div>

                  <div class="school-year-start-readonly">
                    <div class="school-year-readonly-field">
                      <span>Bezeichnung</span>
                      <strong><%= startValues.schoolYearName || '-' %></strong>
                    </div>
                    <div class="school-year-readonly-field">
                      <span>Startdatum</span>
                      <strong><%= formatDate(startValues.startDate) %></strong>
                    </div>
                    <div class="school-year-readonly-field">
                      <span>Enddatum</span>
                      <strong><%= formatDate(startValues.endDate) %></strong>
                    </div>
                  </div>
                </section>

                <div class="school-year-start-actions">
                  <a class="btn btn-primary" href="/admin/rollover?step=classes">Mit Klassenplanung fortfahren</a>
                </div>
              <% } else { %>
                <section class="school-year-subpanel school-year-start-config">
                  <div class="school-year-subpanel-head">
                    <div>
                      <p class="admin-eyebrow">Zielschuljahr</p>
                      <h3>Bezeichnung und Datum festlegen</h3>
                    </div>
                    <small>Standardwerte können vor dem Start angepasst werden.</small>
                  </div>

                  <form method="POST" action="/admin/rollover/start" class="school-year-form-stack school-year-start-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <div class="school-year-start-grid">
                      <label>
                        <span>Bezeichnung</span>
                        <input
                          class="form-input"
                          type="text"
                          name="school_year_name"
                          value="<%= startValues.schoolYearName || '' %>"
                          placeholder="2026/2027"
                          autocomplete="off"
                          required
                        >
                      </label>
                      <label>
                        <span>Startdatum</span>
                        <input
                          class="form-input"
                          type="date"
                          name="start_date"
                          value="<%= startValues.startDate || '' %>"
                          required
                        >
                      </label>
                      <label>
                        <span>Enddatum</span>
                        <input
                          class="form-input"
                          type="date"
                          name="end_date"
                          value="<%= startValues.endDate || '' %>"
                          required
                        >
                      </label>
                    </div>

                    <div class="school-year-start-actions">
                      <button class="btn btn-primary" type="submit">Assistent starten</button>
                      <% if (preview?.nextSchoolYearExists) { %>
                        <div class="school-year-inline-note danger">Zielschuljahr existiert bereits. Bitte Bezeichnung oder Zeitraum anpassen.</div>
                      <% } %>
                    </div>
                  </form>
                </section>
              <% } %>
            <% } else { %>
              <div class="school-year-empty">Kein aktives Schuljahr vorhanden.</div>
            <% } %>
          </section>
        <% } %>

        <% if (hasWizard && wizardStep === 'classes') { %>
          <section class="school-year-panel">
            <div class="school-year-panel-head">
              <div>
                <p class="admin-eyebrow">Schritt 1</p>
                <h2>Klassen planen</h2>
              </div>
              <form method="POST" action="/admin/rollover/reset">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-secondary" type="submit">Neu beginnen</button>
              </form>
            </div>

            <div class="school-year-panel-meta">
              <span><%= baseClassPlans.length %> automatische Zielklassen</span>
              <span><%= extraClassPlans.length %> manuelle Zusatzklassen</span>
              <span><%= targetOptions.length %> aktivierte Ziele</span>
            </div>

            <div class="school-year-filter-bar">
              <label>
                <span>Filter</span>
                <input type="search" placeholder="Nach Klasse oder Fach filtern" data-rollover-class-filter-input>
              </label>
            </div>

            <form method="POST" action="/admin/rollover/classes" class="school-year-form-stack">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">

              <div class="school-year-table-wrap">
                <table class="school-year-table school-year-class-table">
                  <thead>
                    <tr>
                      <th>Typ</th>
                      <th>Quelle</th>
                      <th>Schüler</th>
                      <th>Zielname</th>
                      <th>Lehrer</th>
                      <th>Aktiv</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% baseClassPlans.forEach((plan) => { const sourceClass = sourceClassMap.get(Number(plan.templateSourceClassId)); %>
                      <tr data-rollover-class-row data-search-text="<%= `${sourceClass?.name || ''} ${sourceClass?.subject || ''} ${plan.targetName || ''}`.toLowerCase() %>">
                        <td><span class="school-year-badge"><%= getPlanKindBadge(plan.kind) %></span></td>
                        <td>
                          <strong><%= sourceClass?.name || '-' %></strong>
                          <small><%= sourceClass?.subject || '-' %></small>
                        </td>
                        <td><%= sourceClass?.students?.length || 0 %></td>
                        <td>
                          <input type="text" name="class_plan[<%= plan.key %>][target_name]" value="<%= plan.targetName %>" class="form-input">
                        </td>
                        <td>
                          <input type="hidden" name="class_plan[<%= plan.key %>][copy_teachers]" value="0">
                          <label class="school-year-checkline">
                            <input type="checkbox" name="class_plan[<%= plan.key %>][copy_teachers]" value="1" <%= plan.copyTeachers ? 'checked' : '' %>>
                            <span><%= sourceClass?.assignments?.length || 0 %> Zuordnungen</span>
                          </label>
                        </td>
                        <td>
                          <input type="hidden" name="class_plan[<%= plan.key %>][enabled]" value="0">
                          <label class="school-year-checkline">
                            <input type="checkbox" name="class_plan[<%= plan.key %>][enabled]" value="1" <%= plan.enabled ? 'checked' : '' %>>
                            <span>aktiv</span>
                          </label>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>

              <section class="school-year-subpanel">
                <div class="school-year-subpanel-head">
                  <div>
                    <p class="admin-eyebrow">Zusatzklassen</p>
                    <h3>Weitere Zielklassen anlegen</h3>
                  </div>
                  <small>Vorlage bestimmt Fach und Lehrerzuordnungen.</small>
                </div>
                <div class="school-year-table-wrap">
                  <table class="school-year-table">
                    <thead>
                      <tr>
                        <th>Vorlage</th>
                        <th>Zielname</th>
                        <th>Lehrer</th>
                        <th>Aktiv</th>
                      </tr>
                    </thead>
                    <tbody data-rollover-extra-rows data-next-index="<%= visibleExtraRows.length %>">
                      <% visibleExtraRows.forEach((plan, index) => { %>
                        <tr data-rollover-extra-row>
                          <td>
                            <input type="hidden" name="extra_rows[<%= index %>][plan_key]" value="<%= plan?.key || '' %>">
                            <select name="extra_rows[<%= index %>][template_source_class_id]" class="form-select">
                              <option value="">Vorlage wählen</option>
                              <% sourceClasses.forEach((classRow) => { %>
                                <option value="<%= classRow.id %>" <%= Number(plan?.templateSourceClassId) === Number(classRow.id) ? 'selected' : '' %>>
                                  <%= classRow.name %> / <%= classRow.subject %>
                                </option>
                              <% }) %>
                            </select>
                          </td>
                          <td><input type="text" name="extra_rows[<%= index %>][target_name]" value="<%= plan?.targetName || '' %>" class="form-input"></td>
                          <td>
                            <input type="hidden" name="extra_rows[<%= index %>][copy_teachers]" value="0">
                            <label class="school-year-checkline">
                              <input type="checkbox" name="extra_rows[<%= index %>][copy_teachers]" value="1" <%= plan?.copyTeachers ? 'checked' : '' %>>
                              <span>kopieren</span>
                            </label>
                          </td>
                          <td>
                            <input type="hidden" name="extra_rows[<%= index %>][enabled]" value="0">
                            <label class="school-year-checkline">
                              <input type="checkbox" name="extra_rows[<%= index %>][enabled]" value="1" <%= plan?.enabled ? 'checked' : '' %>>
                              <span>aktiv</span>
                            </label>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
                <div class="school-year-add-row">
                  <button class="btn btn-secondary school-year-add-row-button" type="button" data-rollover-add-extra-row>
                    + Weitere Zeile
                  </button>
                </div>
                <template data-rollover-extra-row-template>
                  <tr data-rollover-extra-row>
                    <td>
                      <input type="hidden" name="extra_rows[__INDEX__][plan_key]" value="">
                      <select name="extra_rows[__INDEX__][template_source_class_id]" class="form-select">
                        <option value="">Vorlage wählen</option>
                        <% sourceClasses.forEach((classRow) => { %>
                          <option value="<%= classRow.id %>">
                            <%= classRow.name %> / <%= classRow.subject %>
                          </option>
                        <% }) %>
                      </select>
                    </td>
                    <td><input type="text" name="extra_rows[__INDEX__][target_name]" value="" class="form-input"></td>
                    <td>
                      <input type="hidden" name="extra_rows[__INDEX__][copy_teachers]" value="0">
                      <label class="school-year-checkline">
                        <input type="checkbox" name="extra_rows[__INDEX__][copy_teachers]" value="1">
                        <span>kopieren</span>
                      </label>
                    </td>
                    <td>
                      <input type="hidden" name="extra_rows[__INDEX__][enabled]" value="0">
                      <label class="school-year-checkline">
                        <input type="checkbox" name="extra_rows[__INDEX__][enabled]" value="1">
                        <span>aktiv</span>
                      </label>
                    </td>
                  </tr>
                </template>
              </section>

              <div class="school-year-button-row">
                <button class="btn btn-secondary" type="submit" name="intent" value="stay">Speichern</button>
                <button class="btn btn-primary" type="submit" name="intent" value="next">Weiter zu Schülern</button>
              </div>
            </form>
          </section>
        <% } %>

        <% if (hasWizard && wizardStep === 'students') { %>
          <section class="school-year-panel">
            <div class="school-year-panel-head">
              <div>
                <p class="admin-eyebrow">Schritt 2</p>
                <h2>Schüler planen</h2>
              </div>
              <div class="school-year-panel-meta">
                <span><%= sourceClassGroups.length %> Ausgangsklassen</span>
                <span><%= validation.reviewStats.promotedStudentCount || 0 %> Übernahmen</span>
                <span><%= validation.reviewStats.intakeStudentCount || 0 %> neue Schüler</span>
              </div>
            </div>

            <div class="school-year-filter-bar">
              <label>
                <span>Filter</span>
                <input type="search" placeholder="Nach Klasse, Name oder E-Mail filtern" data-rollover-student-filter-input>
              </label>
            </div>

            <form method="POST" action="/admin/rollover/students" class="school-year-form-stack">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">

              <% sourceClassGroups.forEach((group, index) => { %>
                <details class="school-year-student-group" data-rollover-student-group <%= index < 3 ? 'open' : '' %>>
                  <summary>
                    <span><strong><%= group.classRow.name %></strong> / <%= group.classRow.subject %></span>
                    <small><%= group.students.length %> Schüler | <%= group.promoteCount %> übernehmen | <%= group.graduateCount %> beenden</small>
                  </summary>
                  <div class="school-year-group-body">
                    <div class="school-year-group-defaults">
                      <label>
                        <span>Standardaktion</span>
                        <select name="student_defaults[<%= group.classRow.id %>][default_action]" class="form-select">
                          <option value="promote" <%= group.defaults.defaultAction === 'promote' ? 'selected' : '' %>>In Zielklasse übernehmen</option>
                          <option value="graduate" <%= group.defaults.defaultAction === 'graduate' ? 'selected' : '' %>>Nicht übernehmen</option>
                        </select>
                      </label>
                      <label>
                        <span>Standard-Zielklasse</span>
                        <select name="student_defaults[<%= group.classRow.id %>][default_target_class_key]" class="form-select">
                          <option value="">Keine Zielklasse</option>
                          <% group.targetOptions.forEach((option) => { %>
                            <option value="<%= option.key %>" <%= option.key === group.defaults.defaultTargetClassKey ? 'selected' : '' %>><%= option.label %></option>
                          <% }) %>
                        </select>
                      </label>
                    </div>

                    <div class="school-year-table-wrap">
                      <table class="school-year-table school-year-student-table">
                        <thead>
                          <tr>
                            <th>Name</th>
                            <th>E-Mail</th>
                            <th>Override</th>
                            <th>Aktion</th>
                            <th>Zielklasse</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% group.students.forEach((studentPlan) => { %>
                            <tr data-rollover-student-row data-search-text="<%= `${studentPlan.studentName} ${studentPlan.studentEmail} ${group.classRow.name} ${group.classRow.subject}`.toLowerCase() %>">
                              <td><strong><%= studentPlan.studentName %></strong></td>
                              <td><%= studentPlan.studentEmail %></td>
                              <td>
                                <select name="student_overrides[<%= studentPlan.sourceStudentId %>][mode]" class="form-select">
                                  <option value="inherit" <%= studentPlan.mode !== 'manual' ? 'selected' : '' %>>Standard</option>
                                  <option value="manual" <%= studentPlan.mode === 'manual' ? 'selected' : '' %>>Manuell</option>
                                </select>
                              </td>
                              <td>
                                <select name="student_overrides[<%= studentPlan.sourceStudentId %>][action]" class="form-select">
                                  <option value="promote" <%= studentPlan.action === 'promote' ? 'selected' : '' %>>Übernehmen</option>
                                  <option value="graduate" <%= studentPlan.action === 'graduate' ? 'selected' : '' %>>Nicht übernehmen</option>
                                </select>
                              </td>
                              <td>
                                <select name="student_overrides[<%= studentPlan.sourceStudentId %>][target_class_key]" class="form-select">
                                  <option value="">Keine Zielklasse</option>
                                  <% group.targetOptions.forEach((option) => { %>
                                    <option value="<%= option.key %>" <%= option.key === studentPlan.targetClassKey ? 'selected' : '' %>><%= option.label %></option>
                                  <% }) %>
                                </select>
                              </td>
                            </tr>
                          <% }) %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </details>
              <% }) %>

              <% if (intakeTargets.length) { %>
                <section class="school-year-subpanel">
                  <div class="school-year-subpanel-head">
                    <div>
                      <p class="admin-eyebrow">Neue Schüler</p>
                      <h3>Intake und Zusatzklassen füllen</h3>
                    </div>
                    <small>Format pro Zeile: <code>Name;E-Mail</code> oder <code>E-Mail</code></small>
                  </div>

                  <div class="school-year-intake-grid">
                    <% intakeTargets.forEach((target) => { %>
                      <label class="school-year-intake-card">
                        <span class="school-year-intake-title"><%= target.label %></span>
                        <textarea
                          name="intake_students[<%= target.plan.key %>][raw_text]"
                          rows="6"
                          placeholder="Max Mustermann;max.mustermann@schule.at"
                        ><%= target.rawText %></textarea>
                        <small><%= target.students.length %> neue Schüler erkannt</small>
                      </label>
                    <% }) %>
                  </div>
                </section>
              <% } %>

              <div class="school-year-button-row">
                <button class="btn btn-secondary" type="submit" name="intent" value="back">Zurück zu Klassen</button>
                <button class="btn btn-primary" type="submit" name="intent" value="next">Weiter zur Prüfung</button>
              </div>
            </form>
          </section>
        <% } %>

        <% if (hasWizard && wizardStep === 'review') { %>
          <section class="school-year-panel">
            <div class="school-year-panel-head">
              <div>
                <p class="admin-eyebrow">Schritt 3</p>
                <h2>Prüfen und ausführen</h2>
              </div>
              <div class="school-year-panel-meta">
                <span><%= validation.reviewStats.targetClassCount || 0 %> Zielklassen</span>
                <span><%= validation.reviewStats.promotedStudentCount || 0 %> Schüler übernehmen</span>
                <span><%= validation.reviewStats.intakeStudentCount || 0 %> neue Schüler</span>
              </div>
            </div>

            <% if (!validation.valid) { %>
              <div class="school-year-inline-note danger">
                <strong>Bitte zuerst korrigieren:</strong>
                <ul class="school-year-inline-list">
                  <% validation.errors.forEach((entry) => { %>
                    <li><%= entry %></li>
                  <% }) %>
                </ul>
              </div>
            <% } %>

            <div class="school-year-metric-grid">
              <div class="school-year-metric"><span>Hochstufungen</span><strong><%= validation.reviewStats.promotedClassCount || 0 %></strong></div>
              <div class="school-year-metric"><span>Neueinstiege</span><strong><%= validation.reviewStats.intakeClassCount || 0 %></strong></div>
              <div class="school-year-metric"><span>Zusatzklassen</span><strong><%= validation.reviewStats.extraClassCount || 0 %></strong></div>
              <div class="school-year-metric"><span>Lehrerzuordnungen</span><strong><%= validation.reviewStats.teacherAssignmentCount || 0 %></strong></div>
            </div>

            <div class="school-year-table-wrap">
              <table class="school-year-table">
                <thead>
                  <tr>
                    <th>Typ</th>
                    <th>Quelle</th>
                    <th>Zielklasse</th>
                    <th>Lehrer</th>
                    <th>Übernahmen</th>
                    <th>Neue Schüler</th>
                  </tr>
                </thead>
                <tbody>
                  <% reviewClassRows.forEach((row) => { %>
                    <tr>
                      <td><span class="school-year-badge"><%= getPlanKindBadge(row.plan.kind) %></span></td>
                      <td><%= row.sourceLabel %></td>
                      <td><strong><%= row.targetLabel %></strong></td>
                      <td><%= row.teacherCount %></td>
                      <td><%= row.promotedStudents %></td>
                      <td><%= row.intakeStudents %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <form method="POST" action="/admin/rollover/execute" class="school-year-confirm-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <label for="confirmation_text">Zielschuljahr bestätigen</label>
              <input
                id="confirmation_text"
                class="form-input school-year-confirm-input"
                name="confirmation_text"
                type="text"
                placeholder="<%= draft?.nextSchoolYear?.name || '' %>"
                autocomplete="off"
                required
              >
              <small class="admin-muted school-year-confirm-note">
                Gib exakt <strong><%= draft?.nextSchoolYear?.name || '-' %></strong> ein. Vor der Ausführung wird ein Backup erzeugt.
              </small>

              <div class="school-year-button-row">
                <a class="btn btn-secondary" href="/admin/rollover?step=students">Zurück zu Schülern</a>
                <button class="btn btn-danger" type="submit" <%= validation.valid ? '' : 'disabled' %>>Schuljahreswechsel ausführen</button>
              </div>
            </form>
          </section>
        <% } %>

        <section class="school-year-panel school-year-panel-logs">
          <div class="school-year-panel-head">
            <div>
              <p class="admin-eyebrow">Historie</p>
              <h2>Letzte Wechsel</h2>
            </div>
          </div>
          <% if (!logs.length) { %>
            <div class="school-year-empty">Noch keine Rollover-Logs vorhanden.</div>
          <% } else { %>
            <div class="school-year-log-list">
              <% logs.forEach((logRow) => { %>
                <% const canRestore = String(logRow.status || '').toLowerCase() === 'success' && Boolean(logRow.backup_path) && activeSchoolYear?.name === logRow.new_school_year; %>
                <div class="school-year-log-row">
                  <div>
                    <strong><%= logRow.old_school_year || '-' %> &rarr; <%= logRow.new_school_year || '-' %></strong>
                    <small><%= formatDateTime(logRow.executed_at) %></small>
                  </div>
                  <div class="school-year-log-actions">
                    <span class="school-year-badge"><%= logRow.status || '-' %></span>
                    <% if (canRestore) { %>
                      <form
                        method="POST"
                        action="/admin/rollover/restore"
                        data-rollover-restore-form
                        data-restore-label="<%= `${logRow.new_school_year} -> ${logRow.old_school_year}` %>"
                      >
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="log_id" value="<%= logRow.id %>">
                        <button class="btn btn-secondary" type="submit">Schuljahr wiederherstellen</button>
                      </form>
                    <% } else if (String(logRow.status || '').toLowerCase() === 'success' && logRow.backup_path) { %>
                      <small>Restore nur möglich, wenn <%= logRow.new_school_year %> aktiv ist.</small>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </section>
      </section>
    </div>
<% } }; %>
<%- include('../layout', page) %>
