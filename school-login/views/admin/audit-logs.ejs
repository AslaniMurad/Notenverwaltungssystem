<%
  const search = query || {};
  const page = {
    title: 'Admin - Audit-Log',
    headerTitle: 'Adminbereich',
    headerActions: [],
    styles: ['/css/admin.css'],
    scripts: ['/js/app.js', '/js/admin-audit-logs.js'],
    bodyClass: 'page-admin',
    hideHeader: true,
    hideFooter: true,
    content: function () { %>
    <div class="app-shell">
      <%- include('./nav', { csrfToken, currentUser, activePath }) %>

      <section class="app-main">
        <div class="app-main-header">
          <div>
            <p class="app-main-subtitle">Protokoll</p>
            <h1>Audit-Log</h1>
          </div>
        </div>

        <div class="admin-card">
          <div class="admin-topbar">
            <div>
              <p class="admin-eyebrow">Filter</p>
              <h3>Eintraege suchen</h3>
            </div>
          </div>
          <form class="admin-form" method="GET" action="/admin/audit-logs">
            <input type="text" name="actor" placeholder="Akteur (E-Mail)" value="<%= search.actor || '' %>">
            <input type="text" name="action" placeholder="Aktion" value="<%= search.action || '' %>">
            <input type="text" name="entity" placeholder="Entitaet (z.B. user, class)" value="<%= search.entity || '' %>">
            <button class="btn btn-secondary" type="submit">Suchen</button>
            <a class="btn" href="/admin/audit-logs">Zuruecksetzen</a>
          </form>
        </div>

        <div class="admin-card">
          <div class="admin-topbar">
            <h3 class="admin-heading-spaced">Letzte Aktionen</h3>
            <span class="admin-badge"><%= logs.length %> Eintraege</span>
          </div>
          <table class="admin-table" id="audit-log-table">
            <thead>
              <tr>
                <th>Zeit</th>
                <th>Akteur</th>
                <th>Rolle</th>
                <th>Beschreibung</th>
                <th>Entitaet</th>
                <th>ID</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody id="audit-log-table-body">
              <% if (!logs || logs.length === 0) { %>
                <tr><td colspan="7" class="admin-muted">Keine Audit-Eintraege gefunden.</td></tr>
              <% } %>
              <% logs.forEach(function(entry){ %>
                <tr>
                  <td><%= entry.created_at || '-' %></td>
                  <td><%= entry.actor_email || '-' %></td>
                  <td><%= entry.actor_role || '-' %></td>
                  <td><%= entry.action || '-' %></td>
                  <td><%= entry.entity_type || '-' %></td>
                  <td><%= entry.entity_id || '-' %></td>
                  <td><%= entry.status_code || '-' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <div id="audit-logs-sentinel" class="admin-muted" style="padding-top:10px;">Weitere Eintraege werden automatisch geladen ...</div>
        </div>
      </section>
    </div>
<% } }; %>
<%- include('../layout', page) %>
