<%
  const page = {
    title: 'Admin - Home',
    headerTitle: 'Adminbereich',
    styles: ['/css/admin.css'],
    scripts: ['/js/app.js'],
    bodyClass: 'page-admin',
    hideHeader: true,
    hideFooter: true,
    content: function () { %>
    <div class="app-shell">
      <%- include('./nav-school-year', { csrfToken, currentUser, activePath, activeSchoolYear }) %>

      <section class="app-main admin-home-page">
        <div class="admin-home-hero">
          <p class="app-main-subtitle admin-home-subtitle">Admin</p>

          <div class="admin-home-header">
            <div class="admin-home-copy">
              <h1>Adminbereich</h1>
              <p class="admin-home-meta">
                Schuljahr
                <strong><%= activeSchoolYear?.name || 'Nicht gesetzt' %></strong>
                <span class="admin-home-status <%= activeSchoolYear?.name ? 'is-ready' : 'is-pending' %>">
                  <%= activeSchoolYear?.name ? 'Aktiv' : 'Fehlt' %>
                </span>
              </p>
            </div>

            <div class="admin-actions-row admin-home-actions">
              <a class="btn btn-primary" href="/admin/users/new">Nutzer anlegen</a>
              <a class="btn btn-secondary" href="/admin/classes/new">Klasse erstellen</a>
              <a class="btn btn-secondary" href="/admin/rollover">Schuljahreswechsel</a>
            </div>
          </div>

          <div class="admin-home-stats">
            <a class="admin-home-stat" href="/admin/users" aria-label="Nutzerverwaltung öffnen">
              <span class="admin-eyebrow">Nutzer</span>
              <strong><%= stats.users %></strong>
            </a>

            <a class="admin-home-stat" href="/admin/classes" aria-label="Klassenbereich öffnen">
              <span class="admin-eyebrow">Klassen</span>
              <strong><%= stats.classes %></strong>
            </a>

            <a class="admin-home-stat" href="/admin/classes" aria-label="Schülerbereich öffnen">
              <span class="admin-eyebrow">Schüler</span>
              <strong><%= stats.students %></strong>
            </a>
          </div>
        </div>

        <div class="admin-home-sections">
          <div class="admin-home-section">
            <p class="admin-eyebrow">Bereiche</p>
            <h2>Direktlinks</h2>

            <div class="admin-home-link-list">
              <a class="admin-home-link" href="/admin/users">Nutzerverwaltung</a>
              <a class="admin-home-link" href="/admin/classes">Klassenbereich</a>
              <a class="admin-home-link" href="/archive">Archiv</a>
              <a class="admin-home-link" href="/admin/audit-logs?returnTo=%2Fadmin">Audit-Log</a>
            </div>
          </div>

          <div class="admin-home-section admin-home-tutorial" id="tutorial-placeholder">
            <p class="admin-eyebrow">Tutorial</p>
            <h2>Platzhalter</h2>

            <button class="btn admin-home-disabled-button" type="button" disabled>
              Tutorial-Seite noch nicht verfügbar
            </button>
          </div>
        </div>
      </section>
    </div>
<% } }; %>
<%- include('../layout', page) %>
