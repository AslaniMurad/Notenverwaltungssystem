<%
  const page = {
    title: 'Admin - Klasse erstellen',
    headerTitle: 'Adminbereich',
    styles: ['/css/admin.css'],
    scripts: ['/js/app.js'],
    bodyClass: 'page-admin',
    hideHeader: true,
    hideFooter: true,
    content: function () { %>
    <div class="app-shell">
      <%- include('./nav', { csrfToken, currentUser, activePath }) %>

      <section class="app-main">
        <div class="app-main-header">
          <div>
            <p class="app-main-subtitle">Klassen</p>
            <h1>Neue Klasse anlegen</h1>
            <p class="admin-muted">Lege zuerst nur die Klasse an. Fächer und Lehrer werden später separat zugeordnet.</p>
          </div>
        </div>

        <div class="admin-card">
          <form class="admin-form vertical" method="POST" action="/admin/classes">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <label for="name">Klassenname</label>
            <input id="name" type="text" name="name" placeholder="z.B. 3AHWII" required>
            <label for="head_teacher_id">Klassenvorstand</label>
            <select id="head_teacher_id" name="head_teacher_id">
              <option value="">Kein Klassenvorstand</option>
              <% (teachers || []).forEach((teacher) => { %>
                <option value="<%= teacher.id %>"><%= teacher.email %></option>
              <% }) %>
            </select>
            <p class="admin-muted">Diese Klasse kann auch ohne Fachzuordnung gespeichert werden.</p>
            <button class="btn btn-primary" type="submit">Klasse erstellen</button>
          </form>
        </div>
      </section>
    </div>
<% } }; %>
<%- include('../layout', page) %>
