<%
  const page = {
    title: 'Admin — Home',
    headerTitle: 'Adminbereich',
    headerActions: [],
    styles: ['/css/admin.css'],
    scripts: ['/js/app.js'],
    bodyClass: 'page-admin',
    hideHeader: true,
    hideFooter: true,
    content: function () { %>
    <div class="app-shell">
      <%- include('./nav', { csrfToken, currentUser, activePath }) %>

      <section class="app-main">
        <div class="app-main-header">
          <div>
            <p class="app-main-subtitle">Übersicht</p>
            <h1>Willkommen im Adminbereich</h1>
            <p class="admin-muted">Direkter Zugang ohne Uhrzeit/Datum — fokussiert auf deine Aufgaben.</p>
          </div>
          <div class="admin-actions-row">
            <a class="btn btn-primary" href="/admin/users/new">Nutzer anlegen</a>
            <a class="btn btn-secondary" href="/admin/classes/new">Klasse erstellen</a>
          </div>
        </div>

        <div class="admin-grid">
          <div class="admin-card">
            <p class="admin-eyebrow">Nutzer</p>
            <h3><%= stats.users %> Accounts</h3>
            <p class="admin-muted">Verwalte Rollen und Kennwörter zentral.</p>
            <a class="admin-link" href="/admin/users">Zur Nutzerliste →</a>
          </div>
          <div class="admin-card">
            <p class="admin-eyebrow">Klassen</p>
            <h3><%= stats.classes %> Klassen</h3>
            <p class="admin-muted">Suche, bearbeite und erstelle Klassen.</p>
            <a class="admin-link" href="/admin/classes">Klassen öffnen →</a>
          </div>
          <div class="admin-card">
            <p class="admin-eyebrow">Schüler</p>
            <h3><%= stats.students %> Einträge</h3>
            <p class="admin-muted">Alle Schüler in den verwalteten Klassen.</p>
            <a class="admin-link" href="/admin/classes">Schüler ansehen →</a>
          </div>
        </div>

        <div class="admin-card">
          <div class="admin-topbar">
            <div>
              <p class="admin-eyebrow">Schnellstart</p>
              <h3>Was möchtest du als Nächstes tun?</h3>
            </div>
          </div>
          <div class="admin-quick-actions">
            <a class="admin-quick" href="/admin/users/new">
              <strong>Einzelnen Nutzer anlegen</strong>
              <span>Geführter Ablauf mit Initial-Kennwort-Option.</span>
            </a>
            <a class="admin-quick" href="/admin/users/new#bulk">
              <strong>Bulk-Anlage starten</strong>
              <span>Mehrere Nutzer per E-Mail-Liste importieren.</span>
            </a>
            <a class="admin-quick" href="/admin/classes">
              <strong>Klassen suchen & bearbeiten</strong>
              <span>Alle Klassen zentral verwalten.</span>
            </a>
          </div>
        </div>
      </section>
    </div>
<% } }; %>
<%- include('../layout', page) %>
