<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meine Klassen</title>
  <style>
    :root{
      --bg:#020817;
      --card:#050816;
      --card-soft:#0b1020;
      --accent:#3b82f6;
      --accent-soft:rgba(59,130,246,.14);
      --accent-green:#22c55e;
      --accent-red:#ef4444;
      --border-soft:rgba(148,163,253,.14);
      --text:#e5e7eb;
      --muted:#6b7280;
      --radius-xl:18px;
      --shadow:0 22px 55px rgba(15,23,42,.95);
      --font:system-ui, -apple-system, BlinkMacSystemFont, -system-ui, sans-serif;
    }
    *{margin:0;padding:0;box-sizing:border-box}
    body{
      min-height:100vh;
      font-family:var(--font);
      background:radial-gradient(circle at top,#111827 0, #020817 38%, #000 100%);
      color:var(--text);
      display:flex;
      align-items:center;
      justify-content:center;
      padding:24px;
    }
    .container {
      width:100%;
      max-width:900px;
      background:radial-gradient(circle at top, rgba(37,99,235,.08), var(--card));
      border-radius:var(--radius-xl);
      padding:22px 24px 20px;
      box-shadow:var(--shadow);
      border:1px solid var(--border-soft);
      backdrop-filter: blur(20px);
    }
    .brand{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
    .logo-dot{width:22px;height:22px;border-radius:999px;background:radial-gradient(circle at 30% 0, #60a5fa, #1d4ed8);box-shadow:0 0 18px rgba(37,99,235,.75);}
    .brand-title{font-size:17px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:#9ca3af;}
    h1 {
      font-size:22px;
      font-weight:600;
      margin-bottom:4px;
      color:#e5e7eb;
    }
    .user-info {
      font-size:11px;
      color:var(--muted);
      margin-bottom:18px;
    }
    .btn {
      display:inline-block;
      padding:8px 16px;
      background:linear-gradient(to right,#2563eb,#4f46e5);
      color:white;
      text-decoration:none;
      border-radius:10px;
      border:none;
      cursor:pointer;
      font-size:11px;
      font-weight:500;
      transition:all .18s ease;
      margin:4px;
      box-shadow:0 8px 16px rgba(15,23,42,.8);
    }
    .btn:hover {
      transform:translateY(-1px);
      box-shadow:0 12px 24px rgba(15,23,42,1);
    }
    .btn-danger {
      background:linear-gradient(to right,#ef4444,#dc2626);
    }
    .btn-secondary {
      background:linear-gradient(to right,#4b5563,#374151);
    }
    .actions {
      display:flex;
      justify-content:space-between;
      align-items:center;
      margin-bottom:20px;
      flex-wrap:wrap;
      gap:10px;
    }
    .class-list {
      margin-top:20px;
    }
    .class-item {
      background:linear-gradient(to bottom,var(--card-soft),#020817);
      border-radius:12px;
      padding:18px;
      margin-bottom:12px;
      border:1px solid rgba(75,85,99,.85);
      display:flex;
      justify-content:space-between;
      align-items:center;
      transition:all .18s ease;
    }
    .class-item:hover{
      border-color:var(--accent);
      box-shadow:0 0 20px rgba(37,99,235,.2);
      transform:translateY(-2px);
    }
    .class-info h3 {
      color:#e5e7eb;
      margin-bottom:5px;
      font-size:15px;
    }
    .class-info p {
      color:var(--muted);
      font-size:11px;
    }
    .class-actions {
      display:flex;
      gap:8px;
      flex-wrap:wrap;
    }
    .empty-state {
      text-align:center;
      padding:40px;
      color:var(--muted);
      font-size:12px;
    }
    form {
      display:inline;
    }
    @media (max-width:720px){
      .container{padding:18px 16px 14px}
      h1{font-size:19px}
      .class-item{flex-direction:column;gap:12px;align-items:flex-start}
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="brand">
      <div class="logo-dot"></div>
      <div class="brand-title">Lehrer Panel</div>
    </div>
    <h1>Meine Klassen</h1>
    <div class="user-info">
      Eingeloggt als: <%= email %>
    </div>

    <div class="actions">
      <a href="/teacher/create-class" class="btn">+ Neue Klasse erstellen</a>
      <div>
        <a href="/" class="btn btn-secondary">Zurück zum Dashboard</a>
        <form method="POST" action="/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-danger">Abmelden</button>
        </form>
      </div>
    </div>

    <div class="class-list">
      <% if (classes.length === 0) { %>
        <div class="empty-state">
          <p>Noch keine Klassen erstellt.</p>
          <p>Klicke auf "Neue Klasse erstellen", um zu beginnen.</p>
        </div>
      <% } else { %>
        <% classes.forEach(cls => { %>
          <div class="class-item">
            <div class="class-info">
              <h3><%= cls.name %></h3>
              <p>Fach: <%= cls.subject %></p>
            </div>
            <div class="class-actions">
              <a href="/teacher/students/<%= cls.id %>" class="btn">Schüler verwalten</a>
              <form method="POST" action="/teacher/delete-class/<%= cls.id %>" 
                    onsubmit="return confirm('Klasse wirklich löschen? Alle Schüler werden entfernt.')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-danger">Löschen</button>
              </form>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</body>
</html>
