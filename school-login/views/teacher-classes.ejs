<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meine Klassen</title>
  <link rel="stylesheet" href="/css/teacher-pages.css">
</head>
<body>
  <div class="container">
    <div class="brand">
      <div class="logo-dot"></div>
      <div class="brand-title">Lehrer Panel</div>
    </div>
    <h1>Meine Klassen</h1>
    <div class="user-info">
      Eingeloggt als: <%= email %>
    </div>

    <div class="actions">
      <a href="/teacher/create-class" class="btn">+ Neue Klasse erstellen</a>
      <div>
        <a href="/" class="btn btn-secondary">Zurück zum Dashboard</a>
        <form class="inline" method="POST" action="/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-danger">Abmelden</button>
        </form>
      </div>
    </div>

    <div class="class-list">
      <% if (classes.length === 0) { %>
        <div class="empty-state">
          <p>Noch keine Klassen erstellt.</p>
          <p>Klicke auf "Neue Klasse erstellen", um zu beginnen.</p>
        </div>
      <% } else { %>
        <% classes.forEach(cls => { %>
          <div class="class-item">
            <div class="class-info">
              <h3><%= cls.name %></h3>
              <p>Fach: <%= cls.subject %></p>
            </div>
            <div class="class-actions">
              <a href="/teacher/students/<%= cls.id %>" class="btn">Schüler verwalten</a>
              <form class="inline" method="POST" action="/teacher/delete-class/<%= cls.id %>"
                    onsubmit="return confirm('Klasse wirklich löschen? Alle Schüler werden entfernt.')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-danger">Löschen</button>
              </form>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</body>
</html>