<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <title>Login | School Panel</title>
  <style>
    :root{--bg:#020817;--card:#050816;--card-soft:#0b1020;--accent:#3b82f6;--text:#e5e7eb;--muted:#6b7280;--radius-xl:18px;--shadow:0 22px 55px rgba(15,23,42,.95);--font:system-ui,-apple-system,BlinkMacSystemFont,Segoe UI,sans-serif}
    *{margin:0;padding:0;box-sizing:border-box}
    body{min-height:100vh;font-family:var(--font);background:radial-gradient(circle at top,#111827 0,#020817 38%,#000 100%);color:var(--text);display:flex;align-items:center;justify-content:center;padding:24px}
    .wrap{width:100%;max-width:420px;background:radial-gradient(circle at top, rgba(37,99,235,.08), var(--card));border-radius:var(--radius-xl);padding:22px;border:1px solid rgba(148,163,253,.04);box-shadow:var(--shadow);position:relative}
    .glow{position:absolute;width:140px;height:140px;background:radial-gradient(circle,#1d4ed8,transparent);opacity:.14;top:-40px;right:-40px;pointer-events:none}
    h1{font-size:21px;margin-bottom:6px}
    .subtitle{font-size:11px;color:var(--muted);margin-bottom:14px}
    label{display:block;font-size:10px;color:#9ca3af;margin-bottom:4px;margin-top:6px}
    input[type="email"],input[type="password"]{width:100%;padding:9px 10px;border-radius:11px;border:1px solid rgba(75,85,99,.9);background:linear-gradient(to bottom,var(--card-soft),#020817);color:var(--text);font-size:11px}
    .hint-row{display:flex;justify-content:space-between;align-items:center;margin-top:4px;margin-bottom:8px}
    button[type="submit"]{width:100%;margin-top:6px;padding:9px 0;border-radius:12px;border:none;background:linear-gradient(to right,#2563eb,#4f46e5);color:#f9fafb;font-size:11px;font-weight:500;cursor:pointer}
    .error-box{background:#3b0b0b;color:#fee2e2;padding:10px;border-radius:8px;margin-bottom:10px;border:1px solid #7f1d1d}
    .buttons{display:flex;gap:8px;margin-top:10px}
    .btn-back{flex:0 0 auto;padding:8px 10px;border-radius:8px;border:1px solid rgba(255,255,255,.06);background:transparent;color:#cbd5e1;cursor:pointer}
    .foot{margin-top:10px;font-size:8px;color:var(--muted);display:flex;justify-content:space-between;gap:8px}
  </style>
</head>
<body>
  <div class="wrap">
    <div class="glow"></div>
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
      <div style="width:22px;height:22px;border-radius:999px;background:radial-gradient(circle at 30% 0,#60a5fa,#1d4ed8)"></div>
      <div>
        <div style="font-size:9px;color:#6b7280;text-transform:uppercase">Secure School Access</div>
        <div style="font-weight:600">School Panel Login</div>
      </div>
    </div>

    <h1>Melde dich an</h1>
    <p class="subtitle">Nutze deine zugewiesene Schul-E-Mail und dein Passwort. Nur freigegebene Accounts erhalten Zugriff.</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-box" role="alert"><%= error %></div>
    <% } %>

    <form method="POST" action="/login">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <label for="email">E-Mail-Adresse</label>
      <input id="email" name="email" type="email" placeholder="z.B. max.muster@schule.at" required value="<%= typeof email !== 'undefined' ? email : '' %>">

      <label for="password">Passwort</label>
      <input id="password" name="password" type="password" placeholder="Dein sicheres Passwort" required>

      <div class="hint-row">
        <div style="font-size:8px;color:var(--muted)">Zugangsdaten erhältst du von einem Admin.</div>
        <div style="font-size:8px;color:var(--accent)">Rollen: Admin • Lehrer • Schüler</div>
      </div>

      <div class="buttons">
        <button type="submit">Login</button>
        <button type="button" class="btn-back" onclick="history.back()">Zurück</button>
      </div>
    </form>

    <div class="foot">
      <div>Keine Selbst-Registrierung – nur zentrale Vergabe.</div>
      <div><span style="color:#f97316">AES</span> / Hashing / Sessions geschützt.</div>
    </div>
  </div>
</body>
</html>