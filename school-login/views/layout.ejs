<!doctype html>
<html lang="de" class="css-loading">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title || "Notenverwaltungssystem" %></title>
  <%
    const assetVersion = locals.assetVersion || "";
    const withAssetVersion = (assetPath) => {
      if (!assetVersion || typeof assetPath !== "string" || !assetPath.startsWith("/")) {
        return assetPath;
      }
      const separator = assetPath.includes("?") ? "&" : "?";
      return `${assetPath}${separator}v=${encodeURIComponent(assetVersion)}`;
    };
    const brandLogoPath = withAssetVersion("/images/nvs-logo.png");
  %>
  <style>
    html {
      background: #f4f6f9;
      color-scheme: light;
    }
    html[data-theme="dark"] {
      background: #0b1220;
      color-scheme: dark;
    }
    @media (prefers-color-scheme: dark) {
      html:not([data-theme="light"]) {
        background: #0b1220;
        color-scheme: dark;
      }
    }
    html.css-loading body { visibility: hidden; }
    html.css-ready body { visibility: visible; }
  </style>
  <script>
    (function () {
      document.documentElement.removeAttribute("data-theme");
    })();
  </script>
  <noscript>
    <style>
      html.css-loading body { visibility: visible; }
    </style>
  </noscript>
  <!-- Inter font for improved typography -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="icon" href="/favicon.ico" sizes="any" type="image/x-icon">
  <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png">
  <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png">
  <link rel="manifest" href="/site.webmanifest">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="<%= withAssetVersion('/css/base.css') %>">
  <link rel="stylesheet" href="<%= withAssetVersion('/css/app-shell.css') %>">
  <% (styles || []).forEach(function(href){ %>
    <link rel="stylesheet" href="<%= withAssetVersion(href) %>">
  <% }) %>
  <% if (locals.isMobile) { %>
    <link rel="stylesheet" href="<%= withAssetVersion('/css/mobile.css') %>">
    <link rel="stylesheet" href="<%= withAssetVersion('/css/mobile-sidebar.css') %>">
    <link rel="stylesheet" href="<%= withAssetVersion('/css/mobile-login.css') %>">
  <% } %>
  <link rel="stylesheet" href="<%= withAssetVersion('/css/style.css') %>">
  <script>
    (function () {
      const root = document.documentElement;
      const styleLinks = Array.from(document.querySelectorAll('link[rel="stylesheet"]'))
        .filter((link) => String(link.getAttribute("href") || "").startsWith("/css/"));
      let revealed = false;
      const reveal = () => {
        if (revealed) return;
        revealed = true;
        root.classList.remove("css-loading");
        root.classList.add("css-ready");
      };

      if (!styleLinks.length) {
        reveal();
        return;
      }

      let pending = 0;
      const done = () => {
        pending -= 1;
        if (pending <= 0) {
          requestAnimationFrame(reveal);
        }
      };

      styleLinks.forEach((link) => {
        if (link.sheet) return;
        pending += 1;
        link.addEventListener("load", done, { once: true });
        link.addEventListener("error", done, { once: true });
      });

      if (pending === 0) {
        reveal();
      } else {
        window.addEventListener("pageshow", reveal, { once: true });
        window.setTimeout(reveal, 1800);
      }
    })();
  </script>
</head>
<body class="<%= ['app-shell-body', bodyClass, locals.isMobile ? 'mobile-view' : 'desktop-view'].filter(Boolean).join(' ') %>">
  <button id="themeToggle" type="button" aria-label="Dark Mode umschalten" title="Dark Mode umschalten">Theme</button>

  <% if (!hideHeader) { %>
    <%- include('partials/site-header', { headerTitle: headerTitle || title, headerActions: headerActions || [], isMobile: locals.isMobile, brandLogoSrc: brandLogoPath }) %>
  <% } %>

  <main class="page-shell app-container">
    <% if (typeof content === 'function') { %>
      <%- content() %>
    <% } %>
  </main>

  <% if (!hideFooter) { %>
    <%- include('partials/site-footer') %>
  <% } %>

  <% if (locals.isMobile) { %>
    <script src="<%= withAssetVersion('/js/mobile-nav.js') %>"></script>
    <script src="<%= withAssetVersion('/js/mobile-login.js') %>"></script>
  <% } %>
  <script src="<%= withAssetVersion('/js/theme.js') %>"></script>
  <script src="<%= withAssetVersion('/js/app-modal.js') %>"></script>
  <% (scripts || []).forEach(function(src){ %>
    <script src="<%= withAssetVersion(src) %>"></script>
  <% }) %>
</body>
</html>
