<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title || "School Panel" %></title>
  <%
    const assetVersion = locals.assetVersion || "";
    const withAssetVersion = (assetPath) => {
      if (!assetVersion || typeof assetPath !== "string" || !assetPath.startsWith("/")) {
        return assetPath;
      }
      const separator = assetPath.includes("?") ? "&" : "?";
      return `${assetPath}${separator}v=${encodeURIComponent(assetVersion)}`;
    };
  %>
  <!-- Inter font for improved typography -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="<%= withAssetVersion('/css/base.css') %>">
  <link rel="stylesheet" href="<%= withAssetVersion('/css/app-shell.css') %>">
  <% (styles || []).forEach(function(href){ %>
    <link rel="stylesheet" href="<%= withAssetVersion(href) %>">
  <% }) %>
  <link rel="stylesheet" href="<%= withAssetVersion('/css/mobile.css') %>" media="screen and (max-width: 900px)">
  <link rel="stylesheet" href="<%= withAssetVersion('/css/mobile-sidebar.css') %>" media="screen and (max-width: 900px)">
  <link rel="stylesheet" href="<%= withAssetVersion('/css/mobile-login.css') %>" media="screen and (max-width: 900px)">
</head>
<body class="<%= ['app-shell-body', bodyClass, locals.isMobile ? 'mobile-view' : 'desktop-view'].filter(Boolean).join(' ') %>">
  <% if (!hideHeader) { %>
    <%- include('partials/site-header', { headerTitle: headerTitle || title, headerActions: headerActions || [], isMobile: locals.isMobile }) %>
  <% } %>

  <main class="page-shell app-container">
    <% if (typeof content === 'function') { %>
      <%- content() %>
    <% } %>
  </main>

  <% if (!hideFooter) { %>
    <%- include('partials/site-footer') %>
  <% } %>

  <script src="<%= withAssetVersion('/js/mobile-nav.js') %>"></script>
  <script src="<%= withAssetVersion('/js/mobile-login.js') %>"></script>
  <% (scripts || []).forEach(function(src){ %>
    <script src="<%= withAssetVersion(src) %>"></script>
  <% }) %>
</body>
</html>
