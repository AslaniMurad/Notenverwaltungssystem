<!doctype html>
<html
  lang="de"
  class="css-loading"
  data-theme="light"
  data-consent-cookie="<%= (legal && legal.consentCookieName) || 'nvs_cookie_consent' %>"
  data-consent-max-age-days="<%= (legal && legal.consentMaxAgeDays) || 180 %>"
>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%
    const pageTitle = typeof title !== "undefined" ? title : "Notenverwaltungssystem";
    const pageStyles = Array.isArray(typeof styles !== "undefined" ? styles : null) ? styles : [];
    const pageScripts = Array.isArray(typeof scripts !== "undefined" ? scripts : null) ? scripts : [];
    const pageBodyClass = typeof bodyClass !== "undefined" ? bodyClass : "";
    const pageHideHeader = typeof hideHeader !== "undefined" ? hideHeader : false;
    const pageHideFooter = typeof hideFooter !== "undefined" ? hideFooter : false;
    const pageHeaderTitle = typeof headerTitle !== "undefined" ? headerTitle : pageTitle;
    const pageHeaderActions =
      Array.isArray(typeof headerActions !== "undefined" ? headerActions : null) ? headerActions : [];
    const assetVersion = locals.assetVersion || "";
    const withAssetVersion = (assetPath) => {
      if (!assetVersion || typeof assetPath !== "string" || !assetPath.startsWith("/")) {
        return assetPath;
      }
      const separator = assetPath.includes("?") ? "&" : "?";
      return `${assetPath}${separator}v=${encodeURIComponent(assetVersion)}`;
    };
  %>
  <title><%= pageTitle %></title>
  <style>
    html.css-loading body { visibility: hidden; }
    html.css-ready body { visibility: visible; }
  </style>
  <script>
    (function () {
      var root = document.documentElement;
      var consentCookieName = <%- JSON.stringify((legal && legal.consentCookieName) || "nvs_cookie_consent") %>;
      function readCookie(name) {
        var cookies = document.cookie ? document.cookie.split(";") : [];
        for (var i = 0; i < cookies.length; i += 1) {
          var entry = cookies[i].trim();
          if (entry.indexOf(name + "=") === 0) {
            return decodeURIComponent(entry.slice(name.length + 1));
          }
        }
        return "";
      }

      function resolveSystemTheme() {
        return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
      }

      var theme = resolveSystemTheme();
      try {
        if (readCookie(consentCookieName) === "all") {
          var stored = localStorage.getItem("theme");
          if (stored === "light" || stored === "dark") {
            theme = stored;
          }
        }
      } catch (err) {
        theme = "light";
      }
      root.setAttribute("data-theme", theme);
    })();
  </script>
  <noscript>
    <style>
      html.css-loading body { visibility: visible; }
    </style>
  </noscript>
  <link rel="icon" type="image/svg+xml" href="<%= withAssetVersion('/favicon.svg') %>">
  <link rel="shortcut icon" href="<%= withAssetVersion('/favicon.svg') %>">
  <meta name="theme-color" content="#0F2D5C">
  <link rel="stylesheet" href="<%= withAssetVersion('/css/base.css') %>">
  <link rel="stylesheet" href="<%= withAssetVersion('/css/app-shell.css') %>">
  <% pageStyles.forEach(function(href){ %>
    <link rel="stylesheet" href="<%= withAssetVersion(href) %>">
  <% }) %>
  <% if (locals.isMobile) { %>
    <link rel="stylesheet" href="<%= withAssetVersion('/css/mobile.css') %>">
    <link rel="stylesheet" href="<%= withAssetVersion('/css/mobile-sidebar.css') %>">
    <link rel="stylesheet" href="<%= withAssetVersion('/css/mobile-login.css') %>">
  <% } %>
  <link rel="stylesheet" href="<%= withAssetVersion('/css/style.css') %>">
  <script>
    (function () {
      const root = document.documentElement;
      const styleLinks = Array.from(document.querySelectorAll('link[rel="stylesheet"]'))
        .filter((link) => String(link.getAttribute("href") || "").startsWith("/css/"));
      let revealed = false;
      const reveal = () => {
        if (revealed) return;
        revealed = true;
        root.classList.remove("css-loading");
        root.classList.add("css-ready");
      };

      if (!styleLinks.length) {
        reveal();
        return;
      }

      let pending = 0;
      const done = () => {
        pending -= 1;
        if (pending <= 0) {
          requestAnimationFrame(reveal);
        }
      };

      styleLinks.forEach((link) => {
        if (link.sheet) return;
        pending += 1;
        link.addEventListener("load", done, { once: true });
        link.addEventListener("error", done, { once: true });
      });

      if (pending === 0) {
        reveal();
      } else {
        window.addEventListener("pageshow", reveal, { once: true });
        window.setTimeout(reveal, 1800);
      }
    })();
  </script>
</head>
<body class="<%= ['app-shell-body', pageBodyClass, locals.isMobile ? 'mobile-view' : 'desktop-view'].filter(Boolean).join(' ') %>">
  <button id="themeToggle" type="button" aria-label="Dark Mode umschalten" title="Dark Mode umschalten">Theme</button>

  <% if (!pageHideHeader) { %>
    <%- include('partials/site-header', { headerTitle: pageHeaderTitle, headerActions: pageHeaderActions, isMobile: locals.isMobile }) %>
  <% } %>

  <main class="page-shell app-container">
    <% if (typeof content === 'function') { %>
      <%- content() %>
    <% } %>
  </main>

  <%- include('partials/site-footer') %>

  <%- include('partials/cookie-banner') %>

  <% if (locals.isMobile) { %>
    <script src="<%= withAssetVersion('/js/mobile-nav.js') %>"></script>
    <script src="<%= withAssetVersion('/js/mobile-login.js') %>"></script>
  <% } %>
  <script src="<%= withAssetVersion('/js/cookie-consent.js') %>"></script>
  <script src="<%= withAssetVersion('/js/theme.js') %>"></script>
  <% pageScripts.forEach(function(src){ %>
    <script src="<%= withAssetVersion(src) %>"></script>
  <% }) %>
</body>
</html>
