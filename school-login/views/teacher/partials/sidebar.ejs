<%
  const sidebarData = typeof teacherSidebar !== "undefined" ? teacherSidebar || {} : {};
  const sidebarClasses = Array.isArray(sidebarData.classes) ? sidebarData.classes : [];
  const activeClassData =
    typeof classData !== "undefined" && classData ? classData : null;
  const currentClassId =
    activeClassData && Number.isInteger(Number(activeClassData.id))
      ? Number(activeClassData.id)
      : Number.isInteger(Number(sidebarData.currentClassId))
      ? Number(sidebarData.currentClassId)
      : null;
  const activeClassNav = new Set([
    "students",
    "test-questions",
    "grades",
    "special-assessments",
    "grade-templates",
    "class-statistics"
  ]);
  const isActiveGeneralLink = (navKey) => activeNav === navKey ? "is-active" : "";
  const isActiveClassLink = (navKey, classId) =>
    activeNav === navKey && currentClassId != null && Number(classId) === Number(currentClassId);
  const currentClassBadgeCount =
    typeof openMessageCount !== "undefined" && Number(openMessageCount) > 0
      ? Number(openMessageCount)
      : 0;
%>
<aside class="teacher-sidebar" aria-label="Lehrer Navigation">
  <div class="sidebar-brand">
    <div>
      <div class="sidebar-title">Teacher Panel</div>
      <div class="sidebar-meta"><%= email %> - Lehrer</div>
    </div>
    <span class="sidebar-badge">Eingeloggt</span>
  </div>

  <div class="app-nav">
    <div class="nav-section">
      <div class="nav-section-title">Menue</div>
      <a class="<%= isActiveGeneralLink('classes') %>" href="/teacher/classes">Meine Klassen</a>
      <a class="<%= isActiveGeneralLink('create-class') %>" href="/teacher/create-class">Klasse erstellen</a>
      <a class="<%= isActiveGeneralLink('settings') %>" href="/teacher/settings">Einstellungen</a>
    </div>

    <div class="nav-section teacher-class-nav-section">
      <div class="nav-section-title">Klassenmenues</div>

      <% if (!sidebarClasses.length) { %>
        <p class="teacher-nav-empty">Noch keine Klassen zugewiesen.</p>
      <% } else { %>
        <div class="teacher-class-nav-list" data-teacher-class-nav>
          <% sidebarClasses.forEach((menuClass) => { %>
            <%
              const menuClassId = Number(menuClass.id);
              const isCurrentClass = currentClassId != null && menuClassId === currentClassId;
              const shouldOpen = isCurrentClass && activeClassNav.has(activeNav);
              const currentSummarySubject =
                isCurrentClass && activeClassData && activeClassData.subject
                  ? activeClassData.subject
                  : (menuClass.subject || "");
              const summarySubject = String(currentSummarySubject || "").trim() || "Ohne Fach";
              const testQuestionsClasses = [
                isActiveClassLink("test-questions", menuClassId) ? "is-active" : "",
                isCurrentClass && currentClassBadgeCount > 0 ? "is-alert" : ""
              ].filter(Boolean).join(" ");
            %>
            <details class="teacher-class-nav-group" <%= shouldOpen ? "open" : "" %>>
              <summary class="teacher-class-nav-summary">
                <span class="teacher-class-nav-summary-main">
                  <span class="teacher-class-nav-name"><%= menuClass.name %></span>
                  <span class="teacher-class-nav-subject"><%= summarySubject %></span>
                </span>
                <% if (isCurrentClass) { %>
                  <span class="teacher-class-nav-current">Aktiv</span>
                <% } %>
              </summary>

              <div class="teacher-class-nav-links">
                <a class="<%= isActiveClassLink('students', menuClassId) ? 'is-active' : '' %>" href="/teacher/students/<%= menuClassId %>">Schueler</a>
                <a class="<%= testQuestionsClasses %>" href="/teacher/test-questions/<%= menuClassId %>">
                  Fragen zu Tests
                  <% if (isCurrentClass && currentClassBadgeCount > 0) { %>
                    <span class="nav-notification-badge"><%= currentClassBadgeCount %></span>
                  <% } %>
                </a>
                <a class="<%= isActiveClassLink('grades', menuClassId) ? 'is-active' : '' %>" href="/teacher/grades/<%= menuClassId %>">Noten</a>
                <a class="<%= isActiveClassLink('special-assessments', menuClassId) ? 'is-active' : '' %>" href="/teacher/special-assessments/<%= menuClassId %>">Sonderleistungen</a>
                <a class="<%= isActiveClassLink('grade-templates', menuClassId) ? 'is-active' : '' %>" href="/teacher/grade-templates/<%= menuClassId %>">Pruefungen</a>
                <a class="<%= isActiveClassLink('class-statistics', menuClassId) ? 'is-active' : '' %>" href="/teacher/class-statistics/<%= menuClassId %>">Statistiken</a>
              </div>
            </details>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="nav-section">
      <form class="logout-form" method="POST" action="/logout">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="app-nav-link" type="submit">Logout</button>
      </form>
    </div>
  </div>
</aside>

<script>
  (function () {
    const containers = document.querySelectorAll("[data-teacher-class-nav]");
    if (!containers.length) return;

    containers.forEach((container) => {
      const groups = Array.from(container.querySelectorAll(".teacher-class-nav-group"));
      groups.forEach((group) => {
        group.addEventListener("toggle", () => {
          if (!group.open) return;
          groups.forEach((otherGroup) => {
            if (otherGroup !== group) {
              otherGroup.open = false;
            }
          });
        });
      });
    });
  })();
</script>
