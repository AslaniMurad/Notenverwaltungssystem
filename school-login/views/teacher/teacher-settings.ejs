<%
  const page = {
    title: 'Lehrer - Einstellungen',
    headerTitle: 'Lehrerbereich',
    styles: ['/css/teacher-pages.css'],
    scripts: ['/js/app.js'],
    bodyClass: 'page-teacher',
    hideHeader: true,
    hideFooter: true,
    content: function () {
      const activeUnit = 'Punkte';
      const scoringLabelByValue = {};
      (scoringModeOptions || []).forEach(option => {
        scoringLabelByValue[option.value] = option.label;
      });
%>
    <div class="app-shell teacher-shell">
      <aside class="teacher-sidebar" aria-label="Lehrer Navigation">
        <div class="sidebar-brand">
          <div>
            <div class="sidebar-title">Teacher Panel</div>
            <div class="sidebar-meta"><%= email %> · Lehrer</div>
          </div>
          <span class="sidebar-badge">Eingeloggt</span>
        </div>

        <div class="app-nav">
          <div class="nav-section">
            <div class="nav-section-title">Navigation</div>
            <a href="/teacher/classes">Meine Klassen</a>
            <a href="/teacher/create-class">Klasse erstellen</a>
            <a class="is-active" href="/teacher/settings">Einstellungen</a>
            <form class="logout-form" method="POST" action="/logout">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="app-nav-link" type="submit">Logout</button>
            </form>
          </div>
        </div>
      </aside>

      <section class="teacher-main">
        <header class="teacher-main-header">
          <div>
            <p class="teacher-eyebrow">Persoenliches Schema</p>
            <h1>Bewertungseinstellungen</h1>
            <p class="teacher-muted">Gewichtung erfolgt nur in Punkten.</p>
          </div>
          <div class="teacher-actions-inline">
            <a class="btn btn-secondary" href="/teacher/classes">Zurueck</a>
          </div>
        </header>

        <% if (!setupComplete || showSetupFlow) { %>
          <div class="teacher-alert info">
            Erste Konfiguration: Erstelle ein Profil. Dieses Profil wird automatisch fuer neue Pruefungen verwendet.
          </div>
        <% } %>

        <% if (message) { %>
          <div class="teacher-alert info"><%= message %></div>
        <% } %>
        <% if (error) { %>
          <div class="teacher-alert error"><%= error %></div>
        <% } %>

        <div class="teacher-card">
          <div class="teacher-card-header">
            <div>
              <p class="teacher-eyebrow">Profile</p>
              <h3><%= profiles.length %> gespeicherte Profile</h3>
            </div>
            <button class="btn btn-secondary btn-sm" type="button" id="new-profile-button">Neues Profil</button>
          </div>

          <% if (profiles.length === 0) { %>
            <div class="teacher-empty">
              <h4>Noch kein Profil vorhanden</h4>
              <p>Starte mit einem Standardprofil und passe danach die Punkte an.</p>
            </div>
          <% } else { %>
            <div class="settings-profiles">
              <% profiles.forEach(profile => { %>
                <div class="settings-profile-item <%= profile.is_active ? 'is-active' : '' %>">
                  <div>
                    <h4><%= profile.name %></h4>
                    <p class="teacher-muted">
                      Modus: Punkte · Eingabe: <%= scoringLabelByValue[profile.scoring_mode] || profile.scoring_mode %>
                    </p>
                  </div>
                  <div class="settings-profile-actions">
                    <a class="btn btn-secondary btn-sm" href="/teacher/settings?profile_id=<%= profile.id %>">Bearbeiten</a>
                    <% if (!profile.is_active) { %>
                      <form class="inline" method="POST" action="/teacher/settings/activate-profile/<%= profile.id %>">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="btn btn-primary btn-sm" type="submit">Aktivieren</button>
                      </form>
                    <% } else { %>
                      <span class="teacher-meta-chip">Aktiv</span>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>

        <div class="teacher-card">
          <div class="teacher-card-header">
            <div>
              <p class="teacher-eyebrow">Konfiguration</p>
              <h3>Profil bearbeiten</h3>
            </div>
            <div class="teacher-meta-chip">
              Summe: <span id="profile-total"><%= selectedTotal %></span>
              <span id="profile-total-unit"><%= activeUnit %></span>
            </div>
          </div>

          <form class="teacher-form" method="POST" action="/teacher/settings/save-profile" id="settings-profile-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="profile_id" id="profile_id" value="<%= formData.profile_id || '' %>">
            <input type="hidden" name="weight_mode" value="points">

            <label for="profile_name">Profilname *</label>
            <input
              type="text"
              id="profile_name"
              name="profile_name"
              required
              placeholder="z.B. Informatik Standard"
              value="<%= formData.profile_name || '' %>"
            >
            <small class="form-hint">Lehrer legen nur Punkte je Kategorie fest.</small>

            <label for="scoring_mode">Bewertungseingabe *</label>
            <select id="scoring_mode" name="scoring_mode" required>
              <% (scoringModeOptions || []).forEach(option => { %>
                <option
                  value="<%= option.value %>"
                  <%= String(formData.scoring_mode || '') === String(option.value) ? 'selected' : '' %>
                >
                  <%= option.label %>
                </option>
              <% }) %>
            </select>
            <small class="form-hint">Legt fest, ob bei neuen Bewertungen Noten, Punkte oder beides eingegeben wird.</small>

            <div class="settings-grid">
              <div class="settings-weight-item">
                <label for="grade1_min_percent">Ab Prozent Note 1</label>
                <input
                  type="number"
                  id="grade1_min_percent"
                  name="grade1_min_percent"
                  min="0"
                  max="100"
                  step="0.1"
                  required
                  value="<%= formData.thresholds && formData.thresholds.grade1_min_percent != null ? formData.thresholds.grade1_min_percent : '' %>"
                >
              </div>
              <div class="settings-weight-item">
                <label for="grade2_min_percent">Ab Prozent Note 2</label>
                <input
                  type="number"
                  id="grade2_min_percent"
                  name="grade2_min_percent"
                  min="0"
                  max="100"
                  step="0.1"
                  required
                  value="<%= formData.thresholds && formData.thresholds.grade2_min_percent != null ? formData.thresholds.grade2_min_percent : '' %>"
                >
              </div>
              <div class="settings-weight-item">
                <label for="grade3_min_percent">Ab Prozent Note 3</label>
                <input
                  type="number"
                  id="grade3_min_percent"
                  name="grade3_min_percent"
                  min="0"
                  max="100"
                  step="0.1"
                  required
                  value="<%= formData.thresholds && formData.thresholds.grade3_min_percent != null ? formData.thresholds.grade3_min_percent : '' %>"
                >
              </div>
              <div class="settings-weight-item">
                <label for="grade4_min_percent">Ab Prozent Note 4</label>
                <input
                  type="number"
                  id="grade4_min_percent"
                  name="grade4_min_percent"
                  min="0"
                  max="100"
                  step="0.1"
                  required
                  value="<%= formData.thresholds && formData.thresholds.grade4_min_percent != null ? formData.thresholds.grade4_min_percent : '' %>"
                >
              </div>
            </div>
            <small class="form-hint">Nur relevant, wenn Punkte erfasst werden und die Note automatisch berechnet wird.</small>

            <label class="checkbox-line" for="set_active">
              <input type="checkbox" id="set_active" name="set_active" value="1" <%= formData.set_active ? 'checked' : '' %>>
              Dieses Profil nach dem Speichern aktivieren
            </label>

            <div class="settings-grid">
              <% categoryDefinitions.forEach(category => { %>
                <div class="settings-weight-item">
                  <label for="weight_<%= category.slug %>"><%= category.label %></label>
                  <div class="settings-weight-input-row">
                    <input
                      type="number"
                      id="weight_<%= category.slug %>"
                      name="weight_<%= category.slug %>"
                      min="0"
                      step="0.5"
                      required
                      value="<%= formData.weights && formData.weights[category.key] != null ? formData.weights[category.key] : '' %>"
                      data-weight-field
                    >
                    <span class="settings-weight-unit"><%= activeUnit %></span>
                  </div>
                </div>
              <% }) %>
            </div>

            <div class="teacher-form-actions">
              <button class="btn btn-primary" type="submit">Schema speichern</button>
              <a class="btn btn-secondary" href="/teacher/classes">Abbrechen</a>
            </div>
          </form>
        </div>
      </section>
    </div>

    <script>
      (function() {
        const totalEl = document.getElementById('profile-total');
        const weightFields = Array.from(document.querySelectorAll('[data-weight-field]'));
        const newProfileButton = document.getElementById('new-profile-button');
        const profileIdField = document.getElementById('profile_id');
        const profileNameField = document.getElementById('profile_name');
        const setActiveField = document.getElementById('set_active');

        function sumWeights() {
          return weightFields.reduce((sum, input) => {
            const value = Number(String(input.value || '').replace(',', '.'));
            return Number.isFinite(value) ? sum + value : sum;
          }, 0);
        }

        function updateTotal() {
          const total = Number(sumWeights().toFixed(2));
          totalEl.textContent = String(total);
        }

        weightFields.forEach((field) => {
          field.addEventListener('input', updateTotal);
        });
        if (newProfileButton) {
          newProfileButton.addEventListener('click', () => {
            if (profileIdField) profileIdField.value = '';
            if (profileNameField) profileNameField.value = '';
            if (setActiveField) setActiveField.checked = true;
          });
        }
        updateTotal();
      })();
    </script>
<% } };
%>
<%- include('../layout', page) %>
