<%
  const page = {
    title: 'Lehrer - PrÃ¼fung erstellen',
    headerTitle: 'Lehrerbereich',
    styles: ['/css/teacher-pages.css'],
    scripts: ['/js/app.js'],
    bodyClass: 'page-teacher',
    hideHeader: true,
    hideFooter: true,
    content: function () {
      const unitLabel = 'Punkte';
      const defaultsByCategory = (activeProfile && activeProfile.weights) || {};
      const useProfileSettings = Boolean(formData && formData.use_profile_settings);
%>
    <div class="app-shell teacher-shell">
      <aside class="teacher-sidebar" aria-label="Lehrer Navigation">
        <%- include('../partials/sidebar-user-card', { user: { email, role: 'teacher' } }) %>

        <div class="app-nav">
          <div class="nav-section">
            <div class="nav-section-title">MenÃ¼</div>
            <a href="/teacher/classes">Fächer</a>
            <a href="/teacher/create-class">Fach erstellen</a>
            <a href="/teacher/settings">Einstellungen</a>
            <div class="nav-section-title">Klasse: <%= classData.name %> / <%= classData.subject %></div>
            <a href="/teacher/students/<%= classData.id %>">Schueler</a>
            <a class="<%= (typeof openMessageCount !== 'undefined' && openMessageCount > 0) ? 'is-alert' : '' %>" href="/teacher/test-questions/<%= classData.id %>">Fragen zu Tests<% if (typeof openMessageCount !== 'undefined' && openMessageCount > 0) { %><span class="nav-notification-badge"><%= openMessageCount %></span><% } %></a>
            <a href="/teacher/grades/<%= classData.id %>">Noten</a>
            <a href="/teacher/special-assessments/<%= classData.id %>">Sonderleistungen</a>
            <a class="is-active" href="/teacher/grade-templates/<%= classData.id %>">PrÃ¼fungen</a>
            <a href="/teacher/class-statistics/<%= classData.id %>">Statistiken</a>
            <form class="logout-form" method="POST" action="/logout">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="app-nav-link" type="submit">Logout</button>
            </form>
          </div>
        </div>
      </aside>

      <section class="teacher-main">
        <header class="teacher-main-header">
          <div>
            <p class="teacher-eyebrow">PrÃ¼fung anlegen</p>
            <h1>Klasse <%= classData.name %></h1>
            <p class="teacher-muted">Profil: <strong><%= activeProfile.name %></strong> Â· Modus: Punkte</p>
          </div>
          <div class="teacher-actions-inline">
            <a class="btn btn-secondary" href="/teacher/grade-templates/<%= classData.id %>">Abbrechen</a>
          </div>
        </header>

        <div class="teacher-card">
          <div class="teacher-card-header">
            <div>
              <p class="teacher-eyebrow">Neue PrÃ¼fungsvorlage</p>
              <h3>Gewichtung wird in Punkten festgelegt</h3>
            </div>
          </div>

          <% if (error) { %>
            <div class="teacher-alert error"><%= error %></div>
          <% } %>

          <div class="teacher-alert info">
            Du kannst den vorgeschlagenen Punktewert aus dem Profil Ã¼bernehmen oder manuell anpassen.
          </div>

          <form class="teacher-form" method="POST" action="/teacher/create-template/<%= classData.id %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <label for="name">Name der PrÃ¼fung *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="z.B. 1. Schularbeit"
              value="<%= formData && formData.name ? formData.name : '' %>"
            >

            <label for="category">Kategorie *</label>
            <select id="category" name="category" required>
              <option value="">-- Kategorie wÃ¤hlen --</option>
              <% categoryDefinitions.forEach(category => { %>
                <option
                  value="<%= category.key %>"
                  <%= formData && String(formData.category) === String(category.key) ? 'selected' : '' %>
                >
                  <%= category.label %>
                </option>
              <% }) %>
            </select>

            <label class="checkbox-line" for="use_profile_settings">
              <input
                type="checkbox"
                id="use_profile_settings"
                name="use_profile_settings"
                value="1"
                <%= useProfileSettings ? 'checked' : '' %>
              >
              Gespeicherte Einstellungen aus dem aktiven Profil verwenden
            </label>
            <small class="form-hint" id="profile-settings-hint">Wenn aktiv, werden Gewichtung und weitere Profilwerte automatisch uebernommen und gesperrt.</small>

            <label for="weight">Gewichtung (<span id="weight-unit-label"><%= unitLabel %></span>) *</label>
            <input
              type="number"
              id="weight"
              name="weight"
              min="0"
              step="0.5"
              data-manual-required="0"
              placeholder="Wert leer lassen fÃ¼r Profil-Vorschlag"
              value="<%= formData && formData.weight !== '' ? formData.weight : '' %>"
              <%= useProfileSettings ? 'disabled' : '' %>
            >
            <small class="form-hint" id="weight-hint">Profil-Vorschlag wird automatisch gesetzt.</small>

            <label for="max_points">Maximale Punkte (optional)</label>
            <input
              type="number"
              id="max_points"
              name="max_points"
              min="0.25"
              step="0.25"
              placeholder="z.B. 50"
              value="<%= formData && formData.max_points !== '' ? formData.max_points : '' %>"
              <%= useProfileSettings ? 'readonly class="is-readonly"' : '' %>
            >
            <small class="form-hint" id="max-points-hint">Wenn gesetzt, wird bei der Benotung nur noch "Erreichte Punkte" abgefragt.</small>

            <label for="date">Datum (optional)</label>
            <input type="date" id="date" name="date" value="<%= formData && formData.date ? formData.date : '' %>">

            <label for="description">Beschreibung (optional)</label>
            <textarea
              id="description"
              name="description"
              rows="3"
              placeholder="z.B. Thema, Kapitel, Hinweise"
            ><%= formData && formData.description ? formData.description : '' %></textarea>

            <div class="teacher-form-actions">
              <button class="btn btn-primary" type="submit">PrÃ¼fung anlegen</button>
              <a class="btn btn-secondary" href="/teacher/grade-templates/<%= classData.id %>">ZurÃ¼ck</a>
            </div>
          </form>
        </div>
      </section>
    </div>

    <script>
      (function() {
        const defaultsByCategory = <%- JSON.stringify(defaultsByCategory || {}).replace(/</g, "\\u003c") %>;
        const categorySelect = document.getElementById('category');
        const useProfileSettingsToggle = document.getElementById('use_profile_settings');
        const weightInput = document.getElementById('weight');
        const maxPointsInput = document.getElementById('max_points');
        const weightHint = document.getElementById('weight-hint');
        const profileSettingsHint = document.getElementById('profile-settings-hint');
        const maxPointsHint = document.getElementById('max-points-hint');
        const unitLabel = document.getElementById('weight-unit-label');
        const manualWeightRequired = weightInput ? weightInput.dataset.manualRequired === '1' : false;

        function formatWeight(value) {
          const numeric = Number(value);
          if (!Number.isFinite(numeric)) return '';
          return String(Number(numeric.toFixed(2)));
        }

        function syncManagedFieldState(suggestion) {
          const useProfileSettings = Boolean(useProfileSettingsToggle && useProfileSettingsToggle.checked);

          if (weightInput) {
            if (useProfileSettings) {
              if (!weightInput.disabled) {
                weightInput.dataset.manualValue = weightInput.value;
              }
              weightInput.value = Number.isFinite(Number(suggestion)) ? formatWeight(suggestion) : '';
            } else if (weightInput.disabled) {
              weightInput.value = Object.prototype.hasOwnProperty.call(weightInput.dataset, 'manualValue')
                ? weightInput.dataset.manualValue
                : '';
            }

            weightInput.disabled = useProfileSettings;
            weightInput.required = useProfileSettings ? false : manualWeightRequired;
          }

          if (maxPointsInput) {
            maxPointsInput.readOnly = useProfileSettings;
            maxPointsInput.classList.toggle('is-readonly', useProfileSettings);
          }

          if (profileSettingsHint) {
            profileSettingsHint.textContent = useProfileSettings
              ? 'Aktives Profil ist eingeschaltet: Gewichtung wird automatisch gesetzt und Maximalpunkte sind schreibgeschuetzt.'
              : 'Wenn aktiv, werden Gewichtung und weitere Profilwerte automatisch uebernommen und gesperrt.';
          }

          if (maxPointsHint) {
            maxPointsHint.textContent = useProfileSettings
              ? 'Maximalpunkte koennen bei aktiven Profileinstellungen nicht manuell geaendert werden.'
              : 'Wenn gesetzt, wird bei der Benotung nur noch "Erreichte Punkte" abgefragt.';
          }
        }

        function updateWeightSuggestion() {
          const selectedCategory = categorySelect ? categorySelect.value : '';
          const suggestion = defaultsByCategory ? defaultsByCategory[selectedCategory] : null;
          const useProfileSettings = Boolean(useProfileSettingsToggle && useProfileSettingsToggle.checked);
          const hasManualValue = String((weightInput && weightInput.value) || '').trim() !== '';
          if (unitLabel) unitLabel.textContent = 'Punkte';

          if (!selectedCategory) {
            if (weightHint) {
              weightHint.textContent = useProfileSettings
                ? 'Waehle zuerst eine Kategorie, damit das Profil die Gewichtung setzen kann.'
                : 'WÃ¤hle zuerst eine Kategorie.';
            }
            syncManagedFieldState(null);
            return;
          }

          if (Number.isFinite(Number(suggestion))) {
            if (weightHint) {
              weightHint.textContent = useProfileSettings
                ? 'Aktives Profil setzt die Gewichtung auf ' + formatWeight(suggestion) + ' Punkte.'
                : 'Vorschlag aus Profil: ' + formatWeight(suggestion) + ' Punkte.';
            }
            if (!useProfileSettings && !hasManualValue && weightInput) {
              weightInput.value = formatWeight(suggestion);
            }
          } else if (weightHint) {
            weightHint.textContent = 'Keine Profil-Gewichtung fÃ¼r diese Kategorie gefunden.';
          }
          syncManagedFieldState(suggestion);
        }

        if (categorySelect) categorySelect.addEventListener('change', updateWeightSuggestion);
        if (useProfileSettingsToggle) useProfileSettingsToggle.addEventListener('change', updateWeightSuggestion);
        updateWeightSuggestion();
      })();
    </script>
<% } };
%>
<%- include('../layout', page) %>
