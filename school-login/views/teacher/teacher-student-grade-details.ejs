<%
  const page = {
    title: `Lehrer - Transparenzdetails (${student.name})`,
    headerTitle: "Lehrerbereich",
    styles: ["/css/teacher-pages.css"],
    scripts: ["/js/app.js"],
    bodyClass: "page-teacher",
    hideHeader: true,
    hideFooter: true,
    content: function () {
      const thresholds = profileInfo && profileInfo.thresholds ? profileInfo.thresholds : {};
      const participation = profileInfo && profileInfo.participation ? profileInfo.participation : {};
%>
    <div class="app-shell teacher-shell">
      <aside class="teacher-sidebar" aria-label="Lehrer Navigation">
        <div class="sidebar-brand">
          <div>
            <div class="sidebar-title">Teacher Panel</div>
            <div class="sidebar-meta"><%= email %> - Lehrer</div>
          </div>
          <span class="sidebar-badge">Eingeloggt</span>
        </div>

        <div class="app-nav">
          <div class="nav-section">
            <div class="nav-section-title">Navigation</div>
            <a href="/teacher/classes">Meine Klassen</a>
            <a href="/teacher/create-class">Klasse erstellen</a>
            <div class="nav-section-title">Klasse: <%= classData.name %> / <%= classData.subject %></div>
            <a href="/teacher/students/<%= classData.id %>">Schueler</a>
            <a href="/teacher/grades/<%= classData.id %>">Noten</a>
            <a href="/teacher/special-assessments/<%= classData.id %>">Sonderleistungen</a>
            <a href="/teacher/grade-templates/<%= classData.id %>">Pruefungen</a>
            <a href="/teacher/class-statistics/<%= classData.id %>">Statistiken</a>
            <a href="/teacher/settings">Einstellungen</a>
            <form class="logout-form" method="POST" action="/logout">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="app-nav-link" type="submit">Logout</button>
            </form>
          </div>
        </div>
      </aside>

      <section class="teacher-main">
        <header class="teacher-main-header">
          <div>
            <p class="teacher-eyebrow">Transparenzdetails</p>
            <h1>Noten-Rechenweg von <%= student.name %></h1>
            <p class="teacher-muted">
              Klasse: <%= classData.name %> (<%= classData.subject %>)
              <% if (activeProfile) { %>
                - Profil: <%= activeProfile.name %>
              <% } else { %>
                - Kein aktives Profil
              <% } %>
            </p>
          </div>
          <div class="teacher-actions-inline">
            <a class="btn btn-secondary" href="/teacher/student-grades/<%= classData.id %>/<%= student.id %>">Zurueck zu Notendetails</a>
          </div>
        </header>

        <div class="teacher-card">
          <div class="teacher-card-header">
            <div>
              <p class="teacher-eyebrow">Ergebnis</p>
              <h3>Gesamtrechnung</h3>
            </div>
          </div>
          <% if (summary.weight_total > 0 && summary.average != null) { %>
            <div class="teacher-alert info">
              Endschnitt = gewichtete Summe / Gesamtgewicht = <strong><%= summary.weighted_sum %></strong> / <strong><%= summary.weight_total %></strong> = <strong><%= summary.average %></strong>
            </div>
          <% } else { %>
            <div class="teacher-alert error">
              Keine berechenbare Gesamtnote vorhanden (Gesamtgewicht = 0).
            </div>
          <% } %>
          <p class="teacher-muted">
            Einbezogene Eintraege: <strong><%= summary.included_count %></strong> |
            Ausgeschlossene Eintraege: <strong><%= summary.excluded_count %></strong> |
            Referenzschnitt (System): <strong><%= summary.reference_average != null ? summary.reference_average : "-" %></strong>
          </p>
          <p class="teacher-muted">
            Punkte (aktuell moeglich):
            <strong>
              <%= summary.points_achieved_total != null ? summary.points_achieved_total : "-" %>/<%= summary.points_max_total != null ? summary.points_max_total : "-" %>
            </strong>
            <% if (summary.points_percent != null) { %>
              (<%= summary.points_percent %>%)
            <% } %>
          </p>
        </div>

        <div class="teacher-card">
          <div class="teacher-card-header">
            <div>
              <p class="teacher-eyebrow">Regelwerk</p>
              <h3>Profil und Notengrenzen</h3>
            </div>
          </div>
          <div class="grades-table-wrapper">
            <table class="grades-table">
              <thead>
                <tr>
                  <th>Regel</th>
                  <th>Wert</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Scoring-Modus</td>
                  <td><%= profileInfo.scoring_mode_label %> (<%= profileInfo.scoring_mode %>)</td>
                </tr>
                <tr>
                  <td>Abwesenheit</td>
                  <td><%= profileInfo.absence_mode_label %> (<%= profileInfo.absence_mode %>)</td>
                </tr>
                <tr>
                  <td>Grenze Note 1 (ab %)</td>
                  <td><%= thresholds.grade1_min_percent %></td>
                </tr>
                <tr>
                  <td>Grenze Note 2 (ab %)</td>
                  <td><%= thresholds.grade2_min_percent %></td>
                </tr>
                <tr>
                  <td>Grenze Note 3 (ab %)</td>
                  <td><%= thresholds.grade3_min_percent %></td>
                </tr>
                <tr>
                  <td>Grenze Note 4 (ab %)</td>
                  <td><%= thresholds.grade4_min_percent %></td>
                </tr>
                <tr>
                  <td>Mitarbeit aktiv</td>
                  <td><%= participation.ma_enabled ? "Ja" : "Nein" %></td>
                </tr>
                <tr>
                  <td>MA-Gewichtung</td>
                  <td><%= participation.ma_weight %> Punkte</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="teacher-card">
          <div class="teacher-card-header">
            <div>
              <p class="teacher-eyebrow">MA-Skala</p>
              <h3>Symbol zu Notenwirkung</h3>
            </div>
          </div>
          <div class="grades-table-wrapper">
            <table class="grades-table">
              <thead>
                <tr>
                  <th>Symbol</th>
                  <th>Notenwirkung</th>
                </tr>
              </thead>
              <tbody>
                <% participationScale.forEach((entry) => { %>
                  <tr>
                    <td><span class="badge-count"><%= entry.symbol %></span></td>
                    <td><%= entry.grade != null ? Number(entry.grade).toFixed(2) : "-" %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="teacher-card">
          <div class="teacher-card-header">
            <div>
              <p class="teacher-eyebrow">Rohdaten</p>
              <h3>Alle bewerteten Eintraege mit Berechnungsdaten</h3>
            </div>
            <div class="teacher-meta-chip"><%= calculationRows.length %> Zeilen</div>
          </div>
          <div class="grades-table-wrapper">
            <table class="grades-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Typ</th>
                  <th>Bezeichnung</th>
                  <th>Kategorie</th>
                  <th>Erfasst</th>
                  <th>Pruefungsdatum</th>
                  <th>Note</th>
                  <th>Gewicht roh</th>
                  <th>Gewicht effektiv</th>
                  <th>Beitrag</th>
                  <th>Punkte</th>
                  <th>%</th>
                  <th>Punkte->Note</th>
                  <th>Abwesend</th>
                  <th>Gewichtet?</th>
                  <th>Grund</th>
                  <th>Notiz</th>
                </tr>
              </thead>
              <tbody>
                <% if (!calculationRows.length) { %>
                  <tr>
                    <td colspan="17">Keine Daten vorhanden.</td>
                  </tr>
                <% } else { %>
                  <% calculationRows.forEach((row) => { %>
                    <tr>
                      <td><%= row.step %></td>
                      <td><%= row.source_type %></td>
                      <td><%= row.source_name %></td>
                      <td><%= row.category %></td>
                      <td><%= row.created_at ? new Date(row.created_at).toLocaleString("de-DE") : "-" %></td>
                      <td><%= row.exam_date ? new Date(row.exam_date).toLocaleDateString("de-DE") : "-" %></td>
                      <td><%= row.grade != null ? row.grade.toFixed(2) : "-" %></td>
                      <td><%= row.raw_weight != null ? row.raw_weight.toFixed(2) : "-" %></td>
                      <td><%= row.effective_weight != null ? row.effective_weight.toFixed(2) : "-" %></td>
                      <td><%= row.contribution != null ? row.contribution.toFixed(4) : "-" %></td>
                      <td>
                        <% if (row.points_achieved != null && row.points_max != null) { %>
                          <%= row.points_achieved %> / <%= row.points_max %>
                        <% } else { %>
                          -
                        <% } %>
                      </td>
                      <td><%= row.points_percent != null ? row.points_percent.toFixed(2) : "-" %></td>
                      <td><%= row.grade_from_points != null ? row.grade_from_points.toFixed(2) : "-" %></td>
                      <td><%= row.is_absent ? "Ja" : "Nein" %></td>
                      <td><%= row.included ? "Ja" : "Nein" %></td>
                      <td><%= row.include_reason %></td>
                      <td><%= row.note || "-" %></td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="teacher-card">
          <div class="teacher-card-header">
            <div>
              <p class="teacher-eyebrow">Rechenweg</p>
              <h3>Laufende Summen pro Schritt</h3>
            </div>
          </div>
          <div class="grades-table-wrapper">
            <table class="grades-table">
              <thead>
                <tr>
                  <th>Schritt</th>
                  <th>Quelle</th>
                  <th>Gewichtet?</th>
                  <th>Note</th>
                  <th>Gewicht eff.</th>
                  <th>Beitrag</th>
                  <th>Laufende Summe</th>
                  <th>Laufendes Gewicht</th>
                  <th>Laufender Schnitt</th>
                </tr>
              </thead>
              <tbody>
                <% if (!calculationRows.length) { %>
                  <tr>
                    <td colspan="9">Keine Rechenschritte vorhanden.</td>
                  </tr>
                <% } else { %>
                  <% calculationRows.forEach((row) => { %>
                    <tr>
                      <td><%= row.step %></td>
                      <td><%= row.source_type %>: <%= row.source_name %></td>
                      <td><%= row.included ? "Ja" : "Nein" %></td>
                      <td><%= row.grade != null ? row.grade.toFixed(2) : "-" %></td>
                      <td><%= row.effective_weight != null ? row.effective_weight.toFixed(2) : "-" %></td>
                      <td><%= row.contribution != null ? row.contribution.toFixed(4) : "-" %></td>
                      <td><%= row.running_weighted_sum != null ? row.running_weighted_sum.toFixed(4) : "-" %></td>
                      <td><%= row.running_weight_total != null ? row.running_weight_total.toFixed(4) : "-" %></td>
                      <td><%= row.running_average != null ? row.running_average.toFixed(4) : "-" %></td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="teacher-card">
          <div class="teacher-card-header">
            <div>
              <p class="teacher-eyebrow">Offene Vorlagen</p>
              <h3>Noch nicht benotete Pruefungen</h3>
            </div>
            <div class="teacher-meta-chip"><%= openTemplates.length %> offen</div>
          </div>
          <div class="grades-table-wrapper">
            <table class="grades-table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Kategorie</th>
                  <th>Gewichtung</th>
                  <th>Max. Punkte</th>
                  <th>Datum</th>
                  <th>Beschreibung</th>
                </tr>
              </thead>
              <tbody>
                <% if (!openTemplates.length) { %>
                  <tr>
                    <td colspan="6">Alle Vorlagen sind bereits benotet.</td>
                  </tr>
                <% } else { %>
                  <% openTemplates.forEach((template) => { %>
                    <tr>
                      <td><%= template.name %></td>
                      <td><%= template.category %></td>
                      <td><%= template.weight_label %></td>
                      <td><%= template.max_points != null ? template.max_points : "-" %></td>
                      <td><%= template.date ? new Date(template.date).toLocaleDateString("de-DE") : "-" %></td>
                      <td><%= template.description || "-" %></td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </div>
<% } };
%>
<%- include("../layout", page) %>
