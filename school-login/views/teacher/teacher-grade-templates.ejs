<%
  const page = {
    title: `Lehrer - Pruefungsvorlagen (${classData.name})`,
    headerTitle: 'Lehrerbereich',
    styles: ['/css/teacher-pages.css'],
    scripts: ['/js/app.js'],
    bodyClass: 'page-teacher',
    hideHeader: true,
    hideFooter: true,
    content: function () {
%>
    <div class="app-shell teacher-shell">
      <aside class="teacher-sidebar" aria-label="Lehrer Navigation">
        <div class="sidebar-brand">
          <div>
            <div class="sidebar-title">Teacher Panel</div>
            <div class="sidebar-meta"><%= email %> · Lehrer</div>
          </div>
          <span class="sidebar-badge">Eingeloggt</span>
        </div>

        <div class="app-nav">
          <div class="nav-section">
            <div class="nav-section-title">Navigation</div>
            <a href="/teacher/classes">Meine Klassen</a>
            <a href="/teacher/create-class">Klasse erstellen</a>
            <div class="nav-section-title">Klasse: <%= classData.name %> / <%= classData.subject %></div>
            <a href="/teacher/students/<%= classData.id %>">Schueler</a>
            <a href="/teacher/grades/<%= classData.id %>">Noten</a>
            <a href="/teacher/special-assessments/<%= classData.id %>">Sonderleistungen</a>
            <a class="is-active" href="/teacher/grade-templates/<%= classData.id %>">Pruefungen</a>
            <a href="/teacher/class-statistics/<%= classData.id %>">Statistiken</a>
            <a href="/teacher/settings">Einstellungen</a>
            <form class="logout-form" method="POST" action="/logout">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="app-nav-link" type="submit">Logout</button>
            </form>
          </div>
        </div>
      </aside>

      <section class="teacher-main">
        <header class="teacher-main-header">
          <div>
            <p class="teacher-eyebrow">Klasse <%= classData.name %></p>
            <h1>Pruefungsvorlagen</h1>
            <p class="teacher-muted">
              Fach: <%= classData.subject %>
              <% if (activeProfile) { %>
                · Aktives Profil: <%= activeProfile.name %> (Punkte)
              <% } %>
            </p>
          </div>
          <div class="teacher-actions-inline">
            <a class="btn btn-primary" href="/teacher/create-template/<%= classData.id %>">+ Pruefung anlegen</a>
            <a class="btn btn-secondary" href="/teacher/classes">Zurueck</a>
          </div>
        </header>

        <% if (!activeProfile) { %>
          <div class="teacher-alert error">
            Bitte zuerst das Bewertungsschema in den <a href="/teacher/settings">Einstellungen</a> konfigurieren.
          </div>
        <% } %>

        <div class="teacher-alert info">
          Gesamtgewichtung: <%= totalPointWeight %> Punkte.
        </div>

        <div class="teacher-card">
          <div class="teacher-card-header">
            <div>
              <p class="teacher-eyebrow">Pruefungen</p>
              <h3>Verfuegbare Vorlagen</h3>
            </div>
            <div class="teacher-meta-chip"><%= templates.length %> Eintraege</div>
          </div>

          <div class="templates-list">
            <% if (templates.length === 0) { %>
              <div class="teacher-empty">
                <h4>Noch keine Pruefungen angelegt</h4>
                <p>Lege zuerst dein Bewertungsschema fest und erstelle dann die erste Vorlage.</p>
                <a class="btn btn-primary" href="/teacher/create-template/<%= classData.id %>">+ Erste Pruefung anlegen</a>
              </div>
            <% } else { %>
              <% templates.forEach(template => { %>
                <div class="template-item">
                  <div class="template-item-header">
                    <div>
                      <span class="grade-category-badge <%= template.category.toLowerCase() %>"><%= template.category %></span>
                      <h4 class="template-name"><%= template.name %></h4>
                      <% if (template.date) { %>
                        <span class="grade-date"><%= new Date(template.date).toLocaleDateString('de-DE') %></span>
                      <% } %>
                    </div>
                    <div class="template-item-actions">
                      <span class="weight-badge"><%= template.weight_label || template.weight %></span>
                      <form class="inline delete-template-form" method="POST" action="/teacher/delete-template/<%= classData.id %>/<%= template.id %>" data-template-name="<%= template.name %>">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="btn btn-danger btn-sm" type="button">Loeschen</button>
                      </form>
                    </div>
                  </div>
                  <% if (template.description) { %>
                    <p class="template-description"><%= template.description %></p>
                  <% } %>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>
      </section>
    </div>

    <div id="deleteTemplateModal" class="modal-overlay">
      <div class="modal-content">
        <div class="modal-header">
          <h3>Pruefung loeschen</h3>
        </div>
        <div class="modal-body">
          <p>Moechtest du die Pruefung <strong id="deleteTemplateName"></strong> wirklich loeschen?</p>
          <p class="teacher-muted">Alle zugeordneten Noten werden ebenfalls entfernt.</p>
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" id="cancelDeleteTemplate">Abbrechen</button>
          <button class="btn btn-danger" id="confirmDeleteTemplate">Loeschen</button>
        </div>
      </div>
    </div>

    <script>
      const deleteTemplateModal = document.getElementById('deleteTemplateModal');
      const deleteTemplateName = document.getElementById('deleteTemplateName');
      const cancelDeleteTemplate = document.getElementById('cancelDeleteTemplate');
      const confirmDeleteTemplate = document.getElementById('confirmDeleteTemplate');
      let currentTemplateForm = null;

      document.querySelectorAll('.delete-template-form button[type="button"]').forEach((btn) => {
        btn.addEventListener('click', (event) => {
          event.preventDefault();
          currentTemplateForm = btn.closest('form');
          deleteTemplateName.textContent = currentTemplateForm.dataset.templateName || '';
          deleteTemplateModal.classList.add('active');
        });
      });

      cancelDeleteTemplate.addEventListener('click', () => {
        deleteTemplateModal.classList.remove('active');
        currentTemplateForm = null;
      });

      confirmDeleteTemplate.addEventListener('click', () => {
        if (currentTemplateForm) currentTemplateForm.submit();
      });

      deleteTemplateModal.addEventListener('click', (event) => {
        if (event.target === deleteTemplateModal) {
          deleteTemplateModal.classList.remove('active');
          currentTemplateForm = null;
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && deleteTemplateModal.classList.contains('active')) {
          deleteTemplateModal.classList.remove('active');
          currentTemplateForm = null;
        }
      });
    </script>
<% } };
%>
<%- include('../layout', page) %>
