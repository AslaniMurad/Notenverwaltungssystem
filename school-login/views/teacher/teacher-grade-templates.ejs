<%
  const page = {
    title: `Lehrer - Pruefungsvorlagen (${classData.name})`,
    headerTitle: 'Lehrerbereich',
    styles: ['/css/teacher-pages.css'],
    scripts: ['/js/app.js'],
    bodyClass: 'page-teacher',
    hideHeader: true,
    hideFooter: true,
    content: function () {
      const categoryClass = (value) =>
        String(value || "")
          .normalize("NFD")
          .replace(/[\u0300-\u036f]/g, "")
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/^-+|-+$/g, "");
      const categoryStyle = (value) => {
        const key = categoryClass(value);
        const palette = {
          schularbeit: { bg: "#fee2e2", fg: "#991b1b" },
          test: { bg: "#dbeafe", fg: "#1e40af" },
          projekt: { bg: "#d1fae5", fg: "#065f46" },
          hausaufgabe: { bg: "#fef3c7", fg: "#92400e" },
          mitarbeit: { bg: "#ede9fe", fg: "#5b21b6" },
          wiederholung: { bg: "#e0f2fe", fg: "#0c4a6e" },
          prasentation: { bg: "#fee2e2", fg: "#991b1b" },
          wunschprufung: { bg: "#e0f2fe", fg: "#0369a1" },
          benutzerdefiniert: { bg: "#ede9fe", fg: "#5b21b6" },
          mundlich: { bg: "#fce7f3", fg: "#9f1239" }
        };
        const tone = palette[key];
        return tone ? `--cat-bg:${tone.bg};--cat-fg:${tone.fg};` : "";
      };
%>
    <div class="app-shell teacher-shell">
      <aside class="teacher-sidebar" aria-label="Lehrer Navigation">
        <div class="sidebar-brand">
          <div>
            <div class="sidebar-title">Teacher Panel</div>
            <div class="sidebar-meta"><%= email %> - Lehrer</div>
          </div>
          <span class="sidebar-badge">Eingeloggt</span>
        </div>

        <div class="app-nav">
          <div class="nav-section">
            <div class="nav-section-title">Menue</div>
            <a href="/teacher/classes">Meine Klassen</a>
            <a href="/teacher/create-class">Klasse erstellen</a>
            <a href="/teacher/settings">Einstellungen</a>
            <div class="nav-section-title">Klasse: <%= classData.name %> / <%= classData.subject %></div>
            <a href="/teacher/students/<%= classData.id %>">Schueler</a>
            <a class="<%= (typeof openMessageCount !== 'undefined' && openMessageCount > 0) ? 'is-alert' : '' %>" href="/teacher/test-questions/<%= classData.id %>">Fragen zu Tests</a>
            <a href="/teacher/grades/<%= classData.id %>">Noten</a>
            <a href="/teacher/special-assessments/<%= classData.id %>">Sonderleistungen</a>
            <a class="is-active" href="/teacher/grade-templates/<%= classData.id %>">Pruefungen</a>
            <a href="/teacher/class-statistics/<%= classData.id %>">Statistiken</a>
            <form class="logout-form" method="POST" action="/logout">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="app-nav-link" type="submit">Logout</button>
            </form>
          </div>
        </div>
      </aside>

      <section class="teacher-main">
        <header class="teacher-main-header">
          <div>
            <p class="teacher-eyebrow">Klasse <%= classData.name %></p>
            <h1>Pruefungsvorlagen</h1>
            <p class="teacher-muted">
              Fach: <%= classData.subject %>
              <% if (activeProfile) { %>
                - Aktives Profil: <%= activeProfile.name %> (Punkte)
              <% } %>
            </p>
          </div>
          <div class="teacher-actions-inline">
            <a class="btn btn-primary" href="/teacher/create-template/<%= classData.id %>">+ Pruefung anlegen</a>
            <a class="btn btn-secondary" href="/teacher/classes">Zurueck</a>
          </div>
        </header>

        <% if (!activeProfile) { %>
          <div class="teacher-alert error">
            Bitte zuerst das Bewertungsschema in den <a href="/teacher/settings">Einstellungen</a> konfigurieren.
          </div>
        <% } %>

        <div class="teacher-alert info">
          Gesamtgewichtung: <%= totalPointWeight %> Punkte.
        </div>

        <form class="teacher-search-form" method="GET" action="/teacher/grade-templates/<%= classData.id %>">
          <input
            class="form-input teacher-search-input"
            type="search"
            name="q"
            placeholder="Pruefung, Kategorie oder Datum suchen"
            value="<%= (search && search.q) || '' %>"
          >
          <select class="form-select teacher-search-select" name="category" aria-label="Kategorie">
            <option value="">Alle Kategorien</option>
            <% (categoryOptions || []).forEach((option) => { %>
              <option value="<%= option.key %>" <%= (search && search.category) === option.key ? 'selected' : '' %>><%= option.label %></option>
            <% }) %>
          </select>
          <select class="form-select teacher-search-select" name="points" aria-label="Maximalpunkte">
            <option value="all" <%= (search && search.points) === 'all' ? 'selected' : '' %>>Alle (Max. Punkte)</option>
            <option value="with_max" <%= (search && search.points) === 'with_max' ? 'selected' : '' %>>Nur mit Max. Punkten</option>
            <option value="without_max" <%= (search && search.points) === 'without_max' ? 'selected' : '' %>>Nur ohne Max. Punkte</option>
          </select>
          <select class="form-select teacher-search-select" name="sort" aria-label="Sortierung">
            <option value="date_desc" <%= (search && search.sort) === 'date_desc' ? 'selected' : '' %>>Datum (neueste zuerst)</option>
            <option value="date_asc" <%= (search && search.sort) === 'date_asc' ? 'selected' : '' %>>Datum (aelteste zuerst)</option>
            <option value="name_asc" <%= (search && search.sort) === 'name_asc' ? 'selected' : '' %>>Name A-Z</option>
            <option value="name_desc" <%= (search && search.sort) === 'name_desc' ? 'selected' : '' %>>Name Z-A</option>
            <option value="weight_desc" <%= (search && search.sort) === 'weight_desc' ? 'selected' : '' %>>Gewichtung absteigend</option>
            <option value="weight_asc" <%= (search && search.sort) === 'weight_asc' ? 'selected' : '' %>>Gewichtung aufsteigend</option>
            <option value="max_desc" <%= (search && search.sort) === 'max_desc' ? 'selected' : '' %>>Max. Punkte absteigend</option>
            <option value="max_asc" <%= (search && search.sort) === 'max_asc' ? 'selected' : '' %>>Max. Punkte aufsteigend</option>
            <option value="category_asc" <%= (search && search.sort) === 'category_asc' ? 'selected' : '' %>>Kategorie A-Z</option>
          </select>
          <button class="btn btn-primary" type="submit">Suchen</button>
          <a class="btn btn-secondary" href="/teacher/grade-templates/<%= classData.id %>">Reset</a>
        </form>

        <div class="teacher-card">
          <div class="teacher-card-header">
            <div>
              <p class="teacher-eyebrow">Pruefungen</p>
              <h3>Verfuegbare Vorlagen</h3>
            </div>
            <div class="teacher-meta-chip"><%= templates.length %> / <%= totalTemplateCount %> Eintraege</div>
          </div>

          <% if (templates.length === 0) { %>
            <div class="teacher-empty">
              <h4>Noch keine Pruefungen angelegt</h4>
              <p>Lege zuerst dein Bewertungsschema fest und erstelle dann die erste Vorlage.</p>
              <a class="btn btn-primary" href="/teacher/create-template/<%= classData.id %>">+ Erste Pruefung anlegen</a>
            </div>
          <% } else { %>
            <div class="grades-table-wrapper">
              <table class="grades-table">
                <thead>
                  <tr>
                    <th>Kategorie</th>
                    <th>Pruefung</th>
                    <th>Datum</th>
                    <th>Gewichtung</th>
                    <th>Max. Punkte</th>
                    <th>Aktionen</th>
                  </tr>
                </thead>
                <tbody>
                  <% templates.forEach(template => { %>
                    <tr>
                      <td>
                        <span class="grade-category-badge <%= template.category_slug || categoryClass(template.category) %>" style="<%= categoryStyle(template.category_slug || template.category) %>"><%= template.category %></span>
                      </td>
                      <td>
                        <div class="template-table-main">
                          <strong><%= template.name %></strong>
                        </div>
                      </td>
                      <td><%= template.date ? new Date(template.date).toLocaleDateString('de-DE') : '-' %></td>
                      <td><strong><%= template.weight_label || template.weight %></strong></td>
                      <td>
                        <%= template.max_points != null && Number(template.max_points) > 0 ? (template.max_points + ' Punkte') : '-' %>
                      </td>
                      <td>
                        <div class="template-table-actions">
                          <a class="btn btn-secondary btn-sm" href="/teacher/edit-template/<%= classData.id %>/<%= template.id %>">Bearbeiten</a>
                          <form class="inline delete-template-form" method="POST" action="/teacher/delete-template/<%= classData.id %>/<%= template.id %>" data-template-name="<%= template.name %>">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button class="btn btn-danger btn-sm" type="button">Loeschen</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </section>
    </div>

    <div id="deleteTemplateModal" class="modal-overlay">
      <div class="modal-content">
        <div class="modal-header">
          <h3>Pruefung loeschen</h3>
        </div>
        <div class="modal-body">
          <p>Moechtest du die Pruefung <strong id="deleteTemplateName"></strong> wirklich loeschen?</p>
          <p class="teacher-muted">Alle zugeordneten Noten werden ebenfalls entfernt.</p>
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" id="cancelDeleteTemplate">Abbrechen</button>
          <button class="btn btn-danger" id="confirmDeleteTemplate">Loeschen</button>
        </div>
      </div>
    </div>

    <script>
      (function applyCategoryBadgeClasses() {
        const normalizeToken = (value) =>
          String(value || '')
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '')
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, ' ')
            .trim();

        document.querySelectorAll('.grade-category-badge').forEach((badge) => {
          const token = normalizeToken(badge.textContent);
          let key = '';
          if (token.includes('schularbeit')) key = 'schularbeit';
          else if (token.includes('mitarbeit')) key = 'mitarbeit';
          else if (token.includes('wiederholung')) key = 'wiederholung';
          else if (token.includes('hausaufgabe') || token.includes('hausubung') || token.includes('hausuebung')) key = 'hausaufgabe';
          else if (token.includes('projekt')) key = 'projekt';
          else if (token.includes('test')) key = 'test';
          else if (token.includes('prasentation') || token.includes('praesentation')) key = 'prasentation';
          else if (token.includes('wunschprufung') || token.includes('wunschpruefung')) key = 'wunschprufung';
          else if (token.includes('benutzerdefiniert')) key = 'benutzerdefiniert';
          else if (token.includes('mundlich')) key = 'mundlich';
          if (key) badge.classList.add(key);
        });
      })();

      const deleteTemplateModal = document.getElementById('deleteTemplateModal');
      const deleteTemplateName = document.getElementById('deleteTemplateName');
      const cancelDeleteTemplate = document.getElementById('cancelDeleteTemplate');
      const confirmDeleteTemplate = document.getElementById('confirmDeleteTemplate');
      let currentTemplateForm = null;

      document.querySelectorAll('.delete-template-form button[type="button"]').forEach((btn) => {
        btn.addEventListener('click', (event) => {
          event.preventDefault();
          currentTemplateForm = btn.closest('form');
          deleteTemplateName.textContent = currentTemplateForm.dataset.templateName || '';
          deleteTemplateModal.classList.add('active');
        });
      });

      cancelDeleteTemplate.addEventListener('click', () => {
        deleteTemplateModal.classList.remove('active');
        currentTemplateForm = null;
      });

      confirmDeleteTemplate.addEventListener('click', () => {
        if (currentTemplateForm) currentTemplateForm.submit();
      });

      deleteTemplateModal.addEventListener('click', (event) => {
        if (event.target === deleteTemplateModal) {
          deleteTemplateModal.classList.remove('active');
          currentTemplateForm = null;
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && deleteTemplateModal.classList.contains('active')) {
          deleteTemplateModal.classList.remove('active');
          currentTemplateForm = null;
        }
      });
    </script>
<% } };
%>
<%- include('../layout', page) %>
