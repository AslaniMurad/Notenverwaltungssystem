<%
  const page = {
    title: `Lehrer - Pruefung benoten (${classData.name})`,
    headerTitle: 'Lehrerbereich',
    styles: ['/css/teacher-pages.css'],
    scripts: ['/js/app.js'],
    bodyClass: 'page-teacher',
    hideHeader: true,
    hideFooter: true,
    content: function () {
      const mode = scoringMode || 'points_or_grade';
      const requiresGrade = mode === 'grade_only' || mode === 'points_and_grade';
      const requiresPoints = mode === 'points_only' || mode === 'points_and_grade';
      const pointsAllowed = mode !== 'grade_only';
      const gradeAllowed = mode !== 'points_only';
%>
    <div class="app-shell teacher-shell">
      <aside class="teacher-sidebar" aria-label="Lehrer Navigation">
        <div class="sidebar-brand">
          <div>
            <div class="sidebar-title">Teacher Panel</div>
            <div class="sidebar-meta"><%= email %> - Lehrer</div>
          </div>
          <span class="sidebar-badge">Eingeloggt</span>
        </div>

        <div class="app-nav">
          <div class="nav-section">
            <div class="nav-section-title">Menue</div>
            <a href="/teacher/classes">Meine Klassen</a>
            <a href="/teacher/create-class">Klasse erstellen</a>
            <a href="/teacher/settings">Einstellungen</a>
            <div class="nav-section-title">Klasse: <%= classData.name %> / <%= classData.subject %></div>
            <a href="/teacher/students/<%= classData.id %>">Schueler</a>
            <a href="/teacher/grades/<%= classData.id %>">Noten</a>
            <a href="/teacher/special-assessments/<%= classData.id %>">Sonderleistungen</a>
            <a class="is-active" href="/teacher/grade-templates/<%= classData.id %>">Pruefungen</a>
            <a href="/teacher/class-statistics/<%= classData.id %>">Statistiken</a>
            <form class="logout-form" method="POST" action="/logout">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="app-nav-link" type="submit">Logout</button>
            </form>
          </div>
        </div>
      </aside>

      <section class="teacher-main">
        <header class="teacher-main-header">
          <div>
            <p class="teacher-eyebrow">Sammelbenotung</p>
            <h1><%= template.name %></h1>
            <p class="teacher-muted">
              Klasse: <%= classData.name %> - Fach: <%= classData.subject %>
            </p>
          </div>
          <div class="teacher-actions-inline">
            <a class="btn btn-secondary" href="/teacher/grade-templates/<%= classData.id %>">Zurueck zu Pruefungen</a>
          </div>
        </header>

        <% if (message) { %>
          <div class="teacher-alert info"><%= message %></div>
        <% } %>

        <% if (error) { %>
          <div class="teacher-alert error">
            <p><%= error %></p>
            <% if (validationErrors && validationErrors.length) { %>
              <ul class="bulk-grade-errors">
                <% validationErrors.forEach((entry) => { %>
                  <li><%= entry %></li>
                <% }) %>
              </ul>
            <% } %>
          </div>
        <% } %>

        <div class="teacher-card">
          <div class="teacher-card-header">
            <div>
              <p class="teacher-eyebrow">Pruefungsdaten</p>
              <h3>Schuelerliste zum Benoten</h3>
            </div>
            <div class="teacher-meta-chip"><%= rows.length %> Schueler</div>
          </div>

          <div class="teacher-alert info">
            Bewertungsmodus: <strong><%= scoringModeLabel || 'Punkte oder Noten' %></strong> -
            <% if (templateHasMaxPoints) { %>
              Max. Punkte: <strong><%= templateMaxPoints %></strong>
            <% } else { %>
              Keine maximalen Punkte hinterlegt.
            <% } %>
            <% if (existingCount > 0) { %>
              Bereits benotet: <strong><%= existingCount %></strong>
            <% } %>
          </div>

          <form class="teacher-form" method="POST" action="/teacher/bulk-grade-template/<%= classData.id %>/<%= template.id %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="grades-table-wrapper">
              <table class="grades-table bulk-grade-table">
                <thead>
                  <tr>
                    <th>Schueler</th>
                    <th>Status</th>
                    <th>Note (1-5)</th>
                    <th>Punkte</th>
                    <th>Abwesend</th>
                    <th>Notiz</th>
                  </tr>
                </thead>
                <tbody>
                  <% rows.forEach((row) => { %>
                    <% const fieldKey = `s_${row.student.id}`; %>
                    <tr class="<%= row.existing ? 'bulk-grade-row-locked' : '' %>">
                      <td>
                        <strong><%= row.student.name %></strong>
                        <div class="teacher-muted"><%= row.student.email %></div>
                      </td>
                      <td>
                        <% if (row.existing) { %>
                          <span class="template-status template-status-graded">
                            Bereits bewertet
                          </span>
                        <% } else { %>
                          <span class="template-status template-status-open">Offen</span>
                        <% } %>
                      </td>
                      <td>
                        <% if (!gradeAllowed) { %>
                          <span class="teacher-muted">-</span>
                        <% } else { %>
                          <input
                            class="bulk-grade-input"
                            type="text"
                            inputmode="decimal"
                            name="grade[<%= fieldKey %>]"
                            value="<%= row.form.grade %>"
                            placeholder="z.B. 2.5"
                          >
                        <% } %>
                      </td>
                      <td>
                        <% if (!pointsAllowed) { %>
                          <span class="teacher-muted">-</span>
                        <% } else { %>
                          <input
                            class="bulk-grade-input bulk-points-input"
                            type="text"
                            inputmode="decimal"
                            name="points_achieved[<%= fieldKey %>]"
                            value="<%= row.form.points_achieved %>"
                            <%= templateHasMaxPoints ? '' : 'disabled' %>
                            data-points-enabled="<%= templateHasMaxPoints ? '1' : '0' %>"
                            placeholder="<%= templateHasMaxPoints ? 'z.B. 18' : 'Keine Max.-Punkte' %>"
                          >
                        <% } %>
                      </td>
                      <td>
                        <label class="checkbox-line">
                          <input
                            class="bulk-absent-checkbox"
                            type="checkbox"
                            name="is_absent[<%= fieldKey %>]"
                            value="1"
                            <%= row.form.is_absent ? 'checked' : '' %>
                          >
                          <span>Ja</span>
                        </label>
                      </td>
                      <td>
                        <input
                          class="bulk-grade-note"
                          type="text"
                          name="note[<%= fieldKey %>]"
                          value="<%= row.form.note %>"
                          maxlength="500"
                          placeholder="Optional"
                        >
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <small class="form-hint">
              Bereits vorhandene Bewertungen sind vorausgefuellt und koennen bei Bedarf direkt angepasst werden.
            </small>
            <p class="form-hint">
              Tipp: Dezimalwerte koennen mit Punkt oder Komma eingegeben werden.
            </p>

            <div class="teacher-form-actions">
              <button class="btn btn-primary" type="submit">Bewertungen speichern</button>
              <a class="btn btn-secondary" href="/teacher/grade-templates/<%= classData.id %>">Abbrechen</a>
            </div>
          </form>
        </div>
      </section>
    </div>

    <script>
      document.querySelectorAll('.bulk-absent-checkbox').forEach((checkbox) => {
        const row = checkbox.closest('tr');
        if (!row) return;
        const gradeInput = row.querySelector('.bulk-grade-input:not(.bulk-points-input)');
        const pointsInput = row.querySelector('.bulk-points-input');
        const toggleInputs = () => {
          const absent = checkbox.checked;
          if (gradeInput) {
            gradeInput.disabled = absent;
            if (absent) gradeInput.value = '';
          }
          if (pointsInput) {
            const pointsEnabled = pointsInput.dataset.pointsEnabled === '1';
            pointsInput.disabled = absent || !pointsEnabled;
            if (absent) pointsInput.value = '';
          }
        };
        checkbox.addEventListener('change', toggleInputs);
        toggleInputs();
      });

      const bulkForm = document.querySelector('form.teacher-form');
      bulkForm?.addEventListener('submit', (event) => {
        const rows = Array.from(document.querySelectorAll('.bulk-grade-table tbody tr'));
        const hasAnyValue = rows.some((row) => {
          const gradeValue = String(row.querySelector('input[name^="grade["]')?.value || '').trim();
          const pointsValue = String(row.querySelector('input[name^="points_achieved["]')?.value || '').trim();
          const noteValue = String(row.querySelector('input[name^="note["]')?.value || '').trim();
          const absentChecked = Boolean(row.querySelector('input[name^="is_absent["]')?.checked);
          return gradeValue || pointsValue || noteValue || absentChecked;
        });

        if (!hasAnyValue) {
          event.preventDefault();
          window.alert('Bitte mindestens eine Bewertung eintragen (Note, Punkte, Abwesend oder Notiz).');
          return;
        }

        const submitButton = bulkForm.querySelector('button[type="submit"]');
        if (submitButton) {
          submitButton.disabled = true;
          submitButton.textContent = 'Speichert...';
        }
      });
    </script>
<% } };
%>
<%- include('../layout', page) %>
