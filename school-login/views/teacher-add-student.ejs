<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Schüler hinzufügen</title>
  <style>
    :root{
      --bg:#020817;
      --card:#050816;
      --card-soft:#0b1020;
      --accent:#3b82f6;
      --border-soft:rgba(148,163,253,.14);
      --text:#e5e7eb;
      --muted:#6b7280;
      --radius-xl:18px;
      --shadow:0 22px 55px rgba(15,23,42,.95);
      --font:system-ui, -apple-system, BlinkMacSystemFont, -system-ui, sans-serif;
    }
    *{margin:0;padding:0;box-sizing:border-box}
    body{
      min-height:100vh;
      font-family:var(--font);
      background:radial-gradient(circle at top,#111827 0, #020817 38%, #000 100%);
      color:var(--text);
      display:flex;
      align-items:center;
      justify-content:center;
      padding:24px;
    }
    .container {
      width:100%;
      max-width:520px;
      background:radial-gradient(circle at top, rgba(37,99,235,.08), var(--card));
      border-radius:var(--radius-xl);
      padding:22px 24px 20px;
      box-shadow:var(--shadow);
      border:1px solid var(--border-soft);
      backdrop-filter:blur(20px);
    }
    .brand{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
    .logo-dot{width:22px;height:22px;border-radius:999px;background:radial-gradient(circle at 30% 0, #60a5fa, #1d4ed8);box-shadow:0 0 18px rgba(37,99,235,.75);}
    .brand-title{font-size:17px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:#9ca3af;}
    h1 {
      font-size:21px;
      font-weight:600;
      margin-bottom:4px;
      color:#e5e7eb;
    }
    .subtitle {
      font-size:11px;
      color:var(--muted);
      margin-bottom:8px;
    }
    .user-info {
      font-size:10px;
      color:var(--muted);
      margin-bottom:16px;
    }
    .error {
      background:rgba(239,68,68,.15);
      color:#fca5a5;
      border:1px solid rgba(239,68,68,.3);
      padding:10px;
      border-radius:10px;
      margin-bottom:14px;
      text-align:center;
      font-size:11px;
    }
    .form-group {
      margin-bottom:14px;
    }
    label {
      display:block;
      color:#9ca3af;
      margin-bottom:6px;
      font-size:10px;
    }
    input {
      width:100%;
      padding:9px 10px;
      border:1px solid rgba(75,85,99,.9);
      border-radius:11px;
      background:linear-gradient(to bottom,var(--card-soft),#020817);
      color:var(--text);
      font-size:11px;
      outline:none;
      transition:all .17s ease;
    }
    input::placeholder{color:#4b5563;font-size:10px;}
    input:focus {
      border-color:var(--accent);
      box-shadow:0 0 16px rgba(37,99,235,.28);
      transform:translateY(-1px);
    }
    .btn {
      width:100%;
      padding:9px 0;
      background:linear-gradient(to right,#2563eb,#4f46e5);
      color:#f9fafb;
      border:none;
      border-radius:12px;
      font-size:11px;
      font-weight:500;
      cursor:pointer;
      box-shadow:0 15px 32px rgba(15,23,42,1);
      transition:all .18s ease-in-out;
      margin-top:10px;
    }
    .btn:hover {
      transform:translateY(-1px);
      box-shadow:0 22px 40px rgba(15,23,42,1);
      filter:saturate(1.08);
    }
    .btn-secondary {
      background:linear-gradient(to right,#4b5563,#374151);
      margin-top:8px;
    }
    a {
      text-decoration:none;
      color:inherit;
    }
    .info-box {
      background:rgba(59,130,246,.12);
      border:1px solid rgba(59,130,246,.25);
      padding:10px;
      border-radius:10px;
      margin-bottom:16px;
      font-size:10px;
      color:#93c5fd;
    }
    @media (max-width:480px){body{padding:14px;} .container{padding:18px 16px 14px;} h1{font-size:18px;}}
  </style>
</head>
<body>
  <div class="container">
    <div class="brand">
      <div class="logo-dot"></div>
      <div class="brand-title">Lehrer Panel</div>
    </div>
    <h1>Schüler hinzufügen</h1>
    <p class="subtitle">Klasse: <%= classData.name %></p>
    <div class="user-info">
      Eingeloggt als: <%= email %>
    </div>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <div class="info-box">
      💡 Der Schüler muss als Benutzer mit der Rolle "student" bereits existieren.
    </div>

    <form method="POST" action="/teacher/add-student/<%= classData.id %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      
      <div class="form-group">
        <label for="name">Name des Schülers:</label>
        <input type="text" id="name" name="name" required placeholder="Max Mustermann">
      </div>

      <div class="form-group">
        <label for="email">E-Mail des Schülers:</label>
        <input type="email" id="email" name="email" required placeholder="max.mustermann@schule.at">
      </div>

      <button type="submit" class="btn">Schüler hinzufügen</button>
      <a href="/teacher/students/<%= classData.id %>">
        <button type="button" class="btn btn-secondary">Abbrechen</button>
      </a>
    </form>
  </div>
</body>
</html>
