<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Schüler - <%= classData.name %></title>
  <style>
    :root{
      --bg:#020817;
      --card:#050816;
      --card-soft:#0b1020;
      --accent:#3b82f6;
      --border-soft:rgba(148,163,253,.14);
      --text:#e5e7eb;
      --muted:#6b7280;
      --radius-xl:18px;
      --shadow:0 22px 55px rgba(15,23,42,.95);
      --font:system-ui, -apple-system, BlinkMacSystemFont, -system-ui, sans-serif;
    }
    *{margin:0;padding:0;box-sizing:border-box}
    body{
      min-height:100vh;
      font-family:var(--font);
      background:radial-gradient(circle at top,#111827 0, #020817 38%, #000 100%);
      color:var(--text);
      display:flex;
      align-items:center;
      justify-content:center;
      padding:24px;
    }
    .container {
      width:100%;
      max-width:800px;
      background:radial-gradient(circle at top, rgba(37,99,235,.08), var(--card));
      border-radius:var(--radius-xl);
      padding:22px 24px 20px;
      box-shadow:var(--shadow);
      border:1px solid var(--border-soft);
      backdrop-filter:blur(20px);
    }
    .brand{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
    .logo-dot{width:22px;height:22px;border-radius:999px;background:radial-gradient(circle at 30% 0, #60a5fa, #1d4ed8);box-shadow:0 0 18px rgba(37,99,235,.75);}
    .brand-title{font-size:17px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:#9ca3af;}
    h1 {
      font-size:21px;
      font-weight:600;
      margin-bottom:4px;
      color:#e5e7eb;
    }
    .subtitle {
      font-size:11px;
      color:var(--muted);
      margin-bottom:8px;
    }
    .user-info {
      font-size:10px;
      color:var(--muted);
      margin-bottom:18px;
    }
    .btn {
      display:inline-block;
      padding:8px 16px;
      background:linear-gradient(to right,#2563eb,#4f46e5);
      color:white;
      text-decoration:none;
      border-radius:10px;
      border:none;
      cursor:pointer;
      font-size:11px;
      font-weight:500;
      transition:all .18s ease;
      margin:4px;
      box-shadow:0 8px 16px rgba(15,23,42,.8);
    }
    .btn:hover {
      transform:translateY(-1px);
      box-shadow:0 12px 24px rgba(15,23,42,1);
    }
    .btn-secondary {
      background:linear-gradient(to right,#4b5563,#374151);
    }
    .actions {
      display:flex;
      justify-content:space-between;
      align-items:center;
      margin-bottom:20px;
      flex-wrap:wrap;
      gap:10px;
    }
    .student-list {
      margin-top:20px;
    }
    .student-item {
      background:linear-gradient(to bottom,var(--card-soft),#020817);
      border-radius:12px;
      padding:16px;
      margin-bottom:12px;
      border:1px solid rgba(75,85,99,.85);
      transition:all .18s ease;
    }
    .student-item:hover{
      border-color:var(--accent);
      box-shadow:0 0 20px rgba(37,99,235,.2);
      transform:translateY(-2px);
    }
    .student-item h3 {
      color:#e5e7eb;
      margin-bottom:5px;
      font-size:14px;
    }
    .student-item p {
      color:var(--muted);
      font-size:11px;
    }
    .empty-state {
      text-align:center;
      padding:40px;
      color:var(--muted);
      font-size:12px;
    }
    form {
      display:inline;
    }
    @media (max-width:720px){.container{padding:18px 16px 14px} h1{font-size:19px}}
  </style>
</head>
<body>
  <div class="container">
    <div class="brand">
      <div class="logo-dot"></div>
      <div class="brand-title">Lehrer Panel</div>
    </div>
    <h1>Schüler - <%= classData.name %></h1>
    <p class="subtitle">Fach: <%= classData.subject %></p>
    <div class="user-info">
      Eingeloggt als: <%= email %>
    </div>

    <div class="actions">
      <a href="/teacher/add-student/<%= classData.id %>" class="btn">+ Schüler hinzufügen</a>
      <a href="/teacher/classes" class="btn btn-secondary">Zurück zu Klassen</a>
    </div>

    <div class="student-list">
      <% if (students.length === 0) { %>
        <div class="empty-state">
          <p>Noch keine Schüler in dieser Klasse.</p>
          <p>Klicke auf "Schüler hinzufügen", um zu beginnen.</p>
        </div>
      <% } else { %>
        <% students.forEach(student => { %>
          <div class="student-item">
            <h3><%= student.name %></h3>
            <p>E-Mail: <%= student.email %></p>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</body>
</html>
