<%- include('layout', {
  title: 'Dashboard',
  styles: ['/css/dashboard.css'],
  scripts: ['/js/app.js'],
  bodyClass: 'page-dashboard',
  content: function() { %>
    <div class="dashboard-shell">
      <div>
        <div class="dashboard-brand">
          <div class="dashboard-logo"></div>
          <div class="brand-title-quiet">School Panel</div>
        </div>
        <div class="dashboard-pill">
          <span class="bullet"></span>
          Eingeloggt – sichere Schulverwaltung aktiv
        </div>
        <h1 class="dashboard-headline">Willkommen zurück, <%= email %></h1>
        <p class="dashboard-subline">
          Du bist angemeldet als <b><%= role %></b>. Verwende das Panel rechts, um in den passenden Bereich zu wechseln.
        </p>
        <div class="dashboard-meta">
          <div><strong>Rolle</strong><br><%= role %></div>
          <div><strong>Sicherheit</strong><br>Session-Cookies, CSRF-Schutz</div>
          <div class="dashboard-tag">Nur autorisierte Zugriffe</div>
        </div>
      </div>
      <div class="dashboard-right">
        <div>
          <div class="dashboard-right-label">Account</div>
          <div class="dashboard-right-email"><%= email %></div>
          <div class="dashboard-right-role">Level: <%= role %></div>
        </div>
        <div class="dashboard-nav-row">
          <% if (role === "admin") { %>
            <a class="dashboard-link" href="/admin">Admin-Bereich öffnen</a>
          <% } else if (role === "student") { %>
            <a class="dashboard-link" href="/student">Schüler-Dashboard</a>
          <% } else { %>
            <span class="dashboard-nav-hint">Nutze das Menü deiner Rolle entsprechend.</span>
          <% } %>
        </div>
        <form class="logout-form" method="POST" action="/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="logout-btn" type="submit">Logout</button>
        </form>
      </div>
    </div>
<% } ) %>
