<header class="site-header">
  <div class="header-brand">
    <a href="/" class="htl-logo" title="Zur Startseite">
      <img src="<%= brandLogoSrc || '/images/nvs-logo.png' %>" alt="Notenverwaltungssystem Logo" class="htl-logo-img">
    </a>
    <div>
      <div class="brand-meta">HTL Waidhofen | Notenverwaltung</div>
      <div class="brand-title"><%= headerTitle || 'Notenverwaltungssystem' %></div>
    </div>
  </div>
  <% if (headerActions && headerActions.length) { %>
    <nav class="header-actions" aria-label="Hauptaktionen">
      <% headerActions.forEach(function(action){ %>
        <a class="btn btn-secondary" href="<%= action.href %>"><%= action.label %></a>
      <% }) %>
    </nav>
  <% } %>
</header>
