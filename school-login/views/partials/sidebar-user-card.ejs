<%
  const resolvedActiveSchoolYear = typeof activeSchoolYear !== "undefined"
    ? activeSchoolYear
    : (typeof locals !== "undefined" ? locals.activeSchoolYear : null);
  const resolvedSidebarStudentClass = typeof sidebarStudentClass !== "undefined"
    ? sidebarStudentClass
    : (typeof locals !== "undefined" ? locals.sidebarStudentClass : null);
  const resolvedSidebarTeacherKvClasses = typeof sidebarTeacherKvClasses !== "undefined"
    ? sidebarTeacherKvClasses
    : (typeof locals !== "undefined" ? locals.sidebarTeacherKvClasses : null);
  const sidebarUser = userDisplay.buildSidebarUser({
    ...(user || {}),
    activeSchoolYearName: resolvedActiveSchoolYear?.name || "",
    className: resolvedSidebarStudentClass || "",
    teacherKvClasses: resolvedSidebarTeacherKvClasses || ""
  });
%>
<div class="sidebar-brand">
  <div class="sidebar-brand-copy">
    <div class="sidebar-title"><%= sidebarUser.titleLine %></div>
    <% sidebarUser.metaLines.forEach((line) => { %>
      <div class="sidebar-meta"><%= line %></div>
    <% }) %>
  </div>
  <span class="sidebar-badge"><%= sidebarUser.badgeLabel %></span>
</div>
