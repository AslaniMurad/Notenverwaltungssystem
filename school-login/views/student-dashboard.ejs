<%
  const pageMeta = {
    overview: { title: "Schueler - Uebersicht", heading: "Uebersicht" },
    tasks: { title: "Schueler - Aufgaben", heading: "Aufgaben" },
    returns: { title: "Schueler - Rueckgaben", heading: "Rueckgaben" },
    requests: { title: "Schueler - Anfragen", heading: "Anfragen" },
    grades: { title: "Schueler - Noten", heading: "Noten" },
    archive: { title: "Schueler - Archiv", heading: "Archiv" }
  };
  const requestedPage = typeof activePage !== "undefined" ? String(activePage) : "overview";
  const currentPage = pageMeta[requestedPage] ? requestedPage : "overview";
  const currentMeta = pageMeta[currentPage];
  const safeSubjects = Array.isArray(subjects) ? subjects : [];
  const resolvedActiveSchoolYear = (typeof activeSchoolYear !== "undefined"
    ? activeSchoolYear
    : (typeof locals !== "undefined" ? locals.activeSchoolYear : null)) || null;
  const schoolYearLabel = studentProfile.schoolYear || resolvedActiveSchoolYear?.name || "-";
  const page = {
    title: currentMeta.title,
    headerTitle: "Schuelerbereich",
    styles: ["/css/student-dashboard.css"],
    scripts: ["/js/app.js", "/js/student-dashboard.js"],
    bodyClass: "page-student",
    hideHeader: true,
    hideFooter: true,
    content: function () { %>
    <button class="mobile-nav-toggle" aria-label="Navigation oeffnen"></button>
    <div class="app-shell app-shell-wide">
      <aside class="app-sidebar" aria-label="Schuelernavigation">
        <%- include('./partials/sidebar-user-card', { user: { email, role: 'student', name: studentProfile.name } }) %>

        <div class="app-nav">
          <div class="nav-section">
            <div class="nav-section-title">Menue</div>
            <a class="<%= currentPage === 'overview' ? 'is-active' : '' %>" href="/student">Uebersicht</a>
            <a class="<%= currentPage === 'tasks' ? 'is-active' : '' %>" href="/student/tasks">Aufgaben</a>
            <a class="<%= currentPage === 'returns' ? 'is-active' : '' %>" href="/student/returns">Rueckgaben</a>
            <a class="<%= currentPage === 'requests' ? 'is-active' : '' %>" href="/student/requests">Anfragen</a>
            <a class="<%= currentPage === 'grades' ? 'is-active' : '' %>" href="/student/grades">Noten</a>
            <a class="<%= currentPage === 'archive' ? 'is-active' : '' %>" href="/student/archive">Archiv</a>
            <form class="logout-form" method="POST" action="/logout">
              <% if (typeof csrfToken !== "undefined") { %>
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <% } %>
              <button class="app-nav-link" type="submit">Logout</button>
            </form>
          </div>
        </div>
      </aside>

      <section class="app-main">
        <header class="dashboard-hero">
          <div class="header-left">
            <img src="/images/nvs-logo.png" alt="Notenverwaltungssystem Logo" class="htl-small">
            <div>
              <h1>HTBLuVA Waidhofen an der Ybbs</h1>
              <small><%= currentMeta.heading %></small>
            </div>
          </div>
          <div class="header-right">
            <div class="dashboard-identity">
              <strong><%= studentProfile.name %></strong>
              <div class="dashboard-identity-meta">
                <span>Klasse <%= studentProfile.class %></span>
                <span>Schuljahr <%= schoolYearLabel %></span>
              </div>
              <small><%= email %></small>
            </div>
            <form class="logout-form" method="POST" action="/logout">
              <% if (typeof csrfToken !== "undefined") { %>
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <% } %>
              <button class="logout-button" type="submit">Logout</button>
            </form>
          </div>
        </header>

        <main class="student-main">
          <% if (currentPage === "overview") { %>
            <section id="overview">
              <div class="card">
                <div class="dataset-head">
                  <div>
                    <h3>Uebersicht</h3>
                    <p class="dataset-copy">Schneller Einstieg fuer aktuelle Noten, Aufgaben und Rueckmeldungen.</p>
                  </div>
                </div>
                <div class="info-grid">
                  <div class="stat-tile">
                    <h4>Durchschnitt</h4>
                    <strong id="overview-average">-</strong>
                  </div>
                  <div class="stat-tile">
                    <h4>Faecher</h4>
                    <strong id="overview-subject-count"><%= safeSubjects.length %></strong>
                  </div>
                  <div class="stat-tile">
                    <h4>Offene Aufgaben</h4>
                    <strong id="overview-open-tasks">-</strong>
                  </div>
                  <div class="stat-tile">
                    <h4>Rueckgaben</h4>
                    <strong id="overview-return-count">-</strong>
                  </div>
                  <div class="stat-tile">
                    <h4>Offene Rueckfragen</h4>
                    <strong id="overview-open-requests">-</strong>
                  </div>
                </div>
              </div>

              <div class="card">
                <div class="dataset-head">
                  <div>
                    <h3>Naechste Aufgaben</h3>
                    <p class="dataset-copy">Die naechsten faelligen Leistungen mit Fachbezug.</p>
                  </div>
                  <span class="dataset-count" id="overview-upcoming-count">-</span>
                </div>
                <div id="overview-upcoming" class="overview-list"></div>
              </div>

              <div class="card">
                <div class="dataset-head">
                  <div>
                    <h3>Letzte Benotungen</h3>
                    <p class="dataset-copy">Die zuletzt eingetragenen Bewertungen ueber alle Faecher.</p>
                  </div>
                  <span class="dataset-count" id="overview-latest-grade-count">-</span>
                </div>
                <div id="overview-latest-grades" class="overview-list"></div>
              </div>

              <div class="card">
                <div class="dataset-head">
                  <div>
                    <h3>Letzte Rueckgaben</h3>
                    <p class="dataset-copy">Rueckgaben mit Notenstand und Aktivitaet.</p>
                  </div>
                  <span class="dataset-count" id="overview-recent-return-count">-</span>
                </div>
                <div id="overview-recent-returns" class="overview-list"></div>
              </div>
            </section>
          <% } %>

          <% if (currentPage === "tasks") { %>
            <section id="tasks">
              <div class="card">
                <div class="dataset-head">
                  <div>
                    <h3>Aufgaben</h3>
                    <p class="dataset-copy">Filterbar und kompakte Liste fuer viele Eintraege.</p>
                  </div>
                  <span class="dataset-count" id="task-count">-</span>
                </div>
                <form id="task-filter" class="filter-grid" aria-label="Aufgaben filtern">
                  <label>Fach
                    <select name="subject" id="task-filter-subject">
                      <option value="">Alle</option>
                      <% safeSubjects.forEach(function(sub){ %>
                        <option value="<%= sub %>"><%= sub %></option>
                      <% }) %>
                    </select>
                  </label>
                  <label>Suche
                    <input type="search" name="query" id="task-filter-query" placeholder="Titel oder Beschreibung">
                  </label>
                </form>
                <div id="task-list"></div>
              </div>
            </section>
          <% } %>

          <% if (currentPage === "returns") { %>
            <section id="returns">
              <div class="card">
                <div class="dataset-head">
                  <div>
                    <h3>Rueckgaben</h3>
                    <p class="dataset-copy">Alle Rueckgaben mit Fach, Status und direktem Zugriff auf Rueckfragen.</p>
                  </div>
                  <span class="dataset-count" id="return-count">-</span>
                </div>
                <form id="return-filter" class="filter-grid" aria-label="Rueckgaben filtern">
                  <label>Fach
                    <select name="subject" id="return-filter-subject">
                      <option value="">Alle</option>
                      <% safeSubjects.forEach(function(sub){ %>
                        <option value="<%= sub %>"><%= sub %></option>
                      <% }) %>
                    </select>
                  </label>
                  <label>Suche
                    <input type="search" name="query" id="return-filter-query" placeholder="Titel oder Beschreibung">
                  </label>
                </form>
                <div id="return-list"></div>
              </div>
            </section>
          <% } %>

          <% if (currentPage === "requests") { %>
            <section id="requests">
              <div class="card">
                <div class="dataset-head">
                  <div>
                    <h3>Anfragen</h3>
                    <p class="dataset-copy">Nur bestehende oder bereits gefuehrte Tickets, sortiert nach Aktivitaet.</p>
                  </div>
                  <span class="dataset-count" id="request-count">-</span>
                </div>
                <form id="request-filter" class="filter-grid" aria-label="Anfragen filtern">
                  <label>Rueckgabe
                    <select name="gradeId" id="request-filter-grade">
                      <option value="">Alle Rueckgaben</option>
                    </select>
                  </label>
                  <label>Suche
                    <input type="search" name="query" id="request-filter-query" placeholder="Titel, Notiz oder Nachricht">
                  </label>
                </form>
                <div id="request-list"></div>
              </div>
            </section>
          <% } %>

          <% if (currentPage === "grades") { %>
            <% const selectedGradeSubject = typeof gradeSubject === "string" ? gradeSubject : ""; %>
            <% const gradeFilterValues = (typeof gradeFilters !== "undefined" && gradeFilters) ? gradeFilters : {}; %>
            <section id="grades">
              <% if (!selectedGradeSubject) { %>
                <div class="card">
                  <div class="dataset-head grades-header">
                    <div>
                      <h3>Fach auswaehlen</h3>
                      <p class="dataset-copy">Waehle ein Fach. Danach oeffnet sich die Detailansicht mit deinem aktuellen Stand und dem Beurteilungsprotokoll.</p>
                    </div>
                    <div class="button-row">
                      <a class="btn small secondary" href="/student/grades.csv">CSV Export</a>
                      <a class="btn small secondary" href="/student/grades.pdf">PDF Export</a>
                    </div>
                  </div>
                  <div id="grade-subject-overview" class="grade-subject-grid" aria-live="polite"></div>
                </div>
              <% } else { %>
                <div class="card">
                  <div class="dataset-head grades-header">
                    <div>
                      <div class="grade-back-link-row">
                        <a class="btn small secondary" href="/student/grades">Zur Faecheruebersicht</a>
                      </div>
                      <h3><%= selectedGradeSubject %></h3>
                      <p class="dataset-copy">Beurteilungsprotokoll und aktueller Stand fuer dieses Fach.</p>
                    </div>
                    <div class="button-row">
                      <a class="btn small secondary" href="/student/grades.csv">CSV Export</a>
                      <a class="btn small secondary" href="/student/grades.pdf">PDF Export</a>
                    </div>
                  </div>

                  <div id="grade-subject-detail" class="grade-subject-detail" aria-live="polite"></div>

                  <form id="grade-filter" class="filter-grid" aria-label="Noten filtern">
                    <input type="hidden" name="subject" id="filter-subject" value="<%= selectedGradeSubject %>" data-grade-subject-locked="true">
                    <label>Suche
                      <input type="search" name="query" id="filter-query" value="<%= gradeFilterValues.query || '' %>" placeholder="Leistung, Kommentar oder Lehrkraft">
                    </label>
                    <label>Von
                      <input type="date" name="startDate" id="filter-start" value="<%= gradeFilterValues.startDate || '' %>">
                    </label>
                    <label>Bis
                      <input type="date" name="endDate" id="filter-end" value="<%= gradeFilterValues.endDate || '' %>">
                    </label>
                    <label>Sortierung
                      <select name="sort" id="filter-sort">
                        <option value="date" <%= (gradeFilterValues.sort || 'date') === 'date' ? 'selected' : '' %>>Datum (neueste zuerst)</option>
                        <option value="value" <%= gradeFilterValues.sort === 'value' ? 'selected' : '' %>>Beste Note zuerst</option>
                      </select>
                    </label>
                  </form>

                  <div class="dataset-head grade-protocol-head">
                    <div>
                      <h3 id="grade-protocol-title">Beurteilungsprotokoll</h3>
                      <p class="dataset-copy" id="grade-protocol-copy">Alle sichtbaren Eintraege nach deinen Filtern.</p>
                    </div>
                  </div>

                  <div class="info-grid" id="grade-insights">
                    <div class="stat-tile">
                      <h4>Fachdurchschnitt</h4>
                      <strong id="avg-overall">-</strong>
                    </div>
                    <div class="stat-tile">
                      <h4>Trend</h4>
                      <div id="avg-trend" class="badge-inline">-</div>
                    </div>
                    <div class="stat-tile">
                      <h4>Letzte Aktualisierung</h4>
                      <small id="avg-updated">-</small>
                    </div>
                    <div class="stat-tile">
                      <h4>Sichtbare Eintraege</h4>
                      <strong id="grade-count">-</strong>
                    </div>
                  </div>

                  <div id="grade-list" aria-live="polite" class="dataset-block"></div>
                </div>
              <% } %>
            </section>
          <% } %>

          <% if (currentPage === "archive") { %>
            <section id="archive">
              <div class="card">
                <div class="dataset-head">
                  <div>
                    <h3>Archivierte Pruefungen</h3>
                    <p class="dataset-copy">Historische Leistungen mit denselben Filtern wie im Live-Bereich.</p>
                  </div>
                  <span class="dataset-count" id="archive-count">-</span>
                </div>
                <form id="archive-filter" class="filter-grid" aria-label="Archiv filtern">
                  <label>Fach
                    <select name="subject" id="archive-filter-subject">
                      <option value="">Alle</option>
                      <% safeSubjects.forEach(function(sub){ %>
                        <option value="<%= sub %>"><%= sub %></option>
                      <% }) %>
                    </select>
                  </label>
                  <label>Suche
                    <input type="search" name="query" id="archive-filter-query" placeholder="Titel oder Beschreibung">
                  </label>
                </form>
                <div id="archive-list"></div>
              </div>
            </section>
          <% } %>
        </main>
      </section>
    </div>
    <script type="application/json" id="student-initial-data"><%- JSON.stringify(initialData || {}).replace(/</g, "\\u003c") %></script>
<% } };
%>
<%- include('layout', page) %>
