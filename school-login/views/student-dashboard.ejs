<%
  const page = {
    title: 'Schüler-Dashboard',
    styles: ['/css/student-dashboard.css'],
    scripts: ['/js/app.js'],
    bodyClass: 'page-student',
    hideHeader: true,
    hideFooter: true,
    content: function () { %>
<div class="app-shell app-shell-wide student-shell">
  <aside class="app-sidebar student-sidebar" aria-label="Schülernavigation">
    <div class="sidebar-brand">
      <div>
        <div class="sidebar-title">Schüler-Dashboard</div>
        <div class="sidebar-meta"><%= studentProfile.name %> · <%= studentProfile.class %></div>
      </div>
      <span class="sidebar-badge">Aktiv</span>
    </div>

    <div class="app-nav">
      <div class="nav-section">
        <div class="nav-section-title">Bereiche</div>
        <a class="student-tab-link is-active" href="#overview" data-tab-target="overview">Übersicht</a>
        <a class="student-tab-link" href="#tasks" data-tab-target="tasks">Aufgaben</a>
        <a class="student-tab-link" href="#returns" data-tab-target="returns">Rückgaben</a>
        <a class="student-tab-link" href="#grades" data-tab-target="grades">Noten</a>
        <a class="student-tab-link" href="#materials" data-tab-target="materials">Materialien</a>
        <button class="nav-trigger" data-target="#messages-panel" aria-expanded="false">Kommunikation <span class="chevron">›</span></button>
        <div class="nav-panel" id="messages-panel">
          <a class="student-tab-link" href="#messages" data-tab-target="messages">Nachrichten</a>
        </div>
        <form class="logout-form" method="POST" action="/logout">
          <% if (typeof csrfToken !== 'undefined') { %>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <% } %>
          <button class="app-nav-link" type="submit">Logout</button>
        </form>
        <p class="nav-note">Die Leiste bleibt beim Navigieren sichtbar.</p>
      </div>
    </div>
  </aside>

  <section class="app-main student-main">
    <header class="student-hero">
      <div class="student-hero-main">
        <img src="/images/htl-waidhofen.png" alt="HTL Waidhofen" class="htl-small" onerror="this.style.display='none'">
        <div>
          <h1><%= hero.headline %></h1>
          <small><%= hero.summary %></small>
        </div>
      </div>
      <div class="student-person">
        <div>
          <strong><%= studentProfile.name %></strong><br>
          <small>Klasse <%= studentProfile.class %></small><br>
          <small><%= email %></small>
        </div>
        <form class="logout-form" method="POST" action="/logout">
          <% if (typeof csrfToken !== 'undefined') { %>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <% } %>
          <button class="btn btn-secondary" type="submit">Logout</button>
        </form>
      </div>
    </header>

    <div class="student-tabs" role="tablist">
      <button class="student-tab is-active" type="button" data-tab="overview">Übersicht</button>
      <button class="student-tab" type="button" data-tab="tasks">Aufgaben</button>
      <button class="student-tab" type="button" data-tab="returns">Rückgaben</button>
      <button class="student-tab" type="button" data-tab="grades">Noten</button>
      <button class="student-tab" type="button" data-tab="materials">Materialien</button>
      <button class="student-tab" type="button" data-tab="messages">Nachrichten</button>
    </div>

    <section id="overview" class="student-tab-content is-active" aria-label="Übersicht">
      <div class="student-grid-two">
        <div class="student-card">
          <span class="pill">Rollenübersicht</span>
          <h3><%= hero.statement %></h3>
          <p><%= hero.summary %></p>
          <div class="student-meta-grid">
            <div class="student-card">
              <small>⌀ Note</small>
              <strong><%= studentProfile.meta[1].value %></strong>
            </div>
            <div class="student-card">
              <small>Offene Aufgaben</small>
              <strong><%= focusStats[1].value %></strong>
            </div>
          </div>
        </div>
        <div class="student-card student-list-card">
          <h3>Aktuelle Hinweise</h3>
          <ul>
            <% focusStats.forEach(function(item){ %>
              <li><strong><%= item.label %></strong> — <%= item.value %> <small><%= item.detail %></small></li>
            <% }); %>
          </ul>
        </div>
      </div>
    </section>

    <section id="tasks" class="student-tab-content" aria-label="Aufgaben">
      <div class="student-card">
        <h3>Aufgaben</h3>
        <% tasks.forEach(function(task){ %>
          <div class="student-accordion">
            <div class="student-accordion-title">
              <span><%= task.title %> · <%= task.subject %></span>
              <span class="pill"><%= task.status %></span>
            </div>
            <div class="student-accordion-content">
              <p>Fällig: <%= task.due %></p>
              <p><%= task.description %></p>
              <% if (task.attachments.length) { %>
                <div class="file-list">Anhänge: <%= task.attachments.join(', ') %></div>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    </section>

    <section id="returns" class="student-tab-content" aria-label="Rückgaben">
      <div class="student-card">
        <h3>Rückgaben</h3>
        <% returns.forEach(function(ret){ %>
          <p><strong><%= ret.title %></strong> (<%= ret.subject %>) — Note <%= ret.grade %><br>
            <small><%= ret.feedback %></small>
          </p>
        <% }); %>
      </div>
    </section>

    <section id="grades" class="student-tab-content" aria-label="Noten">
      <div class="student-card">
        <div class="grades-header" style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
          <h3>Noten</h3>
          <div class="button-row">
            <a class="btn btn-secondary" href="/student/grades.csv">CSV Export</a>
            <a class="btn btn-secondary" href="/student/grades.pdf">PDF Export</a>
          </div>
        </div>
        <form id="grade-filter" class="filter-grid" aria-label="Noten filtern">
          <label>Fach
            <select name="subject" id="filter-subject">
              <option value="">Alle</option>
              <% subjects.forEach(function(sub){ %>
                <option value="<%= sub %>"><%= sub %></option>
              <% }) %>
            </select>
          </label>
          <label>Von
            <input type="date" name="startDate" id="filter-start">
          </label>
          <label>Bis
            <input type="date" name="endDate" id="filter-end">
          </label>
          <label>Sortierung
            <select name="sort" id="filter-sort">
              <option value="date">Datum (neueste zuerst)</option>
              <option value="value">Beste Note zuerst</option>
            </select>
          </label>
        </form>

        <div class="info-grid" id="grade-insights">
          <div class="stat-tile">
            <h4>Gesamtdurchschnitt</h4>
            <strong id="avg-overall">–</strong>
          </div>
          <div class="stat-tile">
            <h4>Trend</h4>
            <div id="avg-trend" class="badge-inline">–</div>
          </div>
          <div class="stat-tile">
            <h4>Letzte Aktualisierung</h4>
            <small id="avg-updated">–</small>
          </div>
        </div>

        <div id="grade-list" aria-live="polite" style="margin-top:10px;"></div>
      </div>

      <div class="student-card">
        <h3>Klassenvergleich</h3>
        <div id="class-average" class="chart-row"></div>
      </div>

      <div class="student-card">
        <h3>Benachrichtigungen</h3>
        <div id="notification-list" class="notifications"></div>
      </div>
    </section>

    <section id="materials" class="student-tab-content" aria-label="Materialien">
      <div class="student-card">
        <h3>Materialien</h3>
        <% materials.forEach(function(item){ %>
          <p><strong><%= item.title %></strong> (<%= item.subject %>) — <%= item.fileName %></p>
        <% }); %>
        <div class="upload-box">Datei hochladen</div>
      </div>
    </section>

    <section id="messages" class="student-tab-content" aria-label="Nachrichten">
      <div class="student-card">
        <h3>Nachrichten</h3>
        <% messages.forEach(function(msg){ %>
          <p><strong><%= msg.title %></strong> — <%= msg.sender %><br><small><%= msg.excerpt %></small></p>
        <% }); %>
      </div>
    </section>
  </section>
</div>

<script>
  const initialData = <%- initialData || '{}' %>;

  document.querySelectorAll('.student-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      setActiveTab(tab.dataset.tab);
    });
  });

  document.querySelectorAll('[data-tab-target]').forEach(link => {
    link.addEventListener('click', (event) => {
      const target = link.getAttribute('data-tab-target');
      if (target) {
        event.preventDefault();
        setActiveTab(target);
        document.getElementById(target)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  function setActiveTab(name) {
    document.querySelectorAll('.student-tab').forEach(t => t.classList.toggle('is-active', t.dataset.tab === name));
    document.querySelectorAll('.student-tab-content').forEach(c => c.classList.toggle('is-active', c.id === name));
    document.querySelectorAll('[data-tab-target]').forEach(link => {
      const isActive = link.getAttribute('data-tab-target') === name;
      link.classList.toggle('is-active', isActive);
    });
  }

  document.querySelectorAll('.student-accordion').forEach(acc => {
    acc.addEventListener('click', () => {
      const content = acc.querySelector('.student-accordion-content');
      if (!content) return;
      content.style.display = content.style.display === 'block' ? 'none' : 'block';
    });
  });

  const state = {
    grades: (initialData.grades || []).map(normalizeGrade),
    averages: initialData.averages || { subjects: [], overall: null },
    classAverages: initialData.classAverages || [],
    notifications: initialData.notifications || [],
    trend: initialData.trend || { direction: 'steady', change: 0 }
  };

  function normalizeGrade(g) {
    return { ...g, value: Number(g.value), weight: Number(g.weight || 1) };
  }

  function gradeColor(value) {
    if (value <= 1.5) return 'success';
    if (value <= 2.5) return 'warning';
    return 'danger';
  }

  function computeAveragesClient(grades) {
    const subjectMap = new Map();
    grades.forEach((g) => {
      const bucket = subjectMap.get(g.subject) || { weightedSum: 0, weightTotal: 0 };
      bucket.weightedSum += g.value * (g.weight || 1);
      bucket.weightTotal += (g.weight || 1);
      subjectMap.set(g.subject, bucket);
    });

    const subjects = [...subjectMap.entries()].map(([subject, data]) => ({
      subject,
      average: Number((data.weightedSum / data.weightTotal).toFixed(2))
    }));

    const total = grades.reduce((acc, g) => {
      acc.weightedSum += g.value * (g.weight || 1);
      acc.weightTotal += (g.weight || 1);
      return acc;
    }, { weightedSum: 0, weightTotal: 0 });
    return { subjects, overall: total.weightTotal ? Number((total.weightedSum / total.weightTotal).toFixed(2)) : null };
  }

  function renderGrades() {
    const container = document.getElementById('grade-list');
    if (!container) return;
    if (!state.grades.length) {
      container.innerHTML = '<p class="empty-state">Keine Noten vorhanden.</p>';
      return;
    }
    const items = state.grades.map((g) => `
      <div class="grade-row">
        <div>
          <div><strong>${g.subject}</strong> · <small>${new Date(g.graded_at).toLocaleDateString()}</small></div>
          <small>${g.teacher || 'Lehrkraft unbekannt'}</small>
          ${g.comment ? `<div class="nav-note">${g.comment}</div>` : ''}
        </div>
        <div class="grade-value">${g.value.toFixed(2)}</div>
        <div><span class="grade-pill ${gradeColor(g.value)}">Gewichtung ${(g.weight || 1)}</span></div>
        <div style="text-align:right;"><span class="grade-pill">${g.subject}</span></div>
      </div>
    `);
    container.innerHTML = items.join('');
  }

  function renderAverages() {
    document.getElementById('avg-overall').textContent = state.averages.overall ?? '–';
    const trend = state.trend || { direction: 'steady', change: 0 };
    const trendEl = document.getElementById('avg-trend');
    if (trendEl) {
      const icon = trend.direction === 'improving' ? '⬆︎' : trend.direction === 'declining' ? '⬇︎' : '→';
      trendEl.textContent = `${icon} ${trend.change}`;
    }
    const updatedEl = document.getElementById('avg-updated');
    if (updatedEl && state.grades.length) {
      const latest = [...state.grades].sort((a, b) => new Date(b.graded_at) - new Date(a.graded_at))[0];
      updatedEl.textContent = new Date(latest.graded_at).toLocaleString();
    }
  }

  function renderClassAverage() {
    const container = document.getElementById('class-average');
    if (!container) return;
    if (!state.classAverages.length) {
      container.innerHTML = '<p class="empty-state">Keine Vergleichsdaten vorhanden.</p>';
      return;
    }
    const highest = Math.max(...state.classAverages.map((c) => c.average || 0), 1);
    container.innerHTML = state.classAverages.map((c) => {
      const width = Math.min(100, Math.round((c.average / highest) * 100));
      return `<div class="chart-bar"><div style="width:120px;font-weight:600;">${c.subject}</div><div class="bar"><span style="width:${width}%;"></span></div><small>${c.average?.toFixed(2) ?? '–'}</small></div>`;
    }).join('');
  }

  function renderNotifications() {
    const container = document.getElementById('notification-list');
    if (!container) return;
    if (!state.notifications.length) {
      container.innerHTML = '<p class="empty-state">Keine neuen Benachrichtigungen.</p>';
      return;
    }
    container.innerHTML = state.notifications.map((n) => `
      <div class="notification ${n.read_at ? '' : 'unread'}">
        <strong>${n.type === 'average' ? 'Durchschnitt' : 'Neue Note'}</strong>
        <p style="margin:4px 0;">${n.message}</p>
        <small>${new Date(n.created_at).toLocaleString()}</small>
        ${n.read_at ? '' : `<button class="btn btn-secondary" data-note-id="${n.id}">Als gelesen markieren</button>`}
      </div>
    `).join('');

    container.querySelectorAll('button[data-note-id]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-note-id');
        await fetch(`/student/notifications/${id}/read`, { method: 'POST' });
        state.notifications = state.notifications.map((n) => n.id == id ? { ...n, read_at: new Date().toISOString() } : n);
        renderNotifications();
      });
    });
  }

  async function refreshGrades(skipRequest = false) {
    const form = document.getElementById('grade-filter');
    const params = new URLSearchParams(new FormData(form)).toString();
    if (!skipRequest) {
      const response = await fetch(`/student/grades?${params}`);
      const data = await response.json();
      state.grades = (data.grades || []).map(normalizeGrade);
      state.averages = computeAveragesClient(state.grades);
    }
    renderGrades();
    renderAverages();
  }

  async function loadClassComparison() {
    const response = await fetch('/student/class-averages');
    const data = await response.json();
    state.classAverages = data.subjects || [];
    renderClassAverage();
  }

  async function loadNotificationsFromServer() {
    const response = await fetch('/student/notifications');
    const data = await response.json();
    state.notifications = data.notifications || [];
    renderNotifications();
  }

  document.getElementById('grade-filter')?.addEventListener('change', () => refreshGrades());

  // Initial render from server data
  renderGrades();
  renderAverages();
  renderClassAverage();
  renderNotifications();

  // Fetch the freshest data in background
  refreshGrades();
  loadClassComparison();
  loadNotificationsFromServer();
</script>
<% } }; %>
<%- include('layout', page) %>
