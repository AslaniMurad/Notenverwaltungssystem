<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <title>Schüler-Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    :root {
      --bg: #020617;
      --panel: rgba(8, 12, 22, 0.95);
      --panel-soft: rgba(10, 15, 27, 0.8);
      --text: #f8fafc;
      --muted: #94a3b8;
      --border: rgba(148, 163, 184, 0.25);
      --accent: #38bdf8;
      --radius: 26px;
      --font: "Space Grotesk", "Inter", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      background: radial-gradient(circle at 5% 0, rgba(56, 189, 248, 0.25), transparent 55%),
        radial-gradient(circle at 85% 15%, rgba(129, 140, 248, 0.25), transparent 45%),
        linear-gradient(120deg, #00040f, #020617 60%, #000);
      font-family: var(--font);
      color: var(--text);
      padding: 42px 24px 64px;
      display: flex;
      justify-content: center;
    }

    main {
      width: 100%;
      max-width: 1280px;
      display: grid;
      grid-template-columns: minmax(0, 2.7fr) minmax(320px, 1fr);
      gap: 32px;
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 32px;
      position: relative;
      overflow: hidden;
    }

    .panel::after {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 90% 15%, rgba(56, 189, 248, 0.15), transparent 35%);
      pointer-events: none;
    }

    .panel > * { position: relative; z-index: 2; }

    .left, .right { display: flex; flex-direction: column; gap: 32px; }

    header.hero { display: flex; flex-direction: column; gap: 18px; margin-bottom: 18px; }
    .eyebrow { text-transform: uppercase; letter-spacing: 0.35em; font-size: 11px; color: var(--muted); }
    header.hero h1 { font-size: 40px; font-weight: 600; line-height: 1.2; }
    header.hero p { color: var(--muted); max-width: 620px; line-height: 1.5; }

    .badge-row { display: flex; flex-wrap: wrap; gap: 12px; }
    .badge { border-radius: 999px; border: 1px solid rgba(56, 189, 248, 0.45); color: #38bdf8; font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; padding: 6px 14px; background: rgba(8, 47, 73, 0.35); }

    .hero-meta { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 14px; margin-top: 10px; }
    .hero-meta article { border-radius: 18px; padding: 16px; border: 1px solid rgba(255, 255, 255, 0.08); background: rgba(2, 6, 23, 0.75); }
    .hero-meta span { font-size: 11px; letter-spacing: 0.15em; color: var(--muted); text-transform: uppercase; }
    .hero-meta strong { font-size: 20px; display: block; margin-top: 4px; }

    .focus-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin-bottom: 28px; }
    .focus-card { border-radius: 22px; border: 1px solid rgba(255,255,255,0.08); background: rgba(7,11,23,0.92); padding: 18px; }
    .focus-card span { font-size: 11px; letter-spacing: 0.2em; color: var(--muted); text-transform: uppercase; }
    .focus-card strong { font-size: 26px; display: block; margin-top: 10px; }
    .focus-card p { color: var(--muted); font-size: 13px; margin-top: 6px; }

    .board { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px; }
    .board-card { border-radius: 24px; border: 1px solid rgba(255,255,255,0.07); background: var(--panel-soft); padding: 22px; min-height: 180px; display: flex; flex-direction: column; justify-content: space-between; }
    .board-card h4 { font-size: 20px; margin-bottom: 6px; }
    .board-card small { font-size: 11px; letter-spacing: 0.18em; color: var(--muted); text-transform: uppercase; }
    .board-card p { color: var(--muted); margin-top: 10px; }

    .timeline { margin-top: 30px; display: flex; flex-direction: column; gap: 18px; }
    .timeline ul { list-style: none; display: flex; flex-direction: column; gap: 14px; }
    .timeline li { display: grid; grid-template-columns: auto 1fr auto; gap: 16px; align-items: center; padding: 18px; border-radius: 20px; background: rgba(4, 7, 20, 0.9); border: 1px solid rgba(255,255,255,0.05); }
    .badge-pill { width: 46px; height: 46px; border-radius: 16px; display: grid; place-items: center; border: 1px solid rgba(255,255,255,0.12); font-weight: 600; letter-spacing: 0.12em; }
    .timeline strong { font-size: 18px; }
    .timeline span.meta { display: block; color: var(--muted); font-size: 13px; margin-top: 4px; }

    .micro-grid { margin-top: 30px; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; }
    .micro-card { border-radius: 20px; border: 1px solid rgba(255,255,255,0.08); background: rgba(6, 9, 18, 0.92); padding: 18px; }
    .micro-card span { font-size: 11px; color: var(--muted); letter-spacing: 0.2em; text-transform: uppercase; }
    .micro-card strong { display: block; font-size: 18px; margin-top: 10px; }
    .micro-card p { color: var(--muted); font-size: 13px; margin-top: 6px; }

    .stack { display: flex; flex-direction: column; gap: 24px; }
    .stack-section { border-radius: var(--radius); border: 1px solid var(--border); padding: 26px; background: rgba(4, 7, 18, 0.85); }
    .stack-section h3 { font-size: 16px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-bottom: 18px; }

    .routine-list { display: flex; flex-direction: column; gap: 18px; }
    .routine-card { border-radius: 20px; border: 1px solid rgba(255,255,255,0.08); padding: 18px; background: rgba(8,11,20,0.9); }
    .routine-card strong { font-size: 17px; }
    .routine-card p { color: var(--muted); font-size: 13px; margin-top: 8px; }

    .goal-list { display: flex; flex-direction: column; gap: 16px; }
    .goal { border-radius: 18px; border: 1px solid rgba(255,255,255,0.08); padding: 16px; background: rgba(6,8,18,0.9); }
    .goal header { display: flex; justify-content: space-between; align-items: center; }
    .goal small { color: var(--muted); }

    .insight-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; }
    .insight { border-radius: 18px; border: 1px solid rgba(255,255,255,0.08); padding: 14px; background: rgba(8,12,23,0.95); font-size: 13px; color: var(--muted); line-height: 1.6; }
    .insight strong { display: block; font-size: 14px; color: var(--text); margin-bottom: 6px; }

    .actions { display: flex; flex-wrap: wrap; gap: 16px; align-items: center; margin-top: 20px; }
    a.back { color: var(--accent); text-decoration: none; font-weight: 500; }
    .logout-button { border: none; border-radius: 16px; padding: 12px 22px; background: linear-gradient(120deg, #38bdf8, #6366f1); color: white; font-weight: 600; cursor: pointer; }

    @media (max-width: 1100px) {
      main { grid-template-columns: 1fr; }
    }

    @media (max-width: 640px) {
      body { padding: 24px 14px 42px; }
      .panel, .stack-section { padding: 22px; }
    }
  </style>
</head>
<body>
  <main>
    <section class="left">
      <article class="panel">
        <header class="hero">
          <p class="eyebrow">Signalraum</p>
          <h1><%= hero.headline %> • <%= hero.statement %></h1>
          <p><%= hero.summary %></p>
          <div class="badge-row">
            <% hero.badges.forEach(tag => { %>
              <span class="badge"><%= tag %></span>
            <% }) %>
          </div>
          <div class="hero-meta">
            <% hero.meta.forEach(item => { %>
              <article>
                <span><%= item.label %></span>
                <strong><%= item.value %></strong>
              </article>
            <% }) %>
          </div>
        </header>

        <section class="focus-stats">
          <% focusStats.forEach(card => { %>
            <article class="focus-card">
              <span><%= card.label %></span>
              <strong><%= card.value %></strong>
              <p><%= card.detail %></p>
            </article>
          <% }) %>
        </section>

        <section class="board">
          <% studyPanels.forEach(card => { %>
            <article class="board-card">
              <div>
                <small><%= card.chip %></small>
                <h4><%= card.title %></h4>
              </div>
              <p><%= card.signal %></p>
            </article>
          <% }) %>
        </section>

        <section class="timeline">
          <p class="eyebrow">Test</p>
          <ul>
            <% timeline.forEach(item => { %>
              <li>
                <div class="badge-pill"><%= item.badge %></div>
                <div>
                  <strong><%= item.title %></strong>
                  <span class="meta"><%= item.detail %></span>
                </div>
                <div style="text-align:right; color: var(--muted); font-size: 13px;">
                  <span><%= item.date %></span>
                </div>
              </li>
            <% }) %>
          </ul>
        </section>

        <section class="micro-grid">
          <% routines.forEach(item => { %>
            <article class="micro-card">
              <span><%= item.emphasis %></span>
              <strong><%= item.title %></strong>
              <p><%= item.detail %></p>
            </article>
          <% }) %>
        </section>
      </article>
    </section>

    <section class="right">
      <article class="stack">
        <div class="stack-section">
          <h3>Test</h3>
          <div class="routine-list">
            <% routines.forEach(item => { %>
              <article class="routine-card">
                <strong><%= item.title %></strong>
                <p><%= item.detail %></p>
              </article>
            <% }) %>
          </div>
        </div>

        <div class="stack-section">
          <h3>Test</h3>
          <div class="goal-list">
            <% goals.forEach(goal => { %>
              <article class="goal">
                <header>
                  <strong><%= goal.title %></strong>
                  <span><%= goal.progress %></span>
                </header>
                <small><%= goal.due %></small>
              </article>
            <% }) %>
          </div>
        </div>

        <div class="stack-section">
          <h3>Test</h3>
          <div class="insight-grid">
            <% insights.forEach(insight => { %>
              <article class="insight">
                <strong><%= insight.title %></strong>
                <p><%= insight.detail %></p>
              </article>
            <% }) %>
          </div>
        </div>

        <div class="stack-section">
          <div class="actions">
            <a class="back" href="/">← Zurück</a>
            <form method="POST" action="/logout">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="logout-button" type="submit">Logout</button>
            </form>
          </div>
        </div>
      </article>
    </section>
  </main>
</body>
</html>