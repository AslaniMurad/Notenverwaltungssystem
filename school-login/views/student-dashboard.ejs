<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <title>Schüler-Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/app-shell.css">
  <style>
    :root {
      --blue: #124f9c;
      --blue-light: #e4efff;
      --bg: #f6f8fb;
      --card: #ffffff;
      --border: #d9e1ec;
      --radius: 12px;
      --shadow: 0 6px 16px rgba(0,0,0,0.06);
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      font-family: Inter, sans-serif;
      color: #1a1a1a;
    }

    header.dashboard-hero {
      background: linear-gradient(135deg, #124f9c, #1b6dd1);
      padding: 18px 20px;
      color: #fff;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-radius: 12px;
      box-shadow: var(--shadow);
      margin-bottom: 18px;
    }

    .tabs {
      display: flex;
      gap: 10px;
      background: #fff;
      padding: 14px 20px;
      border: 1px solid var(--border);
      border-radius: 12px;
      box-shadow: var(--shadow);
      position: sticky;
      top: 0;
      z-index: 10;
      margin-bottom: 16px;
    }

    .tab {
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid transparent;
      background: var(--blue-light);
      color: var(--blue);
      cursor: pointer;
      font-weight: 500;
    }

    .tab.active {
      background: var(--blue);
      color: #fff;
    }

    .student-main {
      display: grid;
      gap: 20px;
    }

    .tab-content { display: none; }
    .tab-content.active { display: block; }

    .card {
      background: #fff;
      padding: 18px 20px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
    }

    .accordion {
      border-bottom: 1px solid var(--border);
      padding: 12px 0;
      cursor: pointer;
    }

    .accordion-title {
      display: flex;
      justify-content: space-between;
      font-weight: 600;
      font-size: 15px;
    }

    .accordion-content {
      display: none;
      padding: 10px 0 4px;
      font-size: 14px;
      color: #333;
    }

    .pill {
      background: var(--blue-light);
      color: var(--blue);
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 500;
    }

    .upload-box {
      margin-top: 8px;
      padding: 10px;
      border-radius: var(--radius);
      border: 1px dashed var(--border);
      background: #fafafa;
      cursor: pointer;
      font-size: 13px;
    }

    .file-list {
      margin-top: 6px;
      font-size: 12px;
      color: #777;
    }
    .htl-small {
      width: 48px;
      height: 48px;
      object-fit: contain;
      border-radius: 8px;
      margin-right: 12px;
      vertical-align: middle;
      background: white;
      padding: 4px;
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .header-right {
      text-align: right;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 6px;
    }

    .logout-form { margin-top: 6px; }
    .logout-form .logout-button {
      padding: 8px 14px;
      border-radius: 8px;
      font-weight: 700;
      border: none;
      cursor: pointer;
      background: rgba(255,255,255,0.12);
      color: #fff;
      transition: all 0.15s ease;
    }
    .logout-form .logout-button:hover { background: rgba(255,255,255,0.18); transform: translateY(-2px); }

    .student-meta {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 12px;
      margin-top: 12px;
    }

    .student-meta .card small { color: #4b5563; }
    .student-meta .card strong { font-size: 18px; }

    .grid-two {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 12px;
    }

    .nav-note {
      font-size: 12px;
      color: #6b7280;
      margin: 8px 0 0;
    }
  </style>
</head>

<body class="app-shell-body">
  <div class="app-shell app-shell-wide">
    <aside class="app-sidebar" aria-label="Schülernavigation">
      <div class="sidebar-brand">
        <div>
          <div class="sidebar-title">Schüler-Dashboard</div>
          <div class="sidebar-meta"><%= studentProfile.name %> · <%= studentProfile.class %></div>
        </div>
        <span class="sidebar-badge">Aktiv</span>
      </div>

      <div class="app-nav">
        <div class="nav-section">
          <div class="nav-section-title">Bereiche</div>
          <a class="is-active" href="#overview" data-tab-target="overview">Übersicht</a>
          <a href="#tasks" data-tab-target="tasks">Aufgaben</a>
          <a href="#returns" data-tab-target="returns">Rückgaben</a>
          <a href="#grades" data-tab-target="grades">Noten</a>
          <a href="#materials" data-tab-target="materials">Materialien</a>
          <button class="nav-trigger" data-target="#messages-panel" aria-expanded="false">Kommunikation <span class="chevron">›</span></button>
          <div class="nav-panel" id="messages-panel">
            <a href="#messages" data-tab-target="messages">Nachrichten</a>
          </div>
          <form class="logout-form" method="POST" action="/logout">
            <% if (typeof csrfToken !== 'undefined') { %>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <% } %>
            <button class="app-nav-link" type="submit">Logout</button>
          </form>
          <p class="nav-note">Die Leiste bleibt beim Navigieren sichtbar.</p>
        </div>
      </div>
    </aside>

    <section class="app-main">
      <header class="dashboard-hero">
        <div class="header-left">
          <img src="/images/htl-waidhofen.png" alt="HTL Waidhofen" class="htl-small" onerror="this.style.display='none'">
          <div>
            <h1><%= hero.headline %></h1>
            <small><%= hero.summary %></small>
          </div>
        </div>
        <div class="header-right">
          <div>
            <strong><%= studentProfile.name %></strong><br>
            <small>Klasse <%= studentProfile.class %></small><br>
            <small><%= email %></small>
          </div>
          <form class="logout-form" method="POST" action="/logout">
            <% if (typeof csrfToken !== 'undefined') { %>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <% } %>
            <button class="logout-button" type="submit">Logout</button>
          </form>
        </div>
      </header>

      <div class="tabs">
        <div class="tab active" data-tab="overview">Übersicht</div>
        <div class="tab" data-tab="tasks">Aufgaben</div>
        <div class="tab" data-tab="returns">Rückgaben</div>
        <div class="tab" data-tab="grades">Noten</div>
        <div class="tab" data-tab="materials">Materialien</div>
        <div class="tab" data-tab="messages">Nachrichten</div>
      </div>

      <main class="student-main">
        <section id="overview" class="tab-content active">
          <div class="grid-two">
            <div class="card">
              <span class="pill">Rollenübersicht</span>
              <h3><%= hero.statement %></h3>
              <p><%= hero.summary %></p>
              <div class="student-meta">
                <div class="card">
                  <small>⌀ Note</small>
                  <strong>2,1</strong>
                </div>
                <div class="card">
                  <small>Offene Aufgaben</small>
                  <strong><%= focusStats[1].value %></strong>
                </div>
              </div>
            </div>
            <div class="card">
              <h3>Aktuelle Hinweise</h3>
              <ul>
                <% focusStats.forEach(function(item){ %>
                  <li><strong><%= item.label %></strong> — <%= item.value %> <small><%= item.detail %></small></li>
                <% }); %>
              </ul>
            </div>
          </div>
        </section>

        <section id="tasks" class="tab-content">
          <div class="card">
            <h3>Aufgaben</h3>
            <% tasks.forEach(function(task){ %>
              <div class="accordion">
                <div class="accordion-title">
                  <span><%= task.title %> · <%= task.subject %></span>
                  <span class="pill"><%= task.status %></span>
                </div>
                <div class="accordion-content">
                  <p>Fällig: <%= task.due %></p>
                  <p><%= task.description %></p>
                  <% if (task.attachments.length) { %>
                    <div class="file-list">Anhänge: <%= task.attachments.join(', ') %></div>
                  <% } %>
                </div>
              </div>
            <% }); %>
          </div>
        </section>

        <section id="returns" class="tab-content">
          <div class="card">
            <h3>Rückgaben</h3>
            <% returns.forEach(function(ret){ %>
              <p><strong><%= ret.title %></strong> (<%= ret.subject %>) — Note <%= ret.grade %><br>
                <small><%= ret.feedback %></small>
              </p>
            <% }); %>
          </div>
        </section>

        <section id="grades" class="tab-content">
          <div class="card">
            <h3>Noten</h3>
            <ul>
              <% grades.forEach(function(grade){ %>
                <li><%= grade.subject %> — <strong><%= grade.grade %></strong> (<%= grade.weight %>)</li>
              <% }); %>
            </ul>
          </div>
        </section>

        <section id="materials" class="tab-content">
          <div class="card">
            <h3>Materialien</h3>
            <% materials.forEach(function(item){ %>
              <p><strong><%= item.title %></strong> (<%= item.subject %>) — <%= item.fileName %></p>
            <% }); %>
            <div class="upload-box">Datei hochladen</div>
          </div>
        </section>

        <section id="messages" class="tab-content">
          <div class="card">
            <h3>Nachrichten</h3>
            <% messages.forEach(function(msg){ %>
              <p><strong><%= msg.title %></strong> — <%= msg.sender %><br><small><%= msg.excerpt %></small></p>
            <% }); %>
          </div>
        </section>
      </main>
    </section>
  </div>
  <script src="/js/app.js"></script>
  <script>
    document.querySelectorAll(".tab").forEach(tab => {
      tab.addEventListener("click", () => {
        setActiveTab(tab.dataset.tab);
      });
    });

    document.querySelectorAll('[data-tab-target]').forEach(link => {
      link.addEventListener('click', (event) => {
        const target = link.getAttribute('data-tab-target');
        if (target) {
          event.preventDefault();
          setActiveTab(target);
          document.getElementById(target)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    function setActiveTab(name) {
      document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === name));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.toggle('active', c.id === name));
      document.querySelectorAll('[data-tab-target]').forEach(link => {
        const isActive = link.getAttribute('data-tab-target') === name;
        link.classList.toggle('is-active', isActive);
      });
    }

    document.querySelectorAll('.accordion').forEach(acc => {
      acc.addEventListener('click', () => {
        const content = acc.querySelector('.accordion-content');
        content.style.display = content.style.display === 'block' ? 'none' : 'block';
      });
    });
  </script>
</body>
</html>
