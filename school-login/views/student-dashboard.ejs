<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <title>Schüler-Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/app-shell.css">
  <style>
    :root {
      --blue: #124f9c;
      --blue-light: #e4efff;
      --bg: #f6f8fb;
      --card: #ffffff;
      --border: #d9e1ec;
      --radius: 12px;
      --shadow: 0 6px 16px rgba(0,0,0,0.06);
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      font-family: Inter, sans-serif;
      color: #1a1a1a;
    }

    header.dashboard-hero {
      background: linear-gradient(135deg, #124f9c, #1b6dd1);
      padding: 18px 20px;
      color: #fff;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-radius: 12px;
      box-shadow: var(--shadow);
      margin-bottom: 18px;
    }

    .tabs {
      display: flex;
      gap: 10px;
      background: #fff;
      padding: 14px 20px;
      border: 1px solid var(--border);
      border-radius: 12px;
      box-shadow: var(--shadow);
      position: sticky;
      top: 0;
      z-index: 10;
      margin-bottom: 16px;
    }

    .tab {
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid transparent;
      background: var(--blue-light);
      color: var(--blue);
      cursor: pointer;
      font-weight: 500;
      transition: all 0.2s ease;
    }

    .tab.active {
      background: var(--blue);
      color: #fff;
    }

    .student-main {
      display: grid;
      gap: 20px;
    }

    .tab-content { display: none; }
    .tab-content.active { display: block; }

    .card {
      background: #fff;
      padding: 18px 20px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
    }

    .pill {
      background: var(--blue-light);
      color: var(--blue);
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 500;
    }

    .upload-box {
      margin-top: 8px;
      padding: 10px;
      border-radius: var(--radius);
      border: 1px dashed var(--border);
      background: #fafafa;
      cursor: pointer;
      font-size: 13px;
    }

    .file-list {
      margin-top: 6px;
      font-size: 12px;
      color: #777;
    }
    .htl-small {
      width: 48px;
      height: 48px;
      object-fit: contain;
      border-radius: 8px;
      margin-right: 12px;
      vertical-align: middle;
      background: white;
      padding: 4px;
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .header-right {
      text-align: right;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 6px;
    }

    .logout-form { margin-top: 6px; }
    .logout-form .logout-button {
      padding: 8px 14px;
      border-radius: 8px;
      font-weight: 700;
      border: none;
      cursor: pointer;
      background: rgba(255,255,255,0.12);
      color: #fff;
      transition: all 0.15s ease;
    }
    .logout-form .logout-button:hover { background: rgba(255,255,255,0.18); transform: translateY(-2px); }

    .student-meta {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 12px;
      margin-top: 12px;
    }

    .student-meta .card small { color: #4b5563; }
    .student-meta .card strong { font-size: 18px; }

    .grid-two {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 12px;
    }

    .card h3 { display: flex; align-items: center; justify-content: space-between; gap: 8px; flex-wrap: wrap; }
    .card h3 small { font-weight: 500; color: #6b7280; }

    .nav-note {
      font-size: 12px;
      color: #6b7280;
      margin: 8px 0 0;
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
      margin-top: 12px;
    }

    .stat-card {
      background: #f8fafc;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 12px;
    }

    .stat-card small { color: #6b7280; }
    .stat-card strong { font-size: 20px; }

    .filter-form {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 10px;
      margin: 12px 0 10px;
    }

    .filter-form label {
      font-size: 12px;
      color: #4b5563;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .link-button { background: none; border: none; color: var(--blue); cursor: pointer; font-weight: 600; padding: 0; }
    .link-button:disabled { color: #9ca3af; cursor: not-allowed; }

    .filter-form input,
    .filter-form select,
    .filter-form button {
      padding: 8px 10px;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 14px;
    }

    .filter-form button {
      background: var(--blue);
      color: white;
      border-color: var(--blue);
      cursor: pointer;
      font-weight: 600;
    }

    .export-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin: 6px 0 12px;
    }

    .export-actions a {
      padding: 8px 10px;
      border-radius: 8px;
      border: 1px solid var(--border);
      text-decoration: none;
      color: var(--blue);
      background: var(--blue-light);
      font-weight: 600;
      transition: all 0.2s ease;
    }

    .text-muted { color: #6b7280; font-size: 13px; }

    .trend-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 12px;
      border-radius: 10px;
      font-weight: 600;
      border: 1px solid var(--border);
    }

    .trend--improving { color: #065f46; background: #ecfdf3; border-color: #bbf7d0; }
    .trend--declining { color: #92400e; background: #fff7ed; border-color: #fed7aa; }
    .trend--stable { color: #1f2937; background: #f3f4f6; border-color: #e5e7eb; }

    .assignment-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 12px; }
    .assignment-card { border: 1px solid var(--border); border-radius: var(--radius); padding: 14px; background: #fff; box-shadow: var(--shadow); cursor: pointer; transition: transform 0.18s ease, box-shadow 0.18s ease; }
    .assignment-card:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(0,0,0,0.08); }
    .assignment-meta { display: flex; justify-content: space-between; align-items: center; gap: 8px; flex-wrap: wrap; }
    .status-pill { border-radius: 999px; padding: 6px 10px; font-size: 12px; font-weight: 700; text-transform: uppercase; }
    .status-open { background: #f3f4f6; color: #1f2937; }
    .status-overdue { background: #fef2f2; color: #991b1b; }
    .status-submitted { background: #ecfdf3; color: #065f46; }
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .attachment-list { display: flex; flex-direction: column; gap: 8px; margin: 8px 0; }
    .attachment-item { display: flex; justify-content: space-between; align-items: center; gap: 8px; padding: 8px 10px; border: 1px solid var(--border); border-radius: 10px; background: #f9fafb; }
    .attachment-actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .badge { background: #e0f2fe; color: #0ea5e9; padding: 4px 8px; border-radius: 999px; font-weight: 600; font-size: 12px; }
    .chip { padding: 6px 10px; border-radius: 10px; background: #f8fafc; border: 1px solid var(--border); font-size: 13px; }
    .section-subtitle { color: #4b5563; font-size: 13px; margin: 4px 0 12px; }

    .grade-row { padding: 10px 0; border-bottom: 1px dashed var(--border); }
    .grade-row:last-child { border-bottom: none; }
    .grade-row strong { display: inline-flex; align-items: center; gap: 6px; }
    .grade-breakdown { margin-top: 4px; font-size: 13px; color: #4b5563; }

    .modal { position: fixed; inset: 0; display: none; align-items: center; justify-content: center; z-index: 40; }
    .modal.is-open { display: flex; }
    .modal-backdrop { position: absolute; inset: 0; background: rgba(17,24,39,0.45); }
    .modal-body { position: relative; background: #fff; padding: 18px; border-radius: 14px; width: min(680px, 90%); max-height: 90vh; overflow-y: auto; box-shadow: 0 20px 40px rgba(0,0,0,0.18); animation: slideUp 0.2s ease; }
    .modal-close { position: absolute; right: 12px; top: 12px; background: none; border: none; font-size: 18px; cursor: pointer; }
    @keyframes slideUp { from { transform: translateY(12px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    @media (max-width: 900px) {
      .dashboard-hero { flex-direction: column; align-items: flex-start; gap: 10px; }
      .tabs { position: sticky; top: 0; z-index: 20; overflow-x: auto; }
      .export-actions { justify-content: flex-start; }
    }

    @media (max-width: 640px) {
      .app-shell { grid-template-columns: 1fr; }
      .app-sidebar { position: static; width: auto; }
      .student-meta { grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); }
      .assignment-meta { flex-direction: column; align-items: flex-start; }
      .tab { flex: 1; text-align: center; }
    }
  </style>
</head>

<body class="app-shell-body">
  <div class="app-shell app-shell-wide">
    <aside class="app-sidebar" aria-label="Schülernavigation">
      <div class="sidebar-brand">
        <div>
          <div class="sidebar-title">Schüler-Dashboard</div>
          <div class="sidebar-meta"><%= studentProfile.name %> · <%= studentProfile.class %></div>
        </div>
        <span class="sidebar-badge">Aktiv</span>
      </div>

      <div class="app-nav">
        <div class="nav-section">
          <div class="nav-section-title">Bereiche</div>
          <a class="is-active" href="#overview" data-tab-target="overview">Übersicht</a>
          <a href="#tasks" data-tab-target="tasks">Aufgaben</a>
          <a href="#returns" data-tab-target="returns">Rückgaben</a>
          <a href="#grades" data-tab-target="grades">Noten</a>
          <a href="#materials" data-tab-target="materials">Materialien</a>
          <button class="nav-trigger" data-target="#messages-panel" aria-expanded="false">Kommunikation <span class="chevron">›</span></button>
          <div class="nav-panel" id="messages-panel">
            <a href="#messages" data-tab-target="messages">Nachrichten</a>
          </div>
          <form class="logout-form" method="POST" action="/logout">
            <% if (typeof csrfToken !== 'undefined') { %>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <% } %>
            <button class="app-nav-link" type="submit">Logout</button>
          </form>
          <p class="nav-note">Die Leiste bleibt beim Navigieren sichtbar.</p>
        </div>
      </div>
    </aside>

    <section class="app-main">
      <header class="dashboard-hero">
        <div class="header-left">
          <img src="/images/htl-waidhofen.png" alt="HTL Waidhofen" class="htl-small" onerror="this.style.display='none'">
          <div>
            <h1><%= hero.headline %></h1>
            <small><%= hero.summary %></small>
          </div>
        </div>
        <div class="header-right">
          <div>
            <strong><%= studentProfile.name %></strong><br>
            <small>Klasse <%= studentProfile.class %></small><br>
            <small><%= email %></small>
          </div>
          <form class="logout-form" method="POST" action="/logout">
            <% if (typeof csrfToken !== 'undefined') { %>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <% } %>
            <button class="logout-button" type="submit">Logout</button>
          </form>
        </div>
      </header>

      <div class="tabs">
        <div class="tab active" data-tab="overview">Übersicht</div>
        <div class="tab" data-tab="tasks">Aufgaben</div>
        <div class="tab" data-tab="returns">Rückgaben</div>
        <div class="tab" data-tab="grades">Noten</div>
        <div class="tab" data-tab="materials">Materialien</div>
        <div class="tab" data-tab="messages">Nachrichten</div>
      </div>

      <main class="student-main">
        <section id="overview" class="tab-content active">
          <div class="grid-two">
            <div class="card">
              <span class="pill">Rollenübersicht</span>
              <h3><%= hero.statement %></h3>
              <p><%= hero.summary %></p>
              <div class="stat-grid">
                <div class="stat-card">
                  <small>⌀ Note</small>
                  <strong><%= overallAverage ? overallAverage.toFixed(2) : '–' %></strong>
                </div>
                <div class="stat-card">
                  <small>Fächer</small>
                  <strong><%= subjects.length || '–' %></strong>
                </div>
                <div class="stat-card">
                  <small>Letzte Änderung</small>
                  <strong><%= grades[0] ? new Date(grades[0].grade_date).toLocaleDateString('de-DE') : '–' %></strong>
                </div>
              </div>
              <div class="trend-chip trend--<%= trend.direction %>">
                <span><strong>Trend:</strong> <%= trend.direction === 'improving' ? 'Verbesserung' : trend.direction === 'declining' ? 'Rückgang' : 'Stabil' %></span>
                <small class="text-muted"><%= trend.message %></small>
              </div>
            </div>
            <div class="card">
              <h3>Neueste Noten</h3>
              <% if (!latestGrades.length) { %>
                <p class="text-muted">Noch keine Noten vorhanden.</p>
              <% } else { %>
                <ul>
                  <% latestGrades.forEach(function(grade){ %>
                    <li class="grade-row" data-grade-row>
                      <strong><button class="link-button" type="button" data-filter-subject="<%= grade.subject %>"><%= grade.subject %></button></strong> — <%= grade.grade_value %>
                      <small class="text-muted">(<%= grade.weight || 1 %>x · <%= new Date(grade.grade_date).toLocaleDateString('de-DE') %>)</small>
                      <div class="grade-breakdown">
                        <% if (grade.teacher_comment) { %><small class="text-muted">Kommentar: <%= grade.teacher_comment %></small><br><% } %>
                        <small class="text-muted">Angelegt am <%= new Date(grade.created_at || grade.grade_date).toLocaleDateString('de-DE') %></small>
                      </div>
                    </li>
                  <% }); %>
                </ul>
              <% } %>
            </div>
          </div>
        </section>

        <section id="tasks" class="tab-content">
          <div class="card">
            <h3>Aufgaben <small>Klicke für Details &amp; Dateien</small></h3>
            <% if (!tasks.length) { %>
              <p class="text-muted">Keine Aufgaben vorhanden. Dein Lehrer kann hier Aufgaben freigeben.</p>
            <% } else { %>
              <div class="assignment-grid">
                <% tasks.forEach(function(task){ %>
                  <article class="assignment-card" data-open-assignment="<%= task.id %>">
                    <div class="assignment-meta">
                      <div>
                        <div class="badge"><%= task.subject || studentProfile.class %></div>
                        <h4><%= task.title %></h4>
                      </div>
                      <span class="status-pill status-<%= task.status %>"><%= task.status === 'overdue' ? 'Überfällig' : task.status === 'submitted' ? 'Abgegeben' : 'Offen' %></span>
                    </div>
                    <p class="text-muted line-clamp-2"><%= task.description || 'Keine Beschreibung hinterlegt.' %></p>
                    <div class="assignment-meta">
                      <span class="chip">Fällig: <%= task.due_date ? new Date(task.due_date).toLocaleDateString('de-DE') : 'Kein Datum' %></span>
                      <button type="button" class="link-button" data-open-assignment="<%= task.id %>">Details öffnen</button>
                    </div>
                  </article>
                <% }); %>
              </div>
            <% } %>
          </div>
        </section>

        <section id="returns" class="tab-content">
          <div class="card">
            <h3>Rückgaben</h3>
            <% returns.forEach(function(ret){ %>
              <p><strong><%= ret.title %></strong> (<%= ret.subject %>) — Note <%= ret.grade %><br>
                <small><%= ret.feedback %></small>
              </p>
            <% }); %>
          </div>
        </section>

        <section id="grades" class="tab-content">
          <% const exportParams = []; %>
          <% if (filters.subject) { exportParams.push(`subject=${encodeURIComponent(filters.subject)}`); } %>
          <% if (filters.startDate) { exportParams.push(`startDate=${encodeURIComponent(filters.startDate)}`); } %>
          <% if (filters.endDate) { exportParams.push(`endDate=${encodeURIComponent(filters.endDate)}`); } %>
          <% if (filters.sortBy) { exportParams.push(`sortBy=${encodeURIComponent(filters.sortBy)}`); } %>
          <% if (filters.order) { exportParams.push(`order=${encodeURIComponent(filters.order)}`); } %>
          <% const exportQuery = exportParams.join('&'); %>
          <div class="card">
            <h3>Noten</h3>
            <form class="filter-form" method="GET" action="/student#grades">
              <label>
                Fach
                <select name="subject">
                  <option value="">Alle</option>
                  <% subjects.forEach(function(subject){ %>
                    <option value="<%= subject %>" <%= filters.subject === subject ? 'selected' : '' %>><%= subject %></option>
                  <% }); %>
                </select>
              </label>
              <label>
                Von
                <input type="date" name="startDate" value="<%= filters.startDate || '' %>">
              </label>
              <label>
                Bis
                <input type="date" name="endDate" value="<%= filters.endDate || '' %>">
              </label>
              <label>
                Sortieren nach
                <select name="sortBy">
                  <option value="grade_date" <%= filters.sortBy === 'grade_date' ? 'selected' : '' %>>Datum</option>
                  <option value="grade_value" <%= filters.sortBy === 'grade_value' ? 'selected' : '' %>>Note</option>
                </select>
              </label>
              <label>
                Reihenfolge
                <select name="order">
                  <option value="DESC" <%= filters.order.toUpperCase() === 'DESC' ? 'selected' : '' %>>Neueste zuerst</option>
                  <option value="ASC" <%= filters.order.toUpperCase() === 'ASC' ? 'selected' : '' %>>Älteste zuerst</option>
                </select>
              </label>
              <div></div>
              <button type="submit">Filtern</button>
            </form>

            <div class="export-actions">
              <a href="/student/export/csv<%= exportQuery ? '?' + exportQuery : '' %>">CSV Export</a>
              <a href="/student/export/pdf<%= exportQuery ? '?' + exportQuery : '' %>">PDF Export</a>
            </div>

            <% if (!grades.length) { %>
              <p class="text-muted">Keine Noten für die aktuellen Filter gefunden.</p>
            <% } else { %>
              <ul>
                <% grades.forEach(function(grade){ %>
                  <li class="grade-row" data-grade-row>
                    <strong><button class="link-button" type="button" data-filter-subject="<%= grade.subject %>"><%= grade.subject %></button></strong> — Note <%= grade.grade_value %>
                    <small class="text-muted">(<%= grade.weight || 1 %>x · <%= new Date(grade.grade_date).toLocaleDateString('de-DE') %>)</small>
                    <div class="grade-breakdown">
                      <% if (grade.teacher_comment) { %><small class="text-muted">Kommentar: <%= grade.teacher_comment %></small><br><% } %>
                      <small class="text-muted">Eingetragen: <%= new Date(grade.created_at || grade.grade_date).toLocaleString('de-DE') %></small>
                    </div>
                  </li>
                <% }); %>
              </ul>
            <% } %>
          </div>
          <div class="card">
            <h3>Durchschnitt & Vergleich</h3>
            <div class="stat-grid">
              <div class="stat-card">
                <small>Dein Schnitt</small>
                <strong><%= overallAverage ? overallAverage.toFixed(2) : '–' %></strong>
              </div>
              <div class="stat-card">
                <small>Klassen-Schnitt</small>
                <strong><%= classComparison.overall ? classComparison.overall.toFixed(2) : '–' %></strong>
              </div>
              <div class="stat-card">
                <small>Fächer</small>
                <strong><%= subjects.length || '–' %></strong>
              </div>
            </div>
            <h4>Fächer-Schnitt</h4>
            <% if (!subjectAverages.length) { %>
              <p class="text-muted">Noch keine Durchschnittswerte verfügbar.</p>
            <% } else { %>
              <ul>
                <% subjectAverages.forEach(function(avg){ %>
                  <% const classAvg = (classComparison.subjects || []).find(function(c){ return c.subject === avg.subject; }); %>
                  <li>
                    <strong><button class="link-button" type="button" data-filter-subject="<%= avg.subject %>"><%= avg.subject %></button></strong>: <%= avg.average ? avg.average.toFixed(2) : '–' %>
                    <% if (classAvg && classAvg.average) { %>
                      <small class="text-muted">(Klasse: <%= classAvg.average.toFixed(2) %>)</small>
                    <% } %>
                  </li>
                <% }); %>
              </ul>
            <% } %>
            <h4>Trend</h4>
            <div class="trend-chip trend--<%= trend.direction %>">
              <strong><%= trend.direction === 'improving' ? 'Verbesserung' : trend.direction === 'declining' ? 'Rückgang' : 'Stabil' %></strong>
              <small class="text-muted"><%= trend.message %></small>
            </div>
          </div>
        </section>

        <section id="materials" class="tab-content">
          <div class="card">
            <h3>Materialien</h3>
            <% materials.forEach(function(item){ %>
              <p><strong><%= item.title %></strong> (<%= item.subject %>) — <%= item.fileName %></p>
            <% }); %>
            <div class="upload-box">Datei hochladen</div>
          </div>
        </section>

        <section id="messages" class="tab-content">
          <div class="card">
            <h3>Benachrichtigungen</h3>
            <% if (!messages.length) { %>
              <p class="text-muted">Keine Benachrichtigungen vorhanden.</p>
            <% } else { %>
              <ul>
                <% messages.forEach(function(msg){ %>
                  <li>
                    <strong><%= msg.type %></strong>
                    <small class="text-muted"><%= new Date(msg.created_at).toLocaleString('de-DE') %></small><br>
                    <span><%= msg.message %></span>
                  </li>
                <% }); %>
              </ul>
            <% } %>
          </div>
        </section>
      </main>
    </section>
  </div>
  <div class="modal" id="assignment-modal" aria-hidden="true">
    <div class="modal-backdrop" data-close-assignment></div>
    <div class="modal-body" role="dialog" aria-modal="true" aria-label="Aufgabendetails">
      <button class="modal-close" type="button" data-close-assignment aria-label="Schließen">×</button>
      <div id="assignment-modal-content">
        <p class="text-muted">Wähle eine Aufgabe aus der Liste, um Details zu sehen.</p>
      </div>
    </div>
  </div>
  <script id="assignment-data" type="application/json"><%- JSON.stringify(tasks || []) %></script>
  <script src="/js/app.js"></script>
  <script>
    document.querySelectorAll(".tab").forEach(tab => {
      tab.addEventListener("click", () => setActiveTab(tab.dataset.tab));
    });

    document.querySelectorAll('[data-tab-target]').forEach(link => {
      link.addEventListener('click', (event) => {
        const target = link.getAttribute('data-tab-target');
        if (target) {
          event.preventDefault();
          setActiveTab(target);
          document.getElementById(target)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    function setActiveTab(name) {
      document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === name));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.toggle('active', c.id === name));
      document.querySelectorAll('[data-tab-target]').forEach(link => link.classList.toggle('is-active', link.getAttribute('data-tab-target') === name));
    }

    const assignmentDataEl = document.getElementById('assignment-data');
    const assignmentCache = assignmentDataEl ? JSON.parse(assignmentDataEl.textContent || '[]') : [];
    const assignmentModal = document.getElementById('assignment-modal');
    const assignmentModalContent = document.getElementById('assignment-modal-content');

    function closeAssignmentModal() {
      assignmentModal?.classList.remove('is-open');
      assignmentModal?.setAttribute('aria-hidden', 'true');
    }

    function renderAssignmentDetail(assignment) {
      const attachments = (assignment.attachments || []).length
        ? assignment.attachments
            .map(file => {
              const sizeLabel = file.file_size ? `${Math.round(file.file_size / 102.4) / 10} KB` : 'Größe unbekannt';
              return `<div class="attachment-item"><div><strong>${file.file_name}</strong><br><small class="text-muted">${sizeLabel}</small></div><div class="attachment-actions"><a class="link-button" href="/student/assignments/${assignment.id}/files/${file.id}" target="_blank" rel="noopener">Ansehen</a><a class="link-button" href="/student/assignments/${assignment.id}/files/${file.id}?download=1">Download</a></div></div>`;
            })
            .join('')
        : '<p class="text-muted">Keine Anhänge vorhanden.</p>';

      const statusLabel = assignment.status === 'overdue' ? 'Überfällig' : assignment.status === 'submitted' ? 'Abgegeben' : 'Offen';
      assignmentModalContent.innerHTML = `
        <h3>${assignment.title}</h3>
        <p class="text-muted">${assignment.description || 'Keine Beschreibung hinterlegt.'}</p>
        <div class="assignment-meta">
          <span class="chip">Fach: ${assignment.subject || 'Allgemein'}</span>
          <span class="chip">Fällig: ${assignment.due_date ? new Date(assignment.due_date).toLocaleDateString('de-DE') : 'Kein Datum'}</span>
          <span class="status-pill status-${assignment.status}">${statusLabel}</span>
        </div>
        <h4>Anhänge</h4>
        <div class="attachment-list">${attachments}</div>
      `;
    }

    function openAssignment(assignmentId) {
      assignmentModalContent.innerHTML = '<p class="text-muted">Lade Aufgabendetails ...</p>';
      assignmentModal.classList.add('is-open');
      assignmentModal.setAttribute('aria-hidden', 'false');

      const cached = assignmentCache.find(a => Number(a.id) === Number(assignmentId));
      if (cached) renderAssignmentDetail(cached);

      fetch(`/student/assignments/${assignmentId}`)
        .then(res => (res.ok ? res.json() : Promise.reject()))
        .then(payload => {
          if (!payload?.assignment) return;
          const idx = assignmentCache.findIndex(a => a.id === payload.assignment.id);
          if (idx >= 0) assignmentCache[idx] = payload.assignment;
          else assignmentCache.push(payload.assignment);
          renderAssignmentDetail(payload.assignment);
        })
        .catch(() => {
          assignmentModalContent.innerHTML = '<p class="text-muted">Aufgabendetails konnten nicht geladen werden.</p>';
        });
    }

    document.querySelectorAll('[data-open-assignment]').forEach(card => {
      card.addEventListener('click', (event) => {
        const id = event.currentTarget.getAttribute('data-open-assignment');
        openAssignment(id);
      });
    });

    document.querySelectorAll('[data-close-assignment]').forEach(btn => btn.addEventListener('click', closeAssignmentModal));
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeAssignmentModal();
    });

    const filterForm = document.querySelector('.filter-form');
    function submitSubjectFilter(subject) {
      if (!filterForm) return;
      const select = filterForm.querySelector('select[name="subject"]');
      if (select) select.value = subject || '';
      setActiveTab('grades');
      filterForm.submit();
    }

    document.querySelectorAll('[data-filter-subject]').forEach(el => {
      el.addEventListener('click', (ev) => {
        ev.stopPropagation();
        submitSubjectFilter(el.getAttribute('data-filter-subject'));
      });
    });

    document.querySelectorAll('[data-grade-row]').forEach(row => {
      const detail = row.querySelector('.grade-breakdown');
      if (!detail) return;
      detail.style.display = 'none';
      row.addEventListener('click', () => {
        detail.style.display = detail.style.display === 'none' ? 'block' : 'none';
      });
    });
  </script>
</body>
</html>
