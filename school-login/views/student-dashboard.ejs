<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <title>Schüler-Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <style>
    :root {
      --blue: #124f9c;
      --blue-light: #e4efff;
      --bg: #f6f8fb;
      --card: #ffffff;
      --border: #d9e1ec;
      --radius: 12px;
      --shadow: 0 6px 16px rgba(0,0,0,0.06);
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      font-family: Inter, sans-serif;
      color: #1a1a1a;
    }

    header {
      background: var(--blue);
      padding: 16px 24px;
      color: #fff;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: var(--shadow);
    }

    header h1 { margin: 0; font-size: 20px; }
    header small { font-size: 13px; opacity: 0.9; }

    .tabs {
      display: flex;
      gap: 10px;
      background: #fff;
      padding: 14px 20px;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 10;
    }

    .tab {
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid transparent;
      background: var(--blue-light);
      color: var(--blue);
      cursor: pointer;
      font-weight: 500;
    }

    .tab.active {
      background: var(--blue);
      color: #fff;
    }

    main {
      max-width: 1100px;
      margin: 20px auto;
      padding: 0 20px;
      display: grid;
      gap: 20px;
    }

    .tab-content { display: none; }
    .tab-content.active { display: block; }

    .card {
      background: #fff;
      padding: 18px 20px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
    }

    .accordion {
      border-bottom: 1px solid var(--border);
      padding: 12px 0;
      cursor: pointer;
    }

    .accordion-title {
      display: flex;
      justify-content: space-between;
      font-weight: 600;
      font-size: 15px;
    }

    .accordion-content {
      display: none;
      padding: 10px 0 4px;
      font-size: 14px;
      color: #333;
    }

    .pill {
      background: var(--blue-light);
      color: var(--blue);
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 500;
    }

    .upload-box {
      margin-top: 8px;
      padding: 10px;
      border-radius: var(--radius);
      border: 1px dashed var(--border);
      background: #fafafa;
      cursor: pointer;
      font-size: 13px;
    }

    .file-list {
      margin-top: 6px;
      font-size: 12px;
      color: #777;
    }
    .htl-small {
      width: 48px;
      height: 48px;
      object-fit: contain;
      border-radius: 8px;
      margin-right: 12px;
      vertical-align: middle;
      background: white;
      padding: 4px;
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .header-right {
      text-align: right;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 6px;
    }

    .logout-form { margin-top: 6px; }
    .logout-form .logout-button {
      padding: 8px 14px;
      border-radius: 8px;
      font-weight: 700;
      border: none;
      cursor: pointer;
      background: rgba(255,255,255,0.12);
      color: #fff;
      transition: all 0.15s ease;
    }
    .logout-form .logout-button:hover { background: rgba(255,255,255,0.18); transform: translateY(-2px); }

  </style>
</head>

<body>
<header>
  <div class="header-left">
    <img src="/images/htl-waidhofen.png" alt="HTL Waidhofen" class="htl-small" onerror="this.style.display='none'">
    <div>
      <h1><%= hero.headline %></h1>
      <small><%= hero.summary %></small>
    </div>
  </div>
  <div class="header-right">
    <div>
      <strong><%= studentProfile.name %></strong><br>
      <small>Klasse <%= studentProfile.class %></small><br>
      <small><%= email %></small>
    </div>
    <form class="logout-form" method="POST" action="/logout">
      <% if (typeof csrfToken !== 'undefined') { %>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% } %>
      <button class="logout-button" type="submit">Logout</button>
    </form>
  </div>
</header>

<div class="tabs">
  <div class="tab active" data-tab="overview">Übersicht</div>
  <div class="tab" data-tab="tasks">Aufgaben</div>
  <div class="tab" data-tab="returns">Rückgaben</div>
  <div class="tab" data-tab="grades">Noten</div>
  <div class="tab" data-tab="materials">Materialien</div>
  <div class="tab" data-tab="messages">Nachrichten</div>
</div>

<main>

  <!-- ÜBERSICHT -->
  <section id="overview" class="tab-content active">
    <article class="card">
      <h2>Willkommen, <%= studentProfile.name %>!</h2>
      <p>Das Wichtigste für dich auf einen Blick:</p>

      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:12px; margin-top:12px;">
        <% studentProfile.meta.forEach(m => { %>
          <div class="card" style="padding:12px;">
            <small style="color:#666;"><%= m.label %></small>
            <div style="font-size:20px; font-weight:600;"><%= m.value %></div>
          </div>
        <% }) %>
      </div>
    </article>

    <article class="card">
      <h2>Neueste Rückgabe</h2>
      <% if (returns.length) { %>
        <div class="accordion">
          <div class="accordion-title">
            <%= returns[0].title %> — <span class="pill">Note: <%= returns[0].grade %></span>
          </div>
          <div class="accordion-content">
            <p><strong>Feedback:</strong> <%= returns[0].feedback %></p>
          </div>
        </div>
      <% } else { %>
        <p>Keine Rückgaben vorhanden.</p>
      <% } %>
    </article>
  </section>

  <!-- AUFGABEN -->
  <section id="tasks" class="tab-content">
    <article class="card">
      <h2>Aufgaben</h2>

      <% tasks.forEach(t => { %>
        <div class="accordion">
          <div class="accordion-title">
            <%= t.title %> — <span class="pill"><%= t.status %></span>
          </div>

          <div class="accordion-content">
            <p><strong>Fach:</strong> <%= t.subject %></p>
            <p><strong>Fällig:</strong> <%= t.due %></p>
            <p><%= t.description %></p>

            <% if (t.attachments.length) { %>
              <p><small>Materialien: <%= t.attachments.join(", ") %></small></p>
            <% } %>

            <div class="upload-box" data-task-id="<%= t.id %>">
              Datei hochladen…
            </div>
            <input id="file-input-<%= t.id %>" type="file" multiple style="display:none;">
            <div id="file-list-<%= t.id %>" class="file-list"></div>
          </div>
        </div>
      <% }) %>
    </article>
  </section>

  <!-- RÜCKGABEN -->
  <section id="returns" class="tab-content">
    <article class="card">
      <h2>Bewertete Aufgaben</h2>

      <% returns.forEach(r => { %>
        <div class="accordion">
          <div class="accordion-title">
            <%= r.title %> — <span class="pill">Note <%= r.grade %></span>
          </div>
          <div class="accordion-content">
            <p><strong>Fach:</strong> <%= r.subject %></p>
            <p><strong>Lehrer:</strong> <%= r.teacher %></p>
            <p><%= r.feedback %></p>

            <% if (r.attachments.length) { %>
              <p><small>Lösungsdokument: <%= r.attachments.join(", ") %></small></p>
            <% } %>
          </div>
        </div>
      <% }) %>
    </article>
  </section>

  <!-- NOTEN -->
  <section id="grades" class="tab-content">
    <article class="card">
      <h2>Notenübersicht</h2>

      <% grades.forEach(g => { %>
        <div class="accordion">
          <div class="accordion-title">
            <%= g.subject %> — <span class="pill">Note <%= g.grade %></span>
          </div>
          <div class="accordion-content">
            <p><strong>Lehrer:</strong> <%= g.teacher %></p>
            <p><strong>Gewichtung:</strong> <%= g.weight %></p>
          </div>
        </div>
      <% }) %>
    </article>
  </section>

  <!-- MATERIALIEN -->
  <section id="materials" class="tab-content">
    <article class="card">
      <h2>Materialien</h2>

      <% materials.forEach(m => { %>
        <div class="accordion">
          <div class="accordion-title">
            <%= m.title %> — <%= m.subject %>
          </div>

          <div class="accordion-content">
            <p>Datei: <%= m.fileName %></p>
          </div>
        </div>
      <% }) %>
    </article>
  </section>

  <!-- NACHRICHTEN -->
  <section id="messages" class="tab-content">
    <article class="card">
      <h2>Nachrichten</h2>

      <% messages.forEach(msg => { %>
        <div class="accordion">
          <div class="accordion-title">
            <%= msg.title %> — <span class="pill">Von <%= msg.sender %></span>
          </div>

          <div class="accordion-content">
            <p><%= msg.excerpt %></p>
          </div>
        </div>
      <% }) %>
    </article>
  </section>

</main>

<script>
  // Tabs
  document.querySelectorAll(".tab").forEach(tab => {
    tab.addEventListener("click", () => {
      document.querySelectorAll(".tab").forEach(t => t.classList.remove("active"));
      document.querySelectorAll(".tab-content").forEach(c => c.classList.remove("active"));

      tab.classList.add("active");
      document.getElementById(tab.dataset.tab).classList.add("active");
    });
  });

  // Accordion Handling
  document.addEventListener("click", (e) => {
    if (e.target.closest(".accordion")) {
      const acc = e.target.closest(".accordion");
      const content = acc.querySelector(".accordion-content");
      content.style.display = content.style.display === "block" ? "none" : "block";
    }
  });

  // File Upload UI
  document.querySelectorAll(".upload-box").forEach(box => {
    const taskId = box.dataset.taskId;
    const input = document.getElementById("file-input-" + taskId);
    const list = document.getElementById("file-list-" + taskId);

    box.addEventListener("click", () => input.click());

    input.addEventListener("change", () => {
      list.innerHTML = "";
      [...input.files].forEach(f => {
        const div = document.createElement("div");
        div.textContent = f.name;
        list.appendChild(div);
      });
    });
  });
</script>

</body>
</html>
